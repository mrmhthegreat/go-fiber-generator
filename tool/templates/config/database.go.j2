package config

import (
    "context"
    "log"
    "os"
    "time"

{% if config.fcm.enabled %}
    firebase "firebase.google.com/go/v4"
    firebaseApp "firebase.google.com/go/v4/app"
    "google.golang.org/api/option"
{% endif %}
    "github.com/spf13/viper"
    "go.uber.org/zap"
{% if config.analytics.google.enabled %}
    analyticsdata "google.golang.org/api/analyticsdata/v1beta"
{% endif %}
    "gorm.io/driver/postgres"
    "gorm.io/gorm"

    "{{ config.project.module }}/internal/models"
)

// ---------------------------------------------------------------------------
// Storage Configuration Structs
// ---------------------------------------------------------------------------

{% if config.storage.enabled %}
{% if config.storage.local %}
type LocalStorageConfig struct {
    UploadPath string
    BaseURL    string
}
{% elif config.storage.s3 %}
type S3StorageConfig struct {
    Endpoint        string
    Region          string
    Bucket          string
    AccessKeyID     string
    SecretAccessKey string
    UseSSL          bool
}
{% elif config.storage.supabase %}
type SupabaseConfig struct {
    URL    string
    Token  string
    Bucket string
}
{% endif %}

type StorageConfig struct {
    Provider string
    {% if config.storage.local %}
    Local    LocalStorageConfig
    {% elif config.storage.s3 %}
    S3       S3StorageConfig
    {% elif config.storage.supabase %}
    Supabase SupabaseConfig
    {% endif %}
}

// StorageRuntime holds the resolved storage config values at runtime.
var StorageRuntime StorageConfig
{% endif %}

{% if config.fcm.enabled %}
// InitializeFirebaseApp initializes Firebase application
func InitializeFirebaseApp() (*firebaseApp.App, error) {
    ctx := context.Background()

    opt := option.WithCredentialsFile(viper.GetString("{{ config.fcm.credentials_path_env }}"))
    c := &firebase.Config{
        ProjectID: viper.GetString("{{ config.fcm.project_id_env }}"),
    }

    app, err := firebase.NewApp(ctx, c, opt)
    if err != nil {
        return nil, err
    }

    return app, nil
}
{% endif %}

// Global configuration variables
var (
{% if config.features.maintenance_mode %}
    Maintinace           bool
{% endif %}
)

// Global service instances
var (
{% if config.fcm.enabled %}
    FCM             *firebaseApp.App
{% endif %}
    LOGGER          *zap.Logger

    DB              *gorm.DB
)

// Init initializes all configuration and services
func Init() {
    var err error

    // Initialize logger
    LOGGER, err = zap.NewProduction()
    if err != nil {
        log.Fatal("Failed to initialize logger")
    }
    defer LOGGER.Sync()

{% if config.fcm.enabled %}
    // Initialize Firebase
    FCM, err = InitializeFirebaseApp()
    if err != nil {
        LOGGER.Fatal("Failed to initialize Firebase")
    }
{% endif %}

    // Set default configuration values
    setDefaults()

    // Load configuration from file
    viper.SetConfigName("config")
    viper.AddConfigPath(".")
    if err := viper.ReadInConfig(); err != nil {
        LOGGER.Warn("No config file found, using defaults", zap.Error(err))
    }

    // Also read from environment variables (override file)
    viper.AutomaticEnv()

    // Load required environment variables
    loadRequiredConfig()

    // Initialize database
    InitDB()
}

// setDefaults sets default configuration values
func setDefaults() {
    viper.SetDefault("{{config.database.url_env}}", "DATABASE_URL")
{% if config.redis.enabled %}
    viper.SetDefault("{{config.redis.host_env}}", "localhost:6379")
{% endif %}
{% if config.email.enabled %}
    viper.SetDefault("{{config.email.smtp_user_env}}", "SMTP_EMAIL")
    viper.SetDefault("{{config.email.smtp_password_env}}", "SMTP_PASSWORD")
    viper.SetDefault("{{config.email.smtp_host_env}}", "SMTP_HOST")
    viper.SetDefault("{{config.email.smtp_port_env}}", 587)
{% endif %}
{% if config.session.enabled %}
    viper.SetDefault("{{config.session.secret_key_env}}", "SESSION_SECRET_KEY")
    viper.SetDefault("{{config.session.cookies_secret_key_env}}", "COKIES_SECRET_KEY")
{% endif %}
{% if config.authentication.social_auth.google.enabled %}
    viper.SetDefault("{{config.authentication.social_auth.google.client_id_env}}", "GOOGLE_CLIENT_ID")
    viper.SetDefault("{{config.authentication.social_auth.google.client_secret_env}}", "GOOGLE_CLIENT_SECRET")
    viper.SetDefault("{{config.authentication.social_auth.google.redirect_url_env}}", "GOOGLE_REDIRECT_URL")
{% endif %}
{% if config.authentication.social_auth.facebook.enabled %}
    viper.SetDefault("{{config.authentication.social_auth.facebook.app_id_env}}", "FACEBOOK_APP_ID")
    viper.SetDefault("{{config.authentication.social_auth.facebook.app_secret_env}}", "FACEBOOK_APP_SECRET")
    viper.SetDefault("{{config.authentication.social_auth.facebook.redirect_url_env}}", "FACEBOOK_REDIRECT_URL")
{% endif %}

{% if config.features.maintenance_mode %}
    viper.SetDefault("MaintenanceMode", false)
{% endif %}


{% if config.storage.enabled %}
    // Storage defaults — override via env vars or config.yaml
    viper.SetDefault("{{ config.storage.provider_env }}", "local")

    // Local
    {% if config.storage.local %}
    viper.SetDefault("{{ config.storage.local.upload_path_env }}", "./public/uploads")
    viper.SetDefault("{{ config.storage.local.base_url_env }}", "/uploads")
    // S3 / MinIO 
    {% elif config.storage.s3 %}
    viper.SetDefault("{{ config.storage.s3.endpoint_env }}", "s3.amazonaws.com")
    viper.SetDefault("{{ config.storage.s3.region_env }}", "us-east-1")
    viper.SetDefault("{{ config.storage.s3.bucket_env }}", "my-bucket")
    viper.SetDefault("{{ config.storage.s3.access_key_id_env }}", "")
    viper.SetDefault("{{ config.storage.s3.secret_access_key_env }}", "")
    viper.SetDefault("{{ config.storage.s3.use_ssl_env }}", true)
    // Supabase
    {% elif config.storage.supabase %}
    viper.SetDefault("{{ config.storage.supabase.url_env }}", "")
    viper.SetDefault("{{ config.storage.supabase.token_env }}", "")
    viper.SetDefault("{{ config.storage.supabase.bucket_name_env }}", "storage")
    {% endif %}
{% endif %}
    viper.SetDefault("RUN_MIGRATIONS", true)
}

// loadRequiredConfig loads and validates required configuration
func loadRequiredConfig() {
{% if config.features.maintenance_mode %}
    Maintinace = viper.GetBool("MaintenanceMode")
{% endif %}

    JwtSecret = viper.GetString("JWT_SECRET")
    if JwtSecret == "" || JwtSecret == "default-secret" {
        log.Fatal("JWT_SECRET not set or using default value")
    }

    AppSecret = viper.GetString("APP_SECRET")
    if AppSecret == "" {
        log.Fatal("APP_SECRET not set")
    }

    AppID = viper.GetString("APP_ID")
    if AppID == "" {
        log.Fatal("APP_ID not set")
    }

    SignSecret = viper.GetString("SIGN_SECRET")
    if SignSecret == "" {
        log.Fatal("SIGN_SECRET not set")
    }




{% if config.storage.enabled %}
    // Build the global StorageRuntime from viper values.
    StorageRuntime = StorageConfig{
        Provider: viper.GetString("{{ config.storage.provider_env }}"),
        {% if config.storage.local %}
        Local: LocalStorageConfig{
            UploadPath: viper.GetString("{{ config.storage.local.upload_path_env }}"),
            BaseURL:    viper.GetString("{{ config.storage.local.base_url_env }}"),
        },
        {% elif config.storage.s3 %}
        S3: S3StorageConfig{    
            Endpoint:        viper.GetString("{{ config.storage.s3.endpoint_env }}"),
            Region:          viper.GetString("{{ config.storage.s3.region_env }}"),
            Bucket:          viper.GetString("{{ config.storage.s3.bucket_env }}"),
            AccessKeyID:     viper.GetString("{{ config.storage.s3.access_key_id_env }}"),
            SecretAccessKey: viper.GetString("{{ config.storage.s3.secret_access_key_env }}"),
            UseSSL:          viper.GetBool("{{ config.storage.s3.use_ssl_env }}"),
        },
        {% elif config.storage.supabase %}
        Supabase: SupabaseConfig{   
            URL:    viper.GetString("{{ config.storage.supabase.url_env }}"),
            Token:  viper.GetString("{{ config.storage.supabase.token_env }}"),
            Bucket: viper.GetString("{{ config.storage.supabase.bucket_name_env }}"),
        },
        {% endif %}
    }
{% endif %}
}

// InitDB initializes the database connection
func InitDB() {
    var err error

    dsn := viper.GetString("{{ config.database.url_env }}")
    if dsn == "" {
        log.Fatal("DATABASE_URL not set")
    }

    // Open database connection
    database, err := gorm.Open(postgres.Open(dsn), &gorm.Config{})
    if err != nil {
        LOGGER.Fatal("Failed to connect to database")
        os.Exit(2)
    }

    // Configure connection pool
    sqlDB, err := database.DB()
    if err != nil {
        panic("failed to get sql.DB: " + err.Error())
    }

    sqlDB.SetMaxOpenConns({{ config.database.max_open_conns | default(10) }})
    sqlDB.SetMaxIdleConns({{ config.database.max_idle_conns | default(5) }})
    sqlDB.SetConnMaxLifetime({{ config.database.conn_max_lifetime | default('5 * time.Minute') }})

    // Run migrations if enabled
    if viper.GetBool("RUN_MIGRATIONS") {
        err = database.AutoMigrate(
{% for model in config.models | default([]) %}
            &models.{{ model.name }}{},
{% endfor %}
{% if config.chat.enabled %}
            &models.Conversation{},
            &models.Message{},
{% endif %}
{% if config.notifications.enabled %}
            &models.Notification{},
{% endif %}
{% if config.rbac.enabled %}
            &models.Role{},
            &models.Permission{},
{% endif %}
        )
        if err != nil {
            LOGGER.Warn("Failed to migrate the database")
            panic(err)
        }
    }

    DB = database
    // Storage is initialized separately via storage.Init() in main.go
}