# =============================================================================
# Generated App Configuration
# Generated by master_generator.py from {{ config.project.module }}
# Copy this to config.yaml and fill in your real values
# =============================================================================

# --- Database ---
{{ config.database.url_env | default('DATABASE_URL') }}: "postgres://user:password@localhost:5432/dbname?sslmode=disable"

{% if config.redis.enabled %}
# --- Redis ---
{{ config.redis.host_env | default('REDIS_ADDR') }}: "localhost:6379"
{{ config.redis.password_env | default('REDIS_PASSWORD') }}: ""
{{ config.redis.db_env | default('REDIS_DB') }}: "0"
{% if config.redis.session_addr_env is defined %}
{{ config.redis.session_addr_env }}: "localhost:6379"
{% endif %}
{% endif %}

# --- JWT / Auth ---
JWT_SECRET: "change-me-to-a-very-long-random-secret"
APP_SECRET: "change-me-to-another-secret"
APP_ID: "my-app-id"
{% if config.authentication.jwt is defined and config.authentication.jwt.secret_key_env is defined %}
{{ config.authentication.jwt.secret_key_env }}: "change-me-to-a-very-long-random-secret"
{% endif %}

{% if config.middleware is defined %}
{% for mw in config.middleware.definitions | default([]) %}
{% if mw.type in ['jwt', 'api_key', 'signature'] and mw.secret_key_env is defined %}
{{ mw.secret_key_env }}: "change-me-{{ mw.name }}-secret"
{% endif %}
{% endfor %}
{% endif %}

SIGN_SECRET: "change-me-sign-secret"

{% if config.session.enabled %}
# --- Session ---
{{ config.session.secret_key_env | default('SESSION_SECRET_KEY') }}: "change-me-session-secret"
{{ config.session.cookies_secret_env | default('COOKIES_SECRET_KEY') }}: "change-me-cookies-secret"
{% endif %}

{% if config.email.enabled %}
# --- SMTP Email ---
{{ config.email.smtp_host_env | default('SMTP_HOST') }}: "smtp.gmail.com"
{{ config.email.smtp_port_env | default('SMTP_PORT') }}: "587"
{{ config.email.smtp_user_env | default('SMTP_EMAIL') }}: "your-email@gmail.com"
{{ config.email.smtp_password_env | default('SMTP_PASSWORD') }}: "your-app-password"
{{ config.email.from_name_env | default('SMTP_FROM_NAME') }}: "{{ config.project.module | regex_replace('.*/', '') | title }}"
{% endif %}

{% if config.imap.enabled %}
# --- IMAP (incoming email) ---
{{ config.imap.host_env | default('IMAP_HOST') }}: "imap.gmail.com"
{{ config.imap.port_env | default('IMAP_PORT') }}: "993"
{{ config.imap.user_env | default('IMAP_USER') }}: "your-email@gmail.com"
{{ config.imap.password_env | default('IMAP_PASSWORD') }}: "your-app-password"
{% endif %}

{% if config.fcm.enabled %}
# --- FCM (Firebase Cloud Messaging) ---
{{ config.fcm.credentials_path_env | default('FCM_CREDENTIALS_PATH') }}: "./serviceAccountKey.json"
{{ config.fcm.project_id_env | default('FCM_PROJECT_ID') }}: "your-firebase-project-id"
{% if config.fcm.admin_topic_env is defined %}
{{ config.fcm.admin_topic_env }}: "admin"
{% endif %}
{% endif %}

{% if config.storage.enabled %}
# --- Storage ---
{{ config.storage.provider_env | default('STORAGE_PROVIDER') }}: "local"
{% if config.storage.local %}
{{ config.storage.local.upload_path_env | default('STORAGE_UPLOAD_PATH') }}: "./public/uploads"
{{ config.storage.local.base_url_env | default('STORAGE_BASE_URL') }}: "/uploads"
{% endif %}
{% if config.storage.s3 %}
{{ config.storage.s3.endpoint_env | default('S3_ENDPOINT') }}: "s3.amazonaws.com"
{{ config.storage.s3.region_env | default('S3_REGION') }}: "us-east-1"
{{ config.storage.s3.bucket_env | default('S3_BUCKET') }}: "my-bucket"
{{ config.storage.s3.access_key_id_env | default('S3_ACCESS_KEY_ID') }}: ""
{{ config.storage.s3.secret_access_key_env | default('S3_SECRET_ACCESS_KEY') }}: ""
{{ config.storage.s3.use_ssl_env | default('S3_USE_SSL') }}: "true"
{% endif %}
{% if config.storage.supabase %}
{{ config.storage.supabase.url_env | default('SUPABASE_URL') }}: "https://your-project.supabase.co"
{{ config.storage.supabase.token_env | default('SUPABASE_SERVICE_TOKEN') }}: "your-service-role-key"
{{ config.storage.supabase.bucket_name_env | default('SUPABASE_BUCKET') }}: "storage"
{% endif %}
{% endif %}

{% if config.authentication.social_auth is defined %}
{% if config.authentication.social_auth.google.enabled %}
# --- Google OAuth ---
{{ config.authentication.social_auth.google.client_id_env | default('GOOGLE_CLIENT_ID') }}: "your-google-client-id"
{{ config.authentication.social_auth.google.client_secret_env | default('GOOGLE_CLIENT_SECRET') }}: "your-google-client-secret"
{{ config.authentication.social_auth.google.redirect_url_env | default('GOOGLE_REDIRECT_URL') }}: "http://localhost:3000/auth/google/callback"
{% endif %}
{% if config.authentication.social_auth.facebook.enabled %}
# --- Facebook OAuth ---
{{ config.authentication.social_auth.facebook.app_id_env | default('FACEBOOK_APP_ID') }}: "your-facebook-app-id"
{{ config.authentication.social_auth.facebook.app_secret_env | default('FACEBOOK_APP_SECRET') }}: "your-facebook-app-secret"
{{ config.authentication.social_auth.facebook.redirect_url_env | default('FACEBOOK_REDIRECT_URL') }}: "http://localhost:3000/auth/facebook/callback"
{% endif %}
{% endif %}

{% if config.analytics is defined and config.analytics.google is defined and config.analytics.google.enabled %}
# --- Google Analytics ---
{{ config.analytics.google.credentials_env | default('GOOGLE_ANALYTICS_CREDENTIALS') }}: "./analytics-credentials.json"
{{ config.analytics.google.property_id_env | default('GOOGLE_ANALYTICS_PROPERTY_ID') }}: "your-property-id"
{% endif %}

# --- Server ---
PORT: "{{ config.server.default_port | default('3000') }}"
RUN_MIGRATIONS: "true"
