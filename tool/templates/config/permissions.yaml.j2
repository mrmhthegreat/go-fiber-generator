{#
  permissions.yaml.j2
  ───────────────────
  Fully driven by config.rbac.roles — every role's permissions and
  permission_allowed lists are generated from the YAML config.

  Fallback: if a role has no explicit permissions list defined in
  config, it will still appear in the roles section with an empty list.
  The superadmin role always receives the wildcard "*" grant.

  Config paths used:
    config.rbac.roles[]           — list of role objects: name, dashboard_path, permissions, permissions_allowed
    config.rbac.all_privileges    — the role name that gets wildcard "*"
    config.models[]               — auto-generate CRUD permission keys per model
    config.authentication.enabled — gate for auth permissions
    config.notifications.enabled  — gate for notification permissions
    config.chat.enabled           — gate for chat permissions
    config.imap.enabled           — gate for email/imap permissions
    config.fcm.enabled            — gate for fcm/push permissions
    config.rbac.enabled           — gate for rbac.* permissions
#}

# =============================================================================
# PERMISSIONS
# Generated from config.rbac.roles — do not edit manually.
# =============================================================================

permissions:

  # ── Auth ──────────────────────────────────────────────────────────────────
  {% if config.authentication.enabled %}
  - key: auth.login
    display_name: Login
    description: Authenticate and receive a token
    category: auth

  - key: auth.register
    display_name: Register
    description: Create a new account
    category: auth

  - key: profile.view
    display_name: View Profile
    description: View own profile
    category: profile

  - key: profile.edit
    display_name: Edit Profile
    description: Edit own profile
    category: profile

  - key: users.view
    display_name: View Users
    description: View all users in the system
    category: users

  - key: users.manage
    display_name: Manage Users
    description: Full user management (block, roles, wallet, etc.)
    category: users

  - key: users.block
    display_name: Block Users
    description: Block or unblock users
    category: users

  - key: users.manage_roles
    display_name: Manage User Roles
    description: Assign roles to users
    category: users
  {% endif %}

  # ── Models (auto-generated from config.models) ─────────────────────────────
  {% for model in config.models %}
  {% set ml = model.name | lower %}
  {% set ctrl = model.controller | default({}) %}
  {% set crud = ctrl.crud_settings | default({}) %}
  {% if ctrl.enabled | default(true) %}

  {% if (crud['list'] is defined and crud['list'].enabled) or (crud['get'] is defined and crud['get'].enabled) %}
  - key: {{ ml }}.view
    display_name: View {{ model.name }}
    description: List and view all {{ model.name }} records
    category: {{ ml }}
  {% endif %}

  {% if crud['create'] is defined and crud['create'].enabled %}
  - key: {{ ml }}.create
    display_name: Create {{ model.name }}
    description: Create new {{ model.name }} records
    category: {{ ml }}
  {% endif %}

  {% if crud['update'] is defined and crud['update'].enabled %}
  - key: {{ ml }}.update
    display_name: Update {{ model.name }}
    description: Update existing {{ model.name }} records
    category: {{ ml }}
  {% endif %}

  {% if crud['delete'] is defined and crud['delete'].enabled %}
  - key: {{ ml }}.delete
    display_name: Delete {{ model.name }}
    description: Delete {{ model.name }} records
    category: {{ ml }}
  {% endif %}

  {% endif %}
  {% endfor %}

  # ── Notifications / FCM ────────────────────────────────────────────────────
  {% if config.notifications.enabled %}
  - key: notifications.send
    display_name: Send Notifications
    description: Send push notifications and in-app alerts
    category: notifications

  - key: notifications.view
    display_name: View Notifications
    description: View notification history and status
    category: notifications
  {% endif %}

  {% if config.fcm.enabled %}
  - key: fcm.send
    display_name: Send FCM Push
    description: Send Firebase Cloud Messaging push notifications
    category: fcm

  - key: fcm.subscribe
    display_name: Subscribe to FCM Topic
    description: Subscribe devices to FCM topics
    category: fcm
  {% endif %}

  # ── Chat ───────────────────────────────────────────────────────────────────
  {% if config.chat.enabled %}
  - key: chat.view
    display_name: View Chat
    description: View chat messages and conversations
    category: chat

  - key: chat.manage
    display_name: Manage Chat
    description: Full chat management (delete messages, moderate)
    category: chat
  {% endif %}

  # ── Email / IMAP ───────────────────────────────────────────────────────────
  {% if config.imap.enabled %}
  - key: mail.view
    display_name: View Mail
    description: View incoming and sent emails
    category: mail

  - key: mail.manage
    display_name: Manage Mail
    description: Send, delete, and manage emails
    category: mail
  {% endif %}

  # ── RBAC Management ────────────────────────────────────────────────────────
  {% if config.rbac.enabled %}
  - key: rbac.roles.manage
    display_name: Manage RBAC Roles
    description: Create, update, and delete roles
    category: rbac

  - key: rbac.overrides.manage
    display_name: Manage Permission Overrides
    description: Set user-level permission overrides
    category: rbac

  - key: rbac.permissions.manage
    display_name: Manage Permissions
    description: Sync and view the permission registry
    category: rbac
  {% endif %}

  # ── Dashboard ──────────────────────────────────────────────────────────────
  {% for role in config.rbac.roles %}
  - key: {{ role.name }}.dashboard.view
    display_name: View {{ role.name | title }} Dashboard
    description: Access to the {{ role.name }} dashboard section
    category: dashboard
  {% endfor %}

  # ── System ─────────────────────────────────────────────────────────────────
  - key: system.config
    display_name: System Configuration
    description: Manage system-level configuration
    category: system

  - key: system.rbac
    display_name: RBAC Management
    description: Full RBAC administration
    category: system


# =============================================================================
# ROLE DEFAULTS
# Generated from config.rbac.roles[].permissions and .permissions_allowed.
#
# Each role entry contains:
#   <role_name>         — permissions granted by default when role is assigned
#   <role_name>_allowed — full set of permissions that CAN be granted to this role
#
# The role named config.rbac.all_privileges gets the wildcard "*" grant.
# =============================================================================

role_defaults:
  {% for role in config.rbac.roles %}
  {% if role.name == config.rbac.all_privileges %}
  # {{ role.name | title }}: superadmin — wildcard grant (handled in code)
  {{ role.name }}:
    - "*"

  {% else %}
  # ── {{ role.name | title }} ───────────────────────────────────────────────
  {{ role.name }}:
    # Dashboard
    - {{ role.name }}.dashboard.view
    # Profile (every role gets basic profile access)
    - profile.view
    - profile.edit
    {% if role.permissions is defined and role.permissions %}
    {% for perm in role.permissions %}
    - {{ perm }}
    {% endfor %}
    {% endif %}

  {{ role.name }}_allowed:
    - {{ role.name }}.dashboard.view
    - profile.view
    - profile.edit
    {% if role.permissions_allowed is defined and role.permissions_allowed %}
    {% for perm in role.permissions_allowed %}
    - {{ perm }}
    {% endfor %}
    {% elif role.permissions is defined and role.permissions %}
    # Same as defaults (no explicit allowed set configured)
    {% for perm in role.permissions %}
    - {{ perm }}
    {% endfor %}
    {% endif %}

  {% endif %}
  {% endfor %}