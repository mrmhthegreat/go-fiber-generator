# Build stage
FROM golang:{{ config.project.go_version }}-alpine AS builder

# Install build dependencies
RUN apk add --no-cache git

# Set working directory
WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Build the application
{% if config.project.structure.use_cmd %}
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o main ./cmd/{{ config.project.structure.cmd_name }}
{% else %}
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o main .
{% endif %}

# Runtime stage
FROM alpine:latest

# Install ca-certificates for HTTPS
RUN apk --no-cache add ca-certificates

WORKDIR /root/

# Copy binary from builder
COPY --from=builder /app/main .

# Copy config file
COPY --from=builder /app/config.yaml .

{% if config.template_engine.enabled %}
# Copy templates
COPY --from=builder /app/{{ config.template_engine.template_dir }} ./{{ config.template_engine.template_dir }}
{% endif %}

{% if config.static_files.enabled %}
# Copy static files
COPY --from=builder /app/{{ config.static_files.directory }} ./{{ config.static_files.directory }}
{% endif %}

# Expose port
EXPOSE {{ config.server.port }}

# Run the application
CMD ["./main"]
