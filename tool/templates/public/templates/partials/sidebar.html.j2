<aside id="sidebar" class="fixed left-0 top-0 z-40 h-screen w-64 -translate-x-full border-r border-gray-200 bg-white transition-transform dark:border-gray-700 dark:bg-gray-800 lg:translate-x-0">
    <div class="flex h-full flex-col">
        <!-- Sidebar Header -->
        <div class="flex h-16 items-center border-b border-gray-200 px-6 dark:border-gray-700">
            <span class="text-xl font-bold text-primary">{{ config.project.name | default('Admin') }}</span>
        </div>

        <!-- Sidebar Navigation -->
        <nav class="flex-1 space-y-1 overflow-y-auto px-4 py-4">
            <!-- Dashboard Home -->
            <a href="/dashboard" class="group flex items-center rounded-lg px-2 py-2 text-sm font-medium {{ 'bg-gray-100 text-primary dark:bg-gray-700 dark:text-white' if active_page == 'Dashboard' else 'text-gray-600 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white' }}">
                <svg class="mr-3 h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Dashboard
            </a>
            <!-- Model CRUD Links -->
            {% if repo.models %}
            <div class="pt-4 pb-2">
                <p class="px-2 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">Management</p>
            </div>
            {% for model in repo.models %}
            {% if model.web_handler.enabled %}
            <a href="/dashboard/{{ model.name | lower }}" class="group flex items-center rounded-lg px-2 py-2 text-sm font-medium {{ 'bg-gray-100 text-primary dark:bg-gray-700 dark:text-white' if active_page == model.name else 'text-gray-600 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white' }}">
                <svg class="mr-3 h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                {{ model.name }}
            {% endif %}
            {% endfor %}
            <!-- Features -->
            {% if (chat and chat.enabled) or (authentication and authentication.rbac and authentication.rbac.enabled) %}
                <p class="px-2 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">Features</p>
            {% if chat and chat.enabled %}
            <a href="/dashboard/chat" class="group flex items-center rounded-lg px-2 py-2 text-sm font-medium {{ 'bg-gray-100 text-primary dark:bg-gray-700 dark:text-white' if active_page == 'Chat' else 'text-gray-600 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white' }}">
                <svg class="mr-3 h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                Chat
            
            {% if authentication and authentication.rbac and authentication.rbac.enabled %}
            <a href="/dashboard/rbac" class="group flex items-center rounded-lg px-2 py-2 text-sm font-medium {{ 'bg-gray-100 text-primary dark:bg-gray-700 dark:text-white' if active_page == 'RBAC' else 'text-gray-600 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white' }}">
                <svg class="mr-3 h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                RBAC
        </nav>
        <!-- Sidebar Footer -->
        <div class="border-t border-gray-200 p-4 dark:border-gray-700">
            <div class="flex items-center gap-3">
                <img src="/static/image/avatar.png" class="h-8 w-8 rounded-full" alt="User">
                <div class="flex-1 overflow-hidden">
                    <p class="truncate text-sm font-medium text-gray-900 dark:text-white">Admin</p>
                    <p class="truncate text-xs text-gray-500 dark:text-gray-400">admin@example.com</p>
                </div>
    </div>
</aside>
