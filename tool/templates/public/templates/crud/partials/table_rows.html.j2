{{- /*
  table_rows.html.j2 → rendered as a Go HTML partial template
  Used via HTMX swap into: #[[ model.name | lower ]]-table-container
  Context: .items (list), .csrfToken
*/ -}}
{{define "[[ handler.template_base ]]/partials/[[ model.name | lower ]]_table_rows"}}
  [% set has_show = handler.crud_settings is defined and handler.crud_settings.get('get', {}).enabled %]
  [% set has_edit   = handler.crud_settings is defined and handler.crud_settings.get('update', {}).enabled %]
  [% set has_delete = handler.crud_settings is defined and handler.crud_settings.get('delete', {}).enabled %]
{{range .items}}
<tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800/50 transition-colors cursor-pointer"
    data-[[ model.name | lower ]]-id="{{.ID}}"
    [% if has_show %]
    @click.self="open[[ model.name ]]DetailsView({{.ID}})"
    [% endif %]>
  [% set display_fields = model.list_response.fields if model.list_response is defined and model.list_response.enabled else model.fields %]
  [% for field in display_fields %]
  [% set field_json = field.json_name | default(field.json) | default(field.name | lower) %]
  [% if field_json != '-' and field.name | lower not in ['id', 'password'] %]
  <td class="px-6 py-4 whitespace-nowrap"
      [% if has_show %]@click="open[[ model.name ]]DetailsView({{.ID}})"[% endif %]>
    [% if 'avatar' in field_json or 'image' in field_json or 'photo' in field_json or 'picture' in field_json %]
    <img src="{{.[[ field.name ]]}}" class="h-10 w-10 rounded-full border border-gray-200 object-cover dark:border-gray-600" onerror="this.src='/static/images/placeholder.png'" alt="[[ field.name ]]" />
    [% elif field.type == 'bool' %]
    {{if .[[ field.name ]]}}
    <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700 dark:bg-green-900/20 dark:text-green-400">Active</span>
    {{else}}
    <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-700 dark:text-gray-400">Inactive</span>
    {{end}}
    [% elif 'role' in field_json or 'status' in field_json %]
    <span class="inline-flex items-center rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-semibold uppercase text-brand-700 dark:bg-brand-900/20 dark:text-brand-400">{{.[[ field.name ]]}}</span>
    [% else %]
    <span class="text-sm text-gray-900 dark:text-white/90">{{.[[ field.name ]]}}</span>
    [% endif %]
  </td>
  [% endif %]
  [% endfor %]

  <!-- Actions column — stop propagation so row click doesn't fire -->
  <td class="px-6 py-4 text-center" @click.stop>
    <div class="flex items-center justify-center gap-1">
      [% if has_show %]
      <!-- View Detail (inline panel) -->
      <button
        @click="open[[ model.name ]]DetailsView({{.ID}})"
        class="rounded-lg p-2 text-gray-500 hover:bg-blue-50 hover:text-blue-600 dark:text-gray-400 dark:hover:bg-blue-900/20 dark:hover:text-blue-400 transition-colors"
        title="View">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
      </button>
      [% endif %]
      [% if has_edit %]
      <button
        @click="current[[ model.name ]]ID = {{.ID}}; is[[ model.name ]]EditModalOpen = true;"
        class="rounded-lg p-2 text-gray-500 hover:bg-gray-100 hover:text-brand-600 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-brand-400 transition-colors"
        title="Edit">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-5M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      </button>
      [% endif %]
      [% if has_delete %]
      <!-- Delete (opens confirm modal) -->
      <button
        @click="current[[ model.name ]]ID = {{.ID}}; is[[ model.name ]]DeleteModalOpen = true;"
        class="rounded-lg p-2 text-gray-500 hover:bg-red-50 hover:text-red-600 dark:text-gray-400 dark:hover:bg-red-900/20 dark:hover:text-red-400 transition-colors"
        title="Delete">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      </button>
      [% endif %]
    </div>
  </td>
</tr>
{{end}}
{{if not .items}}
<tr>
  <td colspan="20" class="px-6 py-12 text-center">
    <div class="flex flex-col items-center gap-2">
      <svg class="h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      <p class="text-sm text-gray-500 dark:text-gray-400">No [[ model.name | lower ]] records found.</p>
    </div>
  </td>
</tr>
{{end}}
{{end}}