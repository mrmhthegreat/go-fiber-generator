{{define "[[ handler.template_base ]]/partials/[[ model.name | lower ]]-details-loading"}}
<div class="mx-auto max-w-(--breakpoint-2xl) p-4 md:p-6">
  <!-- Breadcrumb -->
  <div>
    <div class="flex flex-wrap items-center justify-between gap-3 pb-6">
      <div class="shimmer h-7 w-48 rounded"></div>
      <nav>
        <ol class="flex items-center gap-1.5">
          <li>
            <div class="flex items-center gap-1.5">
              <div class="shimmer h-4 w-12 rounded"></div>
              <svg class="stroke-current text-gray-300 dark:text-gray-600" width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6.0765 12.667L10.2432 8.50033L6.0765 4.33366" stroke="" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
          </li>
          <li><div class="shimmer h-4 w-32 rounded"></div></li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="space-y-6">
    <!-- Top card -->
    <div class="flex flex-col justify-between gap-6 rounded-2xl border border-gray-200 bg-white px-6 py-5 sm:flex-row sm:items-center dark:border-gray-800 dark:bg-white/[0.03]">
      <div class="flex flex-col gap-2.5 divide-gray-300 sm:flex-row sm:divide-x dark:divide-gray-700">
        <div class="flex items-center gap-2 sm:pr-3">
          <div class="shimmer h-5 w-32 rounded"></div>
          <div class="shimmer h-6 w-20 rounded-full"></div>
        </div>
        <div class="sm:pl-3">
          <div class="shimmer h-4 w-28 rounded"></div>
        </div>
      </div>
      <div class="flex gap-3 items-center">
        <div class="shimmer h-11 w-32 rounded-lg"></div>
        <div class="shimmer h-11 w-28 rounded-lg"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
      <!-- Left column -->
      <div class="lg:col-span-8 2xl:col-span-9">
        <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-white/[0.03]">
          <div class="shimmer mb-5 h-6 w-32 rounded"></div>
          <div class="overflow-hidden rounded-2xl border border-gray-100 dark:border-gray-800">
            <div class="custom-scrollbar overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr class="border-b border-gray-100 dark:border-gray-800">
                    [% set display_fields = model.detail_response.fields if model.detail_response is defined and model.detail_response.enabled else model.fields %]
                    [% for field in display_fields[:6] %]
                    [% set field_json = field.json_name | default(field.json) | default(field.name | lower) %]
                    [% if field_json != '-' and field.name | lower not in ['password'] %]
                    <th class="px-5 py-4 font-medium whitespace-nowrap">
                      <div class="shimmer h-4 w-[[ [8, 16, 10, 12, 16, 14][loop.index0 % 6] ]] rounded"></div>
                    </th>
                    [% endif %]
                    [% endfor %]
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white dark:divide-gray-800 dark:bg-white/[0.03]">
                  [% for row in range(3) %]
                  <tr>
                    [% for field in display_fields[:6] %]
                    [% set field_json = field.json_name | default(field.json) | default(field.name | lower) %]
                    [% if field_json != '-' and field.name | lower not in ['password'] %]
                    <td class="px-5 py-4 whitespace-nowrap">
                      [% if 'avatar' in field_json or 'image' in field_json or 'photo' in field_json %]
                      <div class="shimmer h-10 w-10 rounded-full"></div>
                      [% else %]
                      <div class="shimmer h-4 w-[[ [40, 6, 12, 8, 16][loop.index0 % 5] ]] rounded"></div>
                      [% endif %]
                    </td>
                    [% endif %]
                    [% endfor %]
                  </tr>
                  [% endfor %]
                </tbody>
              </table>
            </div>
          </div>
          <!-- Totals -->
          <div class="flex flex-wrap justify-between sm:justify-end">
            <div class="mt-6 w-full space-y-1 text-right sm:w-[220px]">
              <div class="shimmer mb-4 h-5 w-32 rounded text-left"></div>
              <ul class="space-y-2">
                <li class="flex justify-between gap-5">
                  <div class="shimmer h-4 w-16 rounded"></div>
                  <div class="shimmer h-4 w-16 rounded"></div>
                </li>
                <li class="flex items-center justify-between">
                  <div class="shimmer h-4 w-20 rounded"></div>
                  <div class="shimmer h-4 w-16 rounded"></div>
                </li>
                <li class="flex items-center justify-between">
                  <div class="shimmer h-4 w-12 rounded"></div>
                  <div class="shimmer h-6 w-20 rounded"></div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Right column -->
      <div class="space-y-6 lg:col-span-4 2xl:col-span-3">
        <!-- Info card -->
        <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-white/[0.03]">
          <div class="shimmer mb-5 h-6 w-36 rounded"></div>
          <ul class="divide-y divide-gray-100 dark:divide-gray-800">
            [% for i in range(5) %]
            <li class="flex items-start gap-5 py-2.5">
              <div class="shimmer h-4 w-[[ [12, 12, 12, 16, 16][i] ]] rounded"></div>
              <div class="shimmer h-4 w-[[ [28, 40, 32, 24, 48][i] ]] rounded"></div>
            </li>
            [% endfor %]
          </ul>
        </div>

        <!-- Timeline card -->
        <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-white/[0.03]">
          <div class="shimmer mb-5 h-6 w-32 rounded"></div>
          [% for i in range(3) %]
          <div class="relative pb-7 pl-11">
            <div class="absolute top-0 left-0 z-10 flex h-12 w-12 items-center justify-center rounded-full border-2 border-gray-50 bg-white ring ring-gray-200 dark:border-gray-800 dark:bg-gray-900 dark:ring-gray-800">
              <div class="shimmer h-6 w-6 rounded-full"></div>
            </div>
            <div class="ml-4 flex justify-between">
              <div>
                <div class="shimmer mb-2 h-5 w-24 rounded"></div>
                <div class="shimmer h-4 w-36 rounded"></div>
              </div>
              <div>
                <div class="shimmer mb-1 h-3 w-12 rounded"></div>
                <div class="shimmer h-3 w-16 rounded"></div>
              </div>
            </div>
            <div class="absolute top-8 left-6 h-full w-px border border-dashed border-gray-300 dark:border-gray-700"></div>
          </div>
          [% endfor %]
          <div class="relative pl-11">
            <div class="absolute top-0 left-0 z-10 flex h-12 w-12 items-center justify-center rounded-full border-2 border-gray-50 bg-white ring ring-gray-200 dark:border-gray-800 dark:bg-gray-900 dark:ring-gray-800">
              <div class="shimmer h-5 w-5 rounded"></div>
            </div>
            <div class="ml-4 flex justify-between">
              <div>
                <div class="shimmer mb-2 h-5 w-32 rounded"></div>
                <div class="shimmer h-4 w-40 rounded"></div>
              </div>
              <div>
                <div class="shimmer mb-1 h-3 w-12 rounded"></div>
                <div class="shimmer h-3 w-16 rounded"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{end}}