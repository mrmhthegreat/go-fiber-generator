{{define "[[ handler.template_base ]]/partials/[[ model.name | lower ]]_models"}}

[% set has_create = handler.crud_settings is defined and handler.crud_settings.get('create', {}).enabled %]
[% set has_edit   = handler.crud_settings is defined and handler.crud_settings.get('update', {}).enabled %]
[% set has_delete = handler.crud_settings is defined and handler.crud_settings.get('delete', {}).enabled %]
<!-- ===================== CREATE MODAL ===================== -->
[% if has_create %]
<div x-show="is[[ model.name ]]CreateModalOpen"
  class="modal fixed inset-0 z-99999 flex items-center justify-center overflow-y-auto p-5">
  <div class="modal-close-btn fixed inset-0 h-full w-full bg-gray-400/50 backdrop-blur-[32px]"></div>
  <div @click.outside="is[[ model.name ]]CreateModalOpen = false"
    class="relative w-full max-w-[558px] rounded-3xl bg-white p-6 lg:p-10 dark:bg-gray-900">
    <button @click="is[[ model.name ]]CreateModalOpen = false"
      class="absolute top-3 right-3 z-999 flex h-9.5 w-9.5 items-center justify-center rounded-full bg-gray-100 text-gray-400 transition-colors hover:bg-gray-200 hover:text-gray-700 sm:top-6 sm:right-6 sm:h-11 sm:w-11 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">
      <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z" fill=""></path>
      </svg>
    </button>
    <div>
      <h4 class="text-title-xs mb-1 font-semibold text-gray-800 dark:text-white/90" x-text="trans.add_[[ model.name | lower ]] || 'Add [[ model.name ]]'"></h4>
      <p class="mb-7 text-sm leading-6 text-gray-500 dark:text-gray-400" x-text="trans.fill_in_the_details_below || 'Fill in the details below.'"></p>
      <form id="[[ model.name | lower ]]-create-form">
        <input type="hidden" name="_csrf" value="{{.csrfToken}}" />
        <div class="space-y-4">
          [% for field in dto_fields %]
          [% if field.json | default('') != '-' and field.name | lower not in ['id', 'createdat', 'updatedat', 'deletedat'] %]
          [% set json_key = field.json | default(field.name | lower) %]
          <div>
            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
              [[ field.name | replace('_', ' ') | title ]][% if 'required' in (field.validate | default('')) %] <span class="text-red-500">*</span>[% endif %]
            </label>
            [% if field.type == 'file' %]
            <input type="file" name="[[ json_key ]]"
              class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border file:border-gray-300 file:text-sm file:font-medium file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100 dark:file:bg-gray-800 dark:file:text-gray-300 dark:file:border-gray-700" />
            [% elif field.type == 'bool' %]
            <label class="inline-flex items-center cursor-pointer">
              <input type="checkbox" name="[[ json_key ]]" value="true" class="sr-only peer" />
              <div class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-brand-300/20 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-500"></div>
            </label>
            [% elif field.type == 'text' or 'bio' in field.name | lower or 'description' in field.name | lower or 'note' in field.name | lower %]
            <textarea name="[[ json_key ]]"
              class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-24 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30"></textarea>
            [% elif 'role' in field.name | lower or 'status' in field.name | lower or field.type == 'select' %]
            <select name="[[ json_key ]]"
              class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full appearance-none rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 pr-11 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30">
              [% for option in field.options | default(['active', 'inactive']) %]
              <option value="[[ option ]]" x-text="trans.[[ option ]] || '[[ option | title ]]'"></option>
              [% endfor %]
            </select>
            [% else %]
            <input type="[% if 'password' in field.name | lower %]password[% elif 'email' in field.name | lower %]email[% elif field.type in ['int', 'uint', 'int64', 'float64'] %]number[% elif 'date' in field.name | lower or field.type == 'time.Time' %]date[% else %]text[% endif %]"
              name="[[ json_key ]]"
              [% if 'required' in (field.validate | default('')) %]required[% endif %]
              class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30" />
            [% endif %]
          </div>
          [% endif %]
          [% endfor %]
        </div>
        <div class="mt-8 flex w-full items-center justify-between gap-3">
          <button @click="is[[ model.name ]]CreateModalOpen = false" type="button"
            class="shadow-theme-xs flex w-full justify-center rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-800 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-white/[0.03] dark:hover:text-gray-200"
            x-text="trans.cancel || 'Cancel'"></button>
          <button type="button" @click="submit[[ model.name ]]Create()" :disabled="isLoading"
            class="flex items-center justify-center gap-2 bg-brand-500 shadow-theme-xs hover:bg-brand-600 flex w-full justify-center rounded-lg px-4 py-3 text-sm font-medium text-white">
            <span x-show="isLoading" class="animate-spin">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle opacity="0.5" cx="10" cy="10" r="8.75" stroke="white" stroke-width="2.5"></circle>
                <mask id="path-2-inside-1_create" fill="white"><path d="M18.2372 12.9506C18.8873 13.1835 19.6113 12.846 19.7613 12.1719C20.0138 11.0369 20.0672 9.86319 19.9156 8.70384C19.7099 7.12996 19.1325 5.62766 18.2311 4.32117C17.3297 3.01467 16.1303 1.94151 14.7319 1.19042C13.7019 0.637155 12.5858 0.270357 11.435 0.103491C10.7516 0.00440265 10.179 0.561473 10.1659 1.25187V1.25187C10.1528 1.94226 10.7059 2.50202 11.3845 2.6295C12.1384 2.77112 12.8686 3.02803 13.5487 3.39333C14.5973 3.95661 15.4968 4.76141 16.1728 5.74121C16.8488 6.721 17.2819 7.84764 17.4361 9.02796C17.5362 9.79345 17.5172 10.5673 17.3819 11.3223C17.2602 12.002 17.5871 12.7178 18.2372 12.9506V12.9506Z"></path></mask>
                <path d="M18.2372 12.9506C18.8873 13.1835 19.6113 12.846 19.7613 12.1719C20.0138 11.0369 20.0672 9.86319 19.9156 8.70384C19.7099 7.12996 19.1325 5.62766 18.2311 4.32117C17.3297 3.01467 16.1303 1.94151 14.7319 1.19042C13.7019 0.637155 12.5858 0.270357 11.435 0.103491C10.7516 0.00440265 10.179 0.561473 10.1659 1.25187V1.25187C10.1528 1.94226 10.7059 2.50202 11.3845 2.6295C12.1384 2.77112 12.8686 3.02803 13.5487 3.39333C14.5973 3.95661 15.4968 4.76141 16.1728 5.74121C16.8488 6.721 17.2819 7.84764 17.4361 9.02796C17.5362 9.79345 17.5172 10.5673 17.3819 11.3223C17.2602 12.002 17.5871 12.7178 18.2372 12.9506V12.9506Z" stroke="white" stroke-width="4" mask="url(#path-2-inside-1_create)"></path>
              </svg>
            </span>
            <span x-text="isLoading ? (trans.creating || 'Creating...') : (trans.create || 'Create')"></span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
[% endif %]

<!-- ===================== EDIT MODAL ===================== -->
[% if has_edit %]
<div x-show="is[[ model.name ]]EditModalOpen"
  class="modal fixed inset-0 z-99999 flex items-center justify-center overflow-y-auto p-5">
  <div class="modal-close-btn fixed inset-0 h-full w-full bg-gray-400/50 backdrop-blur-[32px]"></div>
  <div @click.outside="is[[ model.name ]]EditModalOpen = false"
    class="relative w-full max-w-[558px] rounded-3xl bg-white p-6 lg:p-10 dark:bg-gray-900">
    <button @click="is[[ model.name ]]EditModalOpen = false"
      class="absolute top-3 right-3 z-999 flex h-9.5 w-9.5 items-center justify-center rounded-full bg-gray-100 text-gray-400 transition-colors hover:bg-gray-200 hover:text-gray-700 sm:top-6 sm:right-6 sm:h-11 sm:w-11 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">
      <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z" fill=""></path>
      </svg>
    </button>
    <div>
      <h4 class="text-title-xs mb-1 font-semibold text-gray-800 dark:text-white/90" x-text="trans.edit_[[ model.name | lower ]] || 'Edit [[ model.name ]]'"></h4>
      <p class="mb-7 text-sm leading-6 text-gray-500 dark:text-gray-400" x-text="trans.update_the_details_below || 'Update the details below.'"></p>
      <form id="[[ model.name | lower ]]-edit-form">
        <input type="hidden" name="_csrf" value="{{.csrfToken}}" />
        <input type="hidden" name="[[ model.name | lower ]]_id" x-bind:value="current[[ model.name ]]ID" />
        <div class="space-y-4">
          [% for field in dto_fields %]
          [% if field.json | default('') != '-' and field.name | lower not in ['id', 'createdat', 'updatedat', 'deletedat'] %]
          [% set json_key = field.json | default(field.name | lower) %]
          <div>
            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
              [[ field.name | replace('_', ' ') | title ]]
            </label>
            [% if field.type == 'file' %]
            <input type="file" name="[[ json_key ]]"
              class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border file:border-gray-300 file:text-sm file:font-medium file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100 dark:file:bg-gray-800 dark:file:text-gray-300 dark:file:border-gray-700" />
            [% elif field.type == 'bool' %]
            <label class="inline-flex items-center cursor-pointer">
              <input type="checkbox" name="[[ json_key ]]" value="true" class="sr-only peer"
                x-effect="$el.checked = current[[ model.name ]]Data ? Boolean(current[[ model.name ]]Data['[[ json_key ]]']) : false" />
              <div class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-brand-300/20 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-500"></div>
            </label>
            [% elif field.type == 'text' or 'bio' in field.name | lower or 'description' in field.name | lower or 'note' in field.name | lower %]
            <textarea name="[[ json_key ]]"
              x-effect="$el.value = current[[ model.name ]]Data ? (current[[ model.name ]]Data['[[ json_key ]]'] || '') : ''"
              class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-24 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30"></textarea>
            [% elif 'role' in field.name | lower or 'status' in field.name | lower or field.type == 'select' %]
            <select name="[[ json_key ]]"
              x-effect="$el.value = current[[ model.name ]]Data ? (current[[ model.name ]]Data['[[ json_key ]]'] || '') : ''"
              class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full appearance-none rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 pr-11 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30">
              [% for option in field.options | default(['active', 'inactive']) %]
              <option value="[[ option ]]" x-text="trans.[[ option ]] || '[[ option | title ]]'"></option>
              [% endfor %]
            </select>
            [% else %]
            <input type="[% if 'password' in field.name | lower %]password[% elif 'email' in field.name | lower %]email[% elif field.type in ['int', 'uint', 'int64', 'float64'] %]number[% elif 'date' in field.name | lower or field.type == 'time.Time' %]date[% else %]text[% endif %]"
              name="[[ json_key ]]"
              x-effect="$el.value = current[[ model.name ]]Data ? (current[[ model.name ]]Data['[[ json_key ]]'] ?? '') : ''"
              class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30" />
            [% endif %]
          </div>
          [% endif %]
          [% endfor %]
        </div>
        <div class="mt-8 flex w-full items-center justify-between gap-3">
          <button @click="is[[ model.name ]]EditModalOpen = false" type="button"
            class="shadow-theme-xs flex w-full justify-center rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-800 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-white/[0.03] dark:hover:text-gray-200"
            x-text="trans.cancel || 'Cancel'"></button>
          <button type="button" @click="submit[[ model.name ]]Edit()" :disabled="isLoading"
            class="flex items-center justify-center gap-2 bg-brand-500 shadow-theme-xs hover:bg-brand-600 flex w-full justify-center rounded-lg px-4 py-3 text-sm font-medium text-white">
            <span x-show="isLoading" class="animate-spin">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle opacity="0.5" cx="10" cy="10" r="8.75" stroke="white" stroke-width="2.5"></circle>
                <mask id="path-2-inside-1_edit" fill="white"><path d="M18.2372 12.9506C18.8873 13.1835 19.6113 12.846 19.7613 12.1719C20.0138 11.0369 20.0672 9.86319 19.9156 8.70384C19.7099 7.12996 19.1325 5.62766 18.2311 4.32117C17.3297 3.01467 16.1303 1.94151 14.7319 1.19042C13.7019 0.637155 12.5858 0.270357 11.435 0.103491C10.7516 0.00440265 10.179 0.561473 10.1659 1.25187V1.25187C10.1528 1.94226 10.7059 2.50202 11.3845 2.6295C12.1384 2.77112 12.8686 3.02803 13.5487 3.39333C14.5973 3.95661 15.4968 4.76141 16.1728 5.74121C16.8488 6.721 17.2819 7.84764 17.4361 9.02796C17.5362 9.79345 17.5172 10.5673 17.3819 11.3223C17.2602 12.002 17.5871 12.7178 18.2372 12.9506V12.9506Z"></path></mask>
                <path d="M18.2372 12.9506C18.8873 13.1835 19.6113 12.846 19.7613 12.1719C20.0138 11.0369 20.0672 9.86319 19.9156 8.70384C19.7099 7.12996 19.1325 5.62766 18.2311 4.32117C17.3297 3.01467 16.1303 1.94151 14.7319 1.19042C13.7019 0.637155 12.5858 0.270357 11.435 0.103491C10.7516 0.00440265 10.179 0.561473 10.1659 1.25187V1.25187C10.1528 1.94226 10.7059 2.50202 11.3845 2.6295C12.1384 2.77112 12.8686 3.02803 13.5487 3.39333C14.5973 3.95661 15.4968 4.76141 16.1728 5.74121C16.8488 6.721 17.2819 7.84764 17.4361 9.02796C17.5362 9.79345 17.5172 10.5673 17.3819 11.3223C17.2602 12.002 17.5871 12.7178 18.2372 12.9506V12.9506Z" stroke="white" stroke-width="4" mask="url(#path-2-inside-1_edit)"></path>
              </svg>
            </span>
            <span x-text="isLoading ? (trans.saving || 'Saving...') : (trans.save_changes || 'Save Changes')"></span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
[% endif %]

<!-- ===================== DELETE MODAL ===================== -->
[% if has_delete %]
<div x-show="is[[ model.name ]]DeleteModalOpen"
  class="modal fixed inset-0 z-99999 flex items-center justify-center overflow-y-auto p-5">
  <div class="modal-close-btn fixed inset-0 h-full w-full bg-gray-400/50 backdrop-blur-[32px]"></div>
  <div @click.outside="is[[ model.name ]]DeleteModalOpen = false"
    class="relative w-full max-w-[580px] rounded-3xl bg-white p-6 lg:p-10 dark:bg-gray-900">
    <button @click="is[[ model.name ]]DeleteModalOpen = false"
      class="absolute top-3 right-3 z-999 flex h-9.5 w-9.5 items-center justify-center rounded-full bg-gray-100 text-gray-400 transition-colors hover:bg-gray-200 hover:text-gray-700 sm:top-6 sm:right-6 sm:h-11 sm:w-11 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">
      <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z" fill=""></path>
      </svg>
    </button>
    <div class="text-center">
      <div class="relative z-1 mb-7 flex items-center justify-center">
        <svg class="fill-error-50 dark:fill-error-500/15" width="90" height="90" viewBox="0 0 90 90" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M34.364 6.85053C38.6205 -2.28351 51.3795 -2.28351 55.636 6.85053C58.0129 11.951 63.5594 14.6722 68.9556 13.3853C78.6192 11.0807 86.5743 21.2433 82.2185 30.3287C79.7862 35.402 81.1561 41.5165 85.5082 45.0122C93.3019 51.2725 90.4628 63.9451 80.7747 66.1403C75.3648 67.3661 71.5265 72.2695 71.5572 77.9156C71.6123 88.0265 60.1169 93.6664 52.3918 87.3184C48.0781 83.7737 41.9219 83.7737 37.6082 87.3184C29.8831 93.6664 18.3877 88.0266 18.4428 77.9156C18.4735 72.2695 14.6352 67.3661 9.22531 66.1403C-0.462787 63.9451 -3.30193 51.2725 4.49185 45.0122C8.84391 41.5165 10.2138 35.402 7.78151 30.3287C3.42572 21.2433 11.3808 11.0807 21.0444 13.3853C26.4406 14.6722 31.9871 11.951 34.364 6.85053Z" fill="" fill-opacity=""></path>
        </svg>
        <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
          <svg class="fill-error-600 dark:fill-error-500" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M9.62684 11.7496C9.04105 11.1638 9.04105 10.2141 9.62684 9.6283C10.2126 9.04252 11.1624 9.04252 11.7482 9.6283L18.9985 16.8786L26.2485 9.62851C26.8343 9.04273 27.7841 9.04273 28.3699 9.62851C28.9556 10.2143 28.9556 11.164 28.3699 11.7498L21.1198 18.9999L28.3699 26.25C28.9556 26.8358 28.9556 27.7855 28.3699 28.3713C27.7841 28.9571 26.8343 28.9571 26.2485 28.3713L18.9985 21.1212L11.7482 28.3715C11.1624 28.9573 10.2126 28.9573 9.62684 28.3715C9.04105 27.7857 9.04105 26.836 9.62684 26.2502L16.8771 18.9999L9.62684 11.7496Z" fill=""></path>
          </svg>
        </span>
      </div>
      <h4 class="sm:text-title-sm mb-2 text-2xl font-semibold text-gray-800 dark:text-white/90" x-text="trans.confirm_deletion || 'Confirm Deletion'"></h4>
      <p class="text-sm leading-6 text-gray-500 dark:text-gray-400" x-text="trans.are_you_sure_you_want_to_delete_this_[[ model.name | lower ]] || 'Are you sure? This action cannot be undone.'"></p>
      <div class="mt-8 flex w-full items-center justify-center gap-3">
        <button @click="is[[ model.name ]]DeleteModalOpen = false" type="button"
          class="shadow-theme-xs flex justify-center rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-800 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-white/[0.03] dark:hover:text-gray-200"
          x-text="trans.no_cancel || 'No, Cancel'"></button>
        <button id="[[ model.name | lower ]]-delete-confirm-btn"
          hx-delete=""
          hx-target="#[[ model.name | lower ]]-table-container"
          hx-swap="none"
          hx-include="form[name='[[ model.name | lower ]]filters']"
          hx-on::after-request="
            const xhr = event.detail.xhr;
            const redirectURL = xhr.getResponseHeader('HX-Redirect');
            if (redirectURL) { window.location.href = redirectURL; return; }
            if (xhr.status === 200) {
              const tableData = Alpine.$data(document.body);
              const id = tableData.current[[ model.name ]]ID;
              tableData.is[[ model.name ]]DeleteModalOpen = false;
              const row = document.querySelector('[data-[[ model.name | lower ]]-id=\'' + id + '\']');
              if (row) row.remove();
              showNotification(trans.[[ model.name | lower ]]_deleted || '[[ model.name ]] deleted.', 'success');
            } else {
              const message = xhr.responseText ? JSON.parse(xhr.responseText).error : 'Failed to delete';
              showNotification(message, 'error');
            }"
          type="button"
          class="shadow-theme-xs flex justify-center rounded-lg bg-red-500 px-4 py-3 text-sm font-medium text-white hover:bg-red-600"
          x-text="trans.yes_im_sure || 'Yes, I\'m sure'"></button>
      </div>
    </div>
  </div>
</div>
[% endif %]

{{end}}