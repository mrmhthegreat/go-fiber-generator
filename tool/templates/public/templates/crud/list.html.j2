<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />
  <link rel="icon" type="image/png" href="/static/favicon.ico" />
  <title>[[ model.name ]] Management | [[ config.project.name | default('Admin') ]]</title>
  <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/persist@3.13.3/dist/cdn.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css" />
  <link rel="stylesheet" href="/static/src/output.css" />
</head>

<body x-data="{
    page: '[[ model.name ]]',
    loaded: true,
    darkMode: false,
    perms: {{.perms}},
    stickyMenu: false,
    sidebarToggle: false,
    scrollTop: false,
    selected: '[[ model.name ]]',
    trans: {{.trans}},

    [# CRUD modal state #]
    is[[ model.name ]]CreateModalOpen: false,
    is[[ model.name ]]DeleteModalOpen: false,

    ...[[ model.name | lower ]]TableData(),
  }"
  x-init="
    darkMode = JSON.parse(localStorage.getItem('darkMode'));
    $watch('darkMode', value => localStorage.setItem('darkMode', JSON.stringify(value)));
  "
  :class="{'dark bg-gray-900': darkMode === true}">

  {{template "shared/preloader" }}

  <div class="flex h-screen overflow-hidden">
    {{template "shared/sidebar" . }}

    <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
      {{template "shared/overlay" }}
      {{template "shared/header" .}}

      <main>
        <!-- Detail / Show panel — replaces the list view when open -->
        [% set has_details = handler.crud_settings is defined and handler.crud_settings.get('get', {}).enabled %]
        [% if has_details %]
        <div x-show="is[[ model.name ]]DetailsModalOpen" x-cloak>
          <div x-show="is[[ model.name ]]DetailsModalOpen && isLoading">
            {{template "[[ handler.template_base ]]/partials/[[ model.name | lower ]]-details-loading" }}
          </div>
          <div id="[[ model.name | lower ]]-details-page"></div>
        </div>
        [% endif %]
        <!-- Main list view -->
        <div x-show="!is[[ model.name ]]DetailsModalOpen" class="p-4 mx-auto max-w-(--breakpoint-2xl) md:p-6">
          <div class="space-y-5 sm:space-y-6">
            <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
              <div class="px-5 py-4 sm:px-6 sm:py-5">
                <div class="flex flex-wrap items-center justify-between gap-4">
                  <!-- Title -->
                  <div>
                    <h3 class="text-lg font-semibold text-gray-800 dark:text-white/90" x-text="trans.[[ model.name | lower ]]_management || '[[ model.name ]] Management'"></h3>
                  </div>
                  <!-- Filters + search + add button -->
                  {{template "[[ handler.template_base ]]/partials/[[ model.name | lower ]]-filter" }}
                </div>
              </div>
              {{template "[[ handler.template_base ]]/partials/[[ model.name | lower ]]-table-view" }}
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  [% set has_create = handler.crud_settings is defined and handler.crud_settings.get('create', {}).enabled %]
  [% set has_edit   = handler.crud_settings is defined and handler.crud_settings.get('update', {}).enabled %]
  [% set has_delete = handler.crud_settings is defined and handler.crud_settings.get('delete', {}).enabled %]


  <!-- Modals: create, delete confirm, edit iframe -->
  [% if has_create or has_edit or has_delete %]
  {{template "[[ handler.template_base ]]/partials/[[ model.name | lower ]]_models" }}
  [% endif %]

  <!-- Hidden CSRF / filter form -->
  <form name="[[ model.name | lower ]]filters" style="display: none">
    <input type="hidden" name="sort_by"    :value="[[ model.name | lower ]]filters.sort_by" />
    <input type="hidden" name="sort_order" :value="[[ model.name | lower ]]filters.sort_order" />
    <input type="hidden" name="limit"      :value="[[ model.name | lower ]]pagination.limit" />
    <input type="hidden" name="offset"     :value="[[ model.name | lower ]]pagination.offset" />
    <input type="hidden" name="search"     :value="[[ model.name | lower ]]filters.search" />
    <input type="hidden" name="_csrf"      value="{{.csrfToken}}" />
  </form>

  <script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js"></script>
  <script src="/static/dashboard/js/base.js"></script>
  <script src="/static/[[ model.name | lower ]]/js/[[ model.name | lower ]].js"></script>
</body>
</html>