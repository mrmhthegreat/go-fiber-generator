<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />
  <link rel="icon" type="image/png" href="/static/favicon.ico" />
  <title x-text="edit ? (trans.edit_[[ model.name | lower ]] || 'Edit [[ model.name ]]') : (trans.add_[[ model.name | lower ]] || 'Add [[ model.name ]]')"></title>
  <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/persist@3.13.3/dist/cdn.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <link rel="stylesheet" href="/static/src/output.css" />
</head>
<body x-data="{
    page: '[% if edit %]Edit[% else %]Create[% endif %] [[ model.name ]]',
    loaded: true,
    darkMode: false,
    stickyMenu: false,
    sidebarToggle: false,
    scrollTop: false,
    selected: '[[ model.name ]]',
    trans:{{.trans}},
    perms:{{.perms}},
    edit: [% if edit %]true[% else %]false[% endif %]
  }"
  x-init="darkMode = JSON.parse(localStorage.getItem('darkMode')); $watch('darkMode', value => localStorage.setItem('darkMode', JSON.stringify(value)))"
  :class="{'dark bg-gray-900': darkMode === true}">

  {{template "dashboard/partials/preloader" }}

  <div class="flex h-screen overflow-hidden">
    {{template "dashboard/partials/sidebar" . }}

    <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
      {{template "dashboard/partials/overlay" }}
      {{template "dashboard/partials/header" . }}

      <main>
        <div class="p-4 mx-auto max-w-4xl md:p-6">
          <!-- Page Header -->
          <div class="flex items-center justify-between mb-6">
            <div>
              <h1 class="text-2xl font-bold text-gray-800 dark:text-white/90" x-text="edit ? (trans.edit_[[ model.name | lower ]] || 'Edit [[ model.name ]]') : (trans.add_[[ model.name | lower ]] || 'Add [[ model.name ]]')"></h1>
            </div>
            <a href="[[ handler.base_path ]]" class="text-sm font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300">← <span x-text="trans.back || 'Back'"></span></a>
          </div>

          <!-- Form -->
          <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-white/[0.03]">
            <form id="[[ model.name | lower ]]-form"
              [% if edit %]
              hx-patch="[[ handler.base_path ]]/{{.item.ID}}"
              [% else %]
              hx-post="[[ handler.base_path ]]"
              [% endif %]
              hx-include="[name=_csrf]"
              hx-swap="none"
              hx-indicator="#form-submit-indicator"
              [% if dto_fields | selectattr('type', 'equalto', 'file') | list | length > 0 %]
              hx-encoding="multipart/form-data"
              enctype="multipart/form-data"
              [% endif %]
              class="space-y-6">

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                [% for field in dto_fields %]
                [% if field.json | default('') != '-' and field.name | lower not in ['id', 'createdat', 'updatedat', 'deletedat'] %]
                <div class="space-y-1[% if field.type == 'text' or 'bio' in field.name | lower %] md:col-span-2[% endif %]">
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                    [[ field.name | replace('_', ' ') | title ]]
                    [% if 'required' in (field.validate | default('')) %]<span class="text-red-500">*</span>[% endif %]
                  </label>

                  [% if field.type == 'file' %]
                  <!-- File Upload -->
                  <div x-data="{ fileName: '' }" class="relative">
                    <input type="file" name="[[ field.json | default(field.name | lower) ]]" id="field-[[ field.name | lower ]]"
                      @change="fileName = $event.target.files[0]?.name || ''"
                      class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border file:border-gray-300 file:text-sm file:font-medium file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100 dark:file:bg-gray-800 dark:file:text-gray-300 dark:file:border-gray-700" />
                    <p class="mt-1 text-xs text-gray-400" x-text="fileName ? fileName : ''"></p>
                    [% if edit %]
                    <p class="mt-1 text-xs text-gray-400">Current: <span class="text-brand-500">{{.item.[[ field.name ]]}}</span></p>
                    [% endif %]
                  </div>

                  [% elif field.type == 'bool' %]
                  <!-- Toggle Switch -->
                  <div x-data="{ toggled: [% if edit %]{{if .item.[[ field.name ]]}}true{{else}}false{{end}}[% else %]false[% endif %] }">
                    <label class="inline-flex items-center cursor-pointer">
                      <input type="checkbox" name="[[ field.json | default(field.name | lower) ]]" :checked="toggled" @change="toggled = !toggled" class="sr-only peer" />
                      <div class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-brand-300/20 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-brand-500"></div>
                      <span class="ml-3 text-sm text-gray-600 dark:text-gray-400" x-text="toggled ? trans.yes : trans.no"></span>
                    </label>
                  </div>

                  [% elif field.type == 'text' or 'bio' in field.name | lower or 'description' in field.name | lower %]
                  <!-- Textarea -->
                  <textarea name="[[ field.json | default(field.name | lower) ]]" id="field-[[ field.name | lower ]]" rows="4"
                    class="block w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm focus:border-brand-300 focus:ring-brand-500/10 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90">[% if edit %]{{.item.[[ field.name ]]}}[% endif %]</textarea>

                  [% elif 'role' in field.name | lower or 'status' in field.name | lower or field.type == 'select' %]
                  <!-- Select Dropdown -->
                  <div class="relative">
                    <select name="[[ field.json | default(field.name | lower) ]]"
                      class="h-11 w-full appearance-none rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30 dark:focus:border-brand-800">
                      [% for option in field.options | default(['user', 'admin']) %]
                      <option value="[[ option ]]"[% if edit %] {{if eq .item.[[ field.name ]] "[[ option ]]"}}selected{{end}}[% endif %]>[[ option | title ]]</option>
                      [% endfor %]
                    </select>
                    <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 dark:text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>

                  [% else %]
                  <!-- Regular Input -->
                  <input
                    [% if 'password' in field.name | lower %]type="password"
                    [% elif 'email' in field.name | lower %]type="email"
                    [% elif field.type in ['int', 'uint', 'int64', 'float64'] %]type="number"
                    [% elif 'date' in field.name | lower or field.type == 'time.Time' %]type="date"
                    [% else %]type="text"[% endif %]
                    id="field-[[ field.name | lower ]]"
                    name="[[ field.json | default(field.name | lower) ]]"
                    [% if edit %]value="{{.item.[[ field.name ]]}}"[% endif %]
                    [% if 'required' in (field.validate | default('')) %]required[% endif %]
                    class="h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30 dark:focus:border-brand-800" />
                  [% endif %]
                </div>
                [% endif %]
                [% endfor %]
              </div>

              <!-- Form Actions -->
              <div class="flex items-center justify-end gap-4 pt-6 mt-6 border-t border-gray-200 dark:border-gray-700">
                <a href="[[ handler.base_path ]]" class="rounded-lg border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800">
                  <span x-text="trans.cancel || 'Cancel'"></span>
                </a>
                <button type="submit" class="flex items-center gap-2 rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2">
                  <span class="htmx-indicator" id="form-submit-indicator">
                    <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                  </span>
                  <span x-text="edit ? trans.update || 'Update' : trans.create || 'Create'"></span>
                </button>
              </div>
            </form>
          </div>

        </div>
      </main>
    </div>
  </div>

  <script>
    // Handle HTMX form responses
    document.getElementById("[[ model.name | lower ]]-form")?.addEventListener("htmx:afterRequest", function(event) {
      const xhr = event.detail.xhr;
      const redirectURL = xhr.getResponseHeader("HX-Redirect");
      try {
        const response = JSON.parse(xhr.responseText);
        if (redirectURL) {
          window.location.href = redirectURL;
        } else if (xhr.status === 200 || xhr.status === 201) {
          if(typeof showNotification === 'function') {
             showNotification(response.message || "[% if edit %]Updated[% else %]Created[% endif %] successfully!", "success");
          }
          setTimeout(() => { window.location.href = "[[ handler.base_path ]]"; }, 1000);
        } else {
          if(typeof showNotification === 'function') {
             showNotification(response.error || response.message || "Something went wrong.", "error");
          }
        }
      } catch (e) {
        if (redirectURL) window.location.href = redirectURL;
      }
    });
  </script>
  <script src="/static/dashboard/js/base.js"></script>
</body>
</html>