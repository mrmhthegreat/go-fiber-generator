<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <link rel="icon" type="image/png" href="/static/favicon.ico" />
    <title>Verify Email | [[ config.project.name ]]</title>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://unpkg.com/htmx.org@1.9.5"></script>
    <link rel="stylesheet" href="/static/src/output.css" />
  </head>
  <body
    x-data="{ page: 'VerifyEmail', 'loaded': true, 'darkMode': false, 'stickyMenu': false, 'sidebarToggle': false, 'scrollTop': false,
      trans:{{.trans}},
    }"
    x-init="
         darkMode = JSON.parse(localStorage.getItem('darkMode'));
         $watch('darkMode', value => localStorage.setItem('darkMode', JSON.stringify(value)))"
    :class="{'dark bg-gray-900': darkMode === true}"
  >
    {{template "superadmin/partials/preloader" }}

    <div class="z-1 bg-white p-6 sm:p-0 dark:bg-gray-900">
      <div class="absolute right-5 top-5 z-2 sm:p-0">{{template "basic/lang" }}</div>
      <div class="relative flex h-screen w-full flex-col justify-center sm:p-0 lg:flex-row dark:bg-gray-900">
        <div class="flex w-full flex-1 flex-col lg:w-1/2">
          <div class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center">
            <div class="mb-5 sm:mb-8">
              <h1 class="text-title-sm sm:text-title-md mb-2 font-semibold text-gray-800 dark:text-white/90" x-text="trans.verify_your_email"></h1>
              <p class="text-sm text-gray-500 dark:text-gray-400" x-text="trans.a_verification_code_has_been_sent_to_your_email_pl"></p>
            </div>
            <div>
              <form
                hx-indicator="#verify-htmx-indicator"
                hx-post="[[ authentication.web_auth.endpoints.verify_email.path | default('/auth/user/verify-account/') ]]"
                hx-swap="none"
                id="verifyEmailForm"
                onsubmit="combineOTP()"
              >
                <input name="_csrf" type="hidden" value="{{.csrfToken}}" />
                <input id="otp" name="otp" type="hidden" />
                <div class="space-y-5">
                  <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400" x-text="trans.type_your_6_digits_security_code"></label>
                    <div class="flex gap-2 sm:gap-4" id="otp-container">
                      [% for digit in ['one','two','three','four','five','six'] %]
                      <input type="text" maxlength="1" required="" id="[[ digit ]]" inputmode="numeric" autocomplete="one-time-code"
                        class="dark:bg-dark-900 otp-input shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-center text-xl font-semibold text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30" />
                      [% endfor %]
                    </div>
                    <p class="text-theme-xs text-error-500 py-1 hidden" id="verify-otp-error" x-text="trans.please_enter_a_valid_code"></p>
                  </div>
                  <div>
                    <button type="submit" class="flex items-center w-full justify-center gap-2 rounded-lg bg-brand-500 px-5 py-3.5 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">
                      <span class="animate-spin htmx-indicator" id="verify-htmx-indicator">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle opacity="0.5" cx="10" cy="10" r="8.75" stroke="white" stroke-width="2.5"></circle>
                          <mask id="path-2-inside-1_verify" fill="white">
                            <path d="M18.2372 12.9506C18.8873 13.1835 19.6113 12.846 19.7613 12.1719C20.0138 11.0369 20.0672 9.86319 19.9156 8.70384C19.7099 7.12996 19.1325 5.62766 18.2311 4.32117C17.3297 3.01467 16.1303 1.94151 14.7319 1.19042C13.7019 0.637155 12.5858 0.270357 11.435 0.103491C10.7516 0.00440265 10.179 0.561473 10.1659 1.25187C10.1528 1.94226 10.7059 2.50202 11.3845 2.6295C12.1384 2.77112 12.8686 3.02803 13.5487 3.39333C14.5973 3.95661 15.4968 4.76141 16.1728 5.74121C16.8488 6.721 17.2819 7.84764 17.4361 9.02796C17.5362 9.79345 17.5172 10.5673 17.3819 11.3223C17.2602 12.002 17.5871 12.7178 18.2372 12.9506Z"></path>
                          </mask>
                          <path d="M18.2372 12.9506C18.8873 13.1835 19.6113 12.846 19.7613 12.1719C20.0138 11.0369 20.0672 9.86319 19.9156 8.70384C19.7099 7.12996 19.1325 5.62766 18.2311 4.32117C17.3297 3.01467 16.1303 1.94151 14.7319 1.19042C13.7019 0.637155 12.5858 0.270357 11.435 0.103491C10.7516 0.00440265 10.179 0.561473 10.1659 1.25187C10.1528 1.94226 10.7059 2.50202 11.3845 2.6295C12.1384 2.77112 12.8686 3.02803 13.5487 3.39333C14.5973 3.95661 15.4968 4.76141 16.1728 5.74121C16.8488 6.721 17.2819 7.84764 17.4361 9.02796C17.5362 9.79345 17.5172 10.5673 17.3819 11.3223C17.2602 12.002 17.5871 12.7178 18.2372 12.9506Z" stroke="white" stroke-width="4" mask="url(#path-2-inside-1_verify)"></path>
                        </svg>
                      </span>
                      <span x-text="trans.verify_email"></span>
                    </button>
                  </div>
                </div>
              </form>

              <!-- Resend code -->
              <div class="mt-5">
                <p class="text-center text-sm font-normal text-gray-700 sm:text-start dark:text-gray-400">
                  <span x-text="trans.didnt_get_the_code"></span>
                  <a class="text-brand-500 hover:text-brand-600 dark:text-brand-400" href="javascript:void(0);"
                    hx-patch="[[ authentication.web_auth.endpoints.resend_verify_email.path | default('/auth/user/resend-verify-email/') ]]"
                    hx-swap="none"
                    hx-include="[name=_csrf]"
                    hx-trigger="click"
                    hx-indicator="#resend-htmx-indicator"
                    hx-on::after-request="handleResendVerify(event)"
                    id="resend">
                    <span class="animate-spin htmx-indicator" id="resend-htmx-indicator">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle opacity="0.5" cx="10" cy="10" r="8.75" stroke="white" stroke-width="2.5"></circle>
                      </svg>
                    </span>
                    <span x-text="trans.resend"></span>
                  </a>
                  <span class="text-brand-500 dark:text-brand-400" id="countdown" style="display: none"></span>
                </p>
              </div>

              <!-- Sign Out -->
              <div class="mt-5 text-center sm:text-start">
                <a href="[[ authentication.web_auth.endpoints.logout.path | default('/auth/logout') ]]"
                  class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="fill-current">
                    <path d="M10.7998 1.59961H6.3998C5.51595 1.59961 4.7998 2.31576 4.7998 3.19961V5.59961C4.7998 5.93098 5.06843 6.19961 5.3998 6.19961C5.73118 6.19961 5.9998 5.93098 5.9998 5.59961V3.19961C5.9998 2.97832 6.17851 2.79961 6.3998 2.79961H10.7998C11.0211 2.79961 11.1998 2.97832 11.1998 3.19961V12.7996C11.1998 13.0209 11.0211 13.1996 10.7998 13.1996H6.3998C6.17851 13.1996 5.9998 13.0209 5.9998 12.7996V10.3996C5.9998 10.0682 5.73118 9.79961 5.3998 9.79961C5.06843 9.79961 4.7998 10.0682 4.7998 10.3996V12.7996C4.7998 13.6835 5.51595 14.3996 6.3998 14.3996H10.7998C11.6837 14.3996 12.3998 13.6835 12.3998 12.7996V3.19961C12.3998 2.31576 11.6837 1.59961 10.7998 1.59961Z"/>
                    <path d="M8.42426 8.62386L10.6485 10.848C10.8877 11.0872 11.2762 11.0872 11.5154 10.848C11.7547 10.6088 11.7547 10.2203 11.5154 9.98107L9.93467 8.40039H13.3998C13.7312 8.40039 13.9998 8.13176 13.9998 7.80039C13.9998 7.46902 13.7312 7.20039 13.3998 7.20039H9.93467L11.5154 5.61972C11.7547 5.38048 11.7547 4.99199 11.5154 4.75276C11.2762 4.51352 10.8877 4.51352 10.6485 4.75276L8.42426 6.97693C7.82426 7.57693 7.82426 8.02386 8.42426 8.62386Z"/>
                  </svg>
                  <span x-text="trans.sign_out"></span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Dark mode toggler -->
        <div class="fixed right-6 bottom-6 z-50">
          <button class="bg-brand-500 hover:bg-brand-600 inline-flex size-14 items-center justify-center rounded-full text-white transition-colors" @click.prevent="darkMode = !darkMode">
            <svg class="hidden fill-current dark:block" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M9.99998 1.5415C10.4142 1.5415 10.75 1.87729 10.75 2.2915V3.5415C10.75 3.95572 10.4142 4.2915 9.99998 4.2915C9.58577 4.2915 9.24998 3.95572 9.24998 3.5415V2.2915C9.24998 1.87729 9.58577 1.5415 9.99998 1.5415ZM10.0009 6.79327C8.22978 6.79327 6.79402 8.22904 6.79402 10.0001C6.79402 11.7712 8.22978 13.207 10.0009 13.207C11.772 13.207 13.2078 11.7712 13.2078 10.0001C13.2078 8.22904 11.772 6.79327 10.0009 6.79327ZM5.29402 10.0001C5.29402 7.40061 7.40135 5.29327 10.0009 5.29327C12.6004 5.29327 14.7078 7.40061 14.7078 10.0001C14.7078 12.5997 12.6004 14.707 10.0009 14.707C7.40135 14.707 5.29402 12.5997 5.29402 10.0001Z" fill=""/></svg>
            <svg class="fill-current dark:hidden" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10.0003 16.9586C6.15734 16.9586 3.04199 13.8433 3.04199 10.0003H1.54199C1.54199 14.6717 5.32892 18.4586 10.0003 18.4586V16.9586Z" fill=""/></svg>
          </button>
        </div>
      </div>
    </div>

    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/persist@3.13.3/dist/cdn.min.js"></script>
    <script src="/static/dashboard/js/base.js"></script>
    <script src="/static/dashboard/js/verify_email.js"></script>
  </body>
</html>
