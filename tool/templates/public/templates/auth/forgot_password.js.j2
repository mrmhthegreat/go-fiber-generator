"use strict";

[% set fp = authentication.email_password.forgot_password %]
[% set fp_ident = fp.identifier_field | default('email') %]

const forgetForm = document.getElementById("forget-password-form");
if (forgetForm) {
  forgetForm.addEventListener("htmx:beforeRequest", function (event) {
    const identEl = document.getElementById("forget-identifier");
    const errorEl = document.getElementById("forget-identifier-error");
    const identVal = identEl?.value.trim();

    identEl?.classList.remove("border-red-500", "focus:ring-red-500");
    errorEl?.classList.add("hidden");

    [% if fp_ident in ['email_or_username', 'username_or_email'] %]
    const isValid = identVal && identVal.length >= 3;
    [% elif fp_ident == 'username' %]
    const isValid = identVal && identVal.length >= 3;
    [% else %]
    const isValid = identVal && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(identVal);
    [% endif %]

    if (!isValid) {
      errorEl?.classList.remove("hidden");
      identEl?.classList.add("border-red-500", "focus:ring-red-500");
      event.preventDefault();
      event.detail.shouldAbort = true;
    }
  });

  forgetForm.addEventListener("htmx:afterRequest", function (event) {
    const xhr = event.detail.xhr;
    const redirectURL = xhr.getResponseHeader("HX-Redirect");
    try {
      const response = JSON.parse(xhr.responseText);
      if (redirectURL) {
        window.location.href = redirectURL;
      } else {
        if (response.email || response.username || response.identifier) {
          document.getElementById("forget-identifier-error")?.classList.remove("hidden");
          document.getElementById("forget-identifier")?.classList.add("border-red-500", "focus:ring-red-500");
        }
        if (response.error) showNotification(response.error, "error");
        if (response.message) showNotification(response.message, "success");
      }
    } catch (e) {
      if (xhr.status >= 400) showNotification("An error occurred. Please try again.", "error");
    }
  });
}