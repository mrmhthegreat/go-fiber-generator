<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <link rel="icon" type="image/png" href="/static/favicon.ico" />
    <title>Forgot Password | [[ config.project.name ]]</title>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://unpkg.com/htmx.org@1.9.5"></script>
    <link rel="stylesheet" href="/static/src/output.css" />
  </head>
  <body
    x-data="{ page: 'Reset-Password', 'loaded': true, 'darkMode': false, 'stickyMenu': false, 'sidebarToggle': false, 'scrollTop': false, trans:{{.trans}} }"
    x-init="darkMode = JSON.parse(localStorage.getItem('darkMode')); $watch('darkMode', value => localStorage.setItem('darkMode', JSON.stringify(value)))"
    :class="{'dark bg-gray-900': darkMode === true}"
  >
    {{template "superadmin/partials/preloader" }}

    <div class="z-1 bg-white p-6 sm:p-0 dark:bg-gray-900">
      <div class="absolute right-5 top-5 z-2 sm:p-0">{{template "basic/lang" }}</div>
      <div class="relative flex h-screen w-full flex-col justify-center sm:p-0 lg:flex-row dark:bg-gray-900">
        <div class="flex w-full flex-1 flex-col lg:w-1/2">
          <div class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center">
            <div class="mb-5 sm:mb-8">
              <h1 class="text-title-sm sm:text-title-md mb-2 font-semibold text-gray-800 dark:text-white/90" x-text="trans.forgot_your_password"></h1>
              <p class="text-sm text-gray-500 dark:text-gray-400" x-text="trans.enter_the_email_address_linked_to_your_account_and"></p>
            </div>
            <div>
              [% set fp = authentication.email_password.forgot_password %]
              [% set fp_ident = fp.identifier_field | default('email') %]
              <form hx-indicator="#forget-htmx-indicator" id="forget-password-form" hx-post="[[ authentication.web_auth.endpoints.forgot_password.path | default('/account/forget-password/') ]]" hx-swap="none">
                <input name="_csrf" type="hidden" value="{{.csrfToken}}" />
                <div class="space-y-5">
                  <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                      [% if fp_ident in ['email_or_username', 'username_or_email'] %]
                      <span x-text="trans.email_or_username"></span>
                      [% elif fp_ident == 'username' %]
                      <span x-text="trans.username"></span>
                      [% else %]
                      <span x-text="trans.email"></span>
                      [% endif %]
                      <span class="text-error-500">*</span>
                    </label>
                    [% if fp_ident in ['email_or_username', 'username_or_email'] %]
                    <input type="text" name="identifier" placeholder="Enter your email or username" id="forget-identifier"
                      class="dark:bg-dark-900 font-normal shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30" />
                    [% elif fp_ident == 'username' %]
                    <input type="text" name="username" placeholder="Enter your username" id="forget-identifier"
                      class="dark:bg-dark-900 font-normal shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30" />
                    [% else %]
                    <input type="email" name="email" placeholder="Enter your email" id="forget-identifier"
                      class="dark:bg-dark-900 font-normal shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30" />
                    [% endif %]
                    <p class="text-theme-xs text-error-500 py-1 hidden" id="forget-identifier-error" x-text="trans.user_not_found"></p>
                  </div>
                  <div>
                    <button type="submit" class="bg-brand-500 shadow-theme-xs hover:bg-brand-600 flex w-full items-center justify-center gap-2 rounded-lg px-4 py-3 text-sm font-medium text-white transition">
                      <span class="animate-spin htmx-indicator" id="forget-htmx-indicator">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle opacity="0.5" cx="10" cy="10" r="8.75" stroke="white" stroke-width="2.5"></circle>
                          <path d="M18.2372 12.9506C18.8873 13.1835 19.6113 12.846 19.7613 12.1719C20.0138 11.0369 20.0672 9.86319 19.9156 8.70384C19.7099 7.12996 19.1325 5.62766 18.2311 4.32117C17.3297 3.01467 16.1303 1.94151 14.7319 1.19042C13.7019 0.637155 12.5858 0.270357 11.435 0.103491C10.7516 0.00440265 10.179 0.561473 10.1659 1.25187C10.1528 1.94226 10.7059 2.50202 11.3845 2.6295C12.1384 2.77112 12.8686 3.02803 13.5487 3.39333C14.5973 3.95661 15.4968 4.76141 16.1728 5.74121C16.8488 6.721 17.2819 7.84764 17.4361 9.02796C17.5362 9.79345 17.5172 10.5673 17.3819 11.3223C17.2602 12.002 17.5871 12.7178 18.2372 12.9506Z" stroke="white" stroke-width="4"></path>
                        </svg>
                      </span>
                      <span x-text="trans.send_reset_link"></span>
                    </button>
                  </div>
                </div>
              </form>
              <div class="mt-5">
                <p class="text-center text-sm font-normal text-gray-700 sm:text-start dark:text-gray-400">
                  <span x-text="trans.wait_i_remember_my_password"></span>
                  <a href="/login" class="text-brand-500 hover:text-brand-600 dark:text-brand-400" x-text="trans.click_here"></a>
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="fixed right-6 bottom-6 z-50">
          <button class="bg-brand-500 hover:bg-brand-600 inline-flex size-14 items-center justify-center rounded-full text-white transition-colors" @click.prevent="darkMode = !darkMode">
            <svg class="hidden fill-current dark:block" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M10.0009 6.79327C8.22978 6.79327 6.79402 8.22904 6.79402 10.0001C6.79402 11.7712 8.22978 13.207 10.0009 13.207C11.772 13.207 13.2078 11.7712 13.2078 10.0001C13.2078 8.22904 11.772 6.79327 10.0009 6.79327Z" fill=""/></svg>
            <svg class="fill-current dark:hidden" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10.0003 16.9586C6.15734 16.9586 3.04199 13.8433 3.04199 10.0003H1.54199C1.54199 14.6717 5.32892 18.4586 10.0003 18.4586V16.9586Z" fill=""/></svg>
          </button>
        </div>
      </div>
    </div>

    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/persist@3.13.3/dist/cdn.min.js"></script>
    <script src="/static/dashboard/js/base.js"></script>
    <script src="/static/dashboard/js/forgot_password.js"></script>
  </body>
</html>