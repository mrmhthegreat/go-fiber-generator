{% extends 'html/layouts/main.html.j2' %}

{% block title %}Chat & Conversations | {{ config.project.name }}{% endblock %}
{% block active_page %}Chat{% endblock %}
{% block head %}
<style>
    .chat-container { height: calc(100vh - 200px); }
</style>
{% endblock %}
{% block content %}
<div class="flex chat-container overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
    <!-- Sidebar: Conversation List -->
    <div class="w-80 border-r border-gray-200 flex flex-col dark:border-gray-700">
        <div class="p-4 border-b border-gray-200 dark:border-gray-700">
            <input type="text" placeholder="Search conversations..." class="w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm focus:border-primary focus:ring-primary dark:border-gray-600 dark:bg-gray-700 dark:text-white">
        </div>
        <div class="flex-1 overflow-y-auto" hx-get="/dashboard/chat/conversations" hx-trigger="load">
            <div class="p-8 text-center text-gray-400">
                <div class="animate-spin h-6 w-6 border-2 border-primary border-t-transparent rounded-full mx-auto mb-2"></div>
                Loading...
            </div>
    </div>
    <!-- Main: Message Area -->
    <div class="flex-1 flex flex-col bg-gray-50 dark:bg-gray-900/50">
        <div id="chat-messages" class="flex-1 p-6 overflow-y-auto space-y-4">
            <div class="flex h-full items-center justify-center text-gray-400">
                <div class="text-center">
                    <svg class="mx-auto h-12 w-12 mb-4 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                    <p>Select a conversation to start chatting</p>
                </div>
        <!-- Input Area -->
        <div class="p-4 bg-white border-t border-gray-200 dark:bg-gray-800 dark:border-gray-700">
            <form hx-post="/dashboard/chat/send" hx-target="#chat-messages" hx-swap="beforeend" class="flex gap-4">
                <input type="text" name="message" placeholder="Type your message..." class="flex-1 rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-sm focus:border-primary focus:ring-primary dark:border-gray-600 dark:bg-gray-700 dark:text-white">
                <button type="submit" class="rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary-600">
                    Send
                </button>
            </form>
</div>
{% block scripts %}
<script>
    // Simple WebSocket integration for real-time updates
    if (window.adminWS) {
        window.adminWS.addEventListener('message', function(event) {
            const data = JSON.parse(event.data);
            if (data.type === 'chat_message') {
                // Potential HTMX trigger or manual DOM update
                console.log('New message:', data.payload);
            }
        });
    }
</script>
