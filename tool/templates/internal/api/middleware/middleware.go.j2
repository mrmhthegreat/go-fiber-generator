	return func(c *fiber.Ctx) error {
		sessVal := c.Locals("{{ config.middleware.locals.session | default('session') }}")
		if sessVal == nil {
			{% if middleware_def.redirect_on_fail %}
			c.Set("HX-Redirect", "{{ middleware_def.redirect_on_fail }}")
