// ============================================
// DASHBOARD ACCESS CONTROL
// ============================================
// NOTE: These functions assume your User model has:
//   - user.Role field (string)
//   - rbac.GetDashboardBasePath() function exists
// If your model is different, disable this and create custom middleware

// SmartDashboardRedirect redirects user to their correct dashboard home
func SmartDashboardRedirect(c *fiber.Ctx) error {
	userID, ok := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint)
	if !ok {
		return c.Redirect("/login")
	}

	dbConn := utilspkg.GetDB(c)
	user, err := cache.GetUser(userID, dbConn)
	if err != nil {
		return fiber.NewError(fiber.StatusNotFound, "internal_server_error")
	}

	dashBase := rbac.GetDashboardBasePath(user.Role)
	return c.Redirect(dashBase+"/", fiber.StatusFound)
}

// EnsureCorrectDashboardAccess prevents role-crossing between dashboards
func EnsureCorrectDashboardAccess() fiber.Handler {
	return func(c *fiber.Ctx) error {
		userID, ok := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint)
		if !ok {
			return c.Redirect("/login")
		}

		dbConn := utilspkg.GetDB(c)
		user, err := cache.GetUser(userID, dbConn)
		if err != nil {
			return fiber.NewError(fiber.StatusNotFound, "internal_server_error")
		}

		correctDashBase := rbac.GetDashboardBasePath(user.Role)
		currentPath := c.Path()

		switch {
		case strings.HasPrefix(currentPath, "/superadmin") && !user.IsSuperuser:
			return c.Redirect(correctDashBase+"/", fiber.StatusFound)
		case strings.HasPrefix(currentPath, "/admin") && !(user.IsAdmin || user.Role == "admin"):
			return c.Redirect(correctDashBase+"/", fiber.StatusFound)
		case strings.HasPrefix(currentPath, "/dashboard") && (user.IsSuperuser || user.IsAdmin || user.Role == "admin"):
			return c.Redirect(correctDashBase+"/", fiber.StatusFound)
		}
		return c.Next()
	}
}
