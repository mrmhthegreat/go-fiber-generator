// CSRFMiddleware configures CSRF protection
func CSRFMiddleware(store *session.Store) fiber.Handler {
	return csrf.New(csrf.Config{
		ContextKey:      "{{ config.middleware.csrf.context_key | default('csrf') }}",
		CookieName:      "{{ config.middleware.csrf.cookie_name | default('csrf_') }}",
		CookieSameSite:  "{{ config.middleware.csrf.same_site | default('Lax') }}",
		Expiration:      {{ config.middleware.csrf.expiration | default('1 * time.Hour') }},
		KeyLookup:       "header:{{ config.middleware.csrf.header | default('X-CSRFToken') }}{% if config.middleware.csrf.form_field %},form:{{ config.middleware.csrf.form_field }}{% endif %}",
		Session:         store,
		ErrorHandler: func(c *fiber.Ctx, err error) error {
			return errorspkg.SendError(c, fiber.StatusForbidden, "invalid_csrf_token")
		},
	})
}
