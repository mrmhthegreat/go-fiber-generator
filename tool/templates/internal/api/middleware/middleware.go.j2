{% if config.middleware.rbac.enabled %}
// ============================================
// RBAC PERMISSION CHECKS
// ============================================

// RequirePerm ensures user has specific permission using RBAC service
func RequirePerm(key string) fiber.Handler {
	return func(c *fiber.Ctx) error {
		userID, ok := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint)
		if !ok {
			if strings.HasPrefix(c.Path(), "/api/") {
				return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
			}
			return c.Redirect("/login")
		}
		if RBACService == nil {
			return c.Next()
		}
		has, _ := RBACService.HasPermission(context.Background(), userID, key)
		if !has {
			if strings.HasPrefix(c.Path(), "/api/") {
				return errorspkg.SendError(c, fiber.StatusForbidden, "forbidden")
			}
			c.Set("HX-Redirect", "/403")
			return c.Status(fiber.StatusForbidden).Redirect("/403")
		}
		return c.Next()
	}
}

// RequireAnyPerm ensures user has at least one of the given permissions
func RequireAnyPerm(keys ...string) fiber.Handler {
	return func(c *fiber.Ctx) error {
		userID, ok := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint)
		if !ok {
			return c.Redirect("/login")
		}
		if RBACService == nil {
			return c.Next()
		}
		for _, key := range keys {
			if has, _ := RBACService.HasPermission(context.Background(), userID, key); has {
				return c.Next()
			}
		}
		c.Set("HX-Redirect", "/403")
		return c.Status(fiber.StatusForbidden).Redirect("/403")
	}
}

// RequireAllPerms ensures user has all of the given permissions
func RequireAllPerms(keys ...string) fiber.Handler {
	return func(c *fiber.Ctx) error {
		userID, ok := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint)
		if !ok {
			return c.Redirect("/login")
		}
		if RBACService == nil {
			return c.Next()
		}
		for _, key := range keys {
			if has, _ := RBACService.HasPermission(context.Background(), userID, key); !has {
				c.Set("HX-Redirect", "/403")
				return c.Status(fiber.StatusForbidden).Redirect("/403")
			}
		}
		return c.Next()
	}
}
