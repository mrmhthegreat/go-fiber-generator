			{% endif %}
		}

		return c.Next()
	}
}

{% elif middleware_def.type == 'jwt' %}
// {{ middleware_def.name | capitalize }}Middleware - {{ middleware_def.description }}
func {{ middleware_def.name | capitalize }}Middleware() fiber.Handler {
	return func(c *fiber.Ctx) error {
		authHeader := c.Get("{{ middleware_def.header_name | default('Authorization') }}")
		if authHeader == "" {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "authorization_missing")
		}

		scheme := "{{ middleware_def.scheme | default('Bearer') }} "
		if !strings.HasPrefix(authHeader, scheme) {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "invalid_auth_scheme")
		}
		tokenString := strings.TrimPrefix(authHeader, scheme)

		token, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {
			{% if middleware_def.algorithm %}
			// Verify algorithm: {{ middleware_def.algorithm }}
			{% if middleware_def.algorithm.startswith('HS') or middleware_def.algorithm.startswith('hmac') %}
			expectedAlg := "{{ middleware_def.algorithm.upper().replace('HMAC_SHA', 'HS') }}"
			if _, ok := token.Method.(*jwt.SigningMethodHMAC); !ok || token.Method.Alg() != expectedAlg {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% elif middleware_def.algorithm.startswith('RS') or middleware_def.algorithm.startswith('rsa') %}
			expectedAlg := "{{ middleware_def.algorithm.upper().replace('RSA_SHA', 'RS') }}"
			if _, ok := token.Method.(*jwt.SigningMethodRSA); !ok || token.Method.Alg() != expectedAlg {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% elif middleware_def.algorithm.startswith('ES') or middleware_def.algorithm.startswith('ecdsa') %}
			expectedAlg := "{{ middleware_def.algorithm.upper().replace('ECDSA_SHA', 'ES') }}"
			if _, ok := token.Method.(*jwt.SigningMethodECDSA); !ok || token.Method.Alg() != expectedAlg {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% else %}
			// Default HMAC check
			if _, ok := token.Method.(*jwt.SigningMethodHMAC); !ok {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% endif %}
			{% else %}
			// No algorithm specified, accept any HMAC
			if _, ok := token.Method.(*jwt.SigningMethodHMAC); !ok {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% endif %}
			
			{% if middleware_def.secret_key_env %}
			return []byte(viper.GetString("{{ middleware_def.secret_key_env }}")), nil
			{% else %}
			return []byte(viper.GetString("JWT_SECRET")), nil
			{% endif %}
		})

		if err != nil || !token.Valid {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "invalid_token")
		}

		claims, ok := token.Claims.(jwt.MapClaims)
		if !ok {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "invalid_claims")
		}

		{% if middleware_def.claims %}
		// Extract claims with type conversion
		{% for claim in middleware_def.claims %}
		if val, ok := claims["{{ claim.name }}"]; ok {
			{% if claim.type == 'uint' or claim.type == 'uint64' %}
			if floatVal, ok := val.(float64); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", uint(floatVal))
			}
			{% elif claim.type == 'int' or claim.type == 'int64' %}
			if floatVal, ok := val.(float64); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", int(floatVal))
			}
			{% elif claim.type == 'string' %}
			if strVal, ok := val.(string); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", strVal)
			}
			{% elif claim.type == 'bool' %}
			if boolVal, ok := val.(bool); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", boolVal)
			}
			{% elif claim.type == 'float64' %}
			if floatVal, ok := val.(float64); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", floatVal)
			}
			{% else %}
			// Custom type or no type - store as-is
			c.Locals("{{ claim.context_key | default(claim.name) }}", val)
			{% endif %}
			{% if claim.required %}
		} else {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "missing_claim_{{ claim.name }}")
			{% endif %}
		}
		{% endfor %}
		{% elif middleware_def.claims_required %}
		// Legacy claims_required format (backward compatible)
		{% for claim in middleware_def.claims_required %}
		if val, ok := claims["{{ claim }}"]; ok {
			{% if claim == 'user_id' %}
			c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}", uint(val.(float64)))
			{% elif claim == 'email' %}
			c.Locals("{{ config.middleware.locals.email | default('email') }}", val)
			{% else %}
			c.Locals("{{ claim }}", val)
			{% endif %}
		} else {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "missing_claim_{{ claim }}")
		}
		{% endfor %}
		{% else %}
		// No required claims - extract all available
		for key, val := range claims {
			c.Locals(key, val)
		}
		{% endif %}

		c.Locals("{{ middleware_def.context_key | default('user') }}", token)
		return c.Next()
	}
}

{% elif middleware_def.type == 'combined' %}
// {{ middleware_def.name | capitalize }}Middleware - {{ middleware_def.description }}
func {{ middleware_def.name | capitalize }}Middleware() fiber.Handler {
	return func(c *fiber.Ctx) error {
		{% for component in middleware_def.components %}
		{% if component.type == 'api_key' %}
		// Validate API Key
		apiKey := c.Get("{{ component.header }}")
		if apiKey == "" {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "api_key_missing")
		}
		

		{% if component.secret_key_env %}
		expectedAPIKey := viper.GetString("{{ component.secret_key_env }}",'')
		{% else %}
		expectedAPIKey := viper.GetString("API_KEY")
		{% endif %}

		if apiKey != expectedAPIKey {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "api_key_invalid")
		}

		{% endif %}
		{% if component.type == 'app_token' %}
		// Validate App Token (JWT)
		appToken := c.Get("{{ component.header }}")
		if appToken == "" {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "app_token_missing")
		}

		appTokenParsed, err := jwt.Parse(appToken, func(token *jwt.Token) (interface{}, error) {
			if _, ok := token.Method.(*jwt.SigningMethodHMAC); !ok {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			
			return []byte(viper.GetString("{{ component.secret_key_env }}")), nil
		})

		if err != nil || !appTokenParsed.Valid {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "app_token_invalid")
		}

		appClaims, ok := appTokenParsed.Claims.(jwt.MapClaims)
		if !ok {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "app_token_invalid_claims")
		}

		{% for claim in component.claims_required %}
		if _, ok := appClaims["{{ claim }}"]; !ok {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "app_token_missing_{{ claim }}")
		}
		{% endfor %}

		appID, _ := appClaims["app_id"].(string)
		c.Locals("{{ config.middleware.locals.app_id | default('app_id') }}", appID)

		{% endif %}
		{% if component.type == 'signature' %}
		// Validate HMAC Signature
		signature := c.Get("{{ component.header }}")
		timestamp := c.Get("{{ component.timestamp_header }}")

		if signature == "" || timestamp == "" {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "signature_headers_missing")
		}

		// Parse timestamp
		{% if component.timestamp_format == 'Unix' %}
		ts, err := strconv.ParseInt(timestamp, 10, 64)
		if err != nil {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "timestamp_invalid_format")
		}
		requestTime := time.Unix(ts, 0)
		{% else %}
		requestTime, err := time.Parse(time.RFC3339, timestamp)
		if err != nil {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "timestamp_invalid_format")
		}
		{% endif %}

		// Check timestamp window
		maxAge, _ := time.ParseDuration("{{ component.timestamp_window }}")
		if time.Since(requestTime) > maxAge {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "timestamp_stale")
		}

		// Compute HMAC signature
		data := ""
		{% for field in component.signature_fields %}
		data += c.Get("{{ field }}")
		{% endfor %}

		{% if component.algorithm == 'hmac_sha512' %}
		mac := hmac.New(sha512.New, []byte(viper.GetString("{{ component.secret_key_env }}")))
		{% else %}
		mac := hmac.New(sha256.New, []byte(viper.GetString("{{ component.secret_key_env }}")))
		{% endif %}
		mac.Write([]byte(data))
		expectedSignature := base64.StdEncoding.EncodeToString(mac.Sum(nil))

		if !hmac.Equal([]byte(signature), []byte(expectedSignature)) {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "signature_invalid")
		}

		{% endif %}
		{% if component.type == 'jwt' %}
		// Validate User JWT
		authHeader := c.Get("{{ component.header }}")
		if authHeader == "" {
			authHeader = c.Query("token") // WebSocket fallback
		}

		if authHeader == "" {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "authorization_missing")
		}

		{% if component.scheme %}
		tokenString := strings.TrimPrefix(authHeader, "{{ component.scheme }} ")
		{% else %}
		tokenString := authHeader
		{% endif %}

		userJWT, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {
			{% if component.algorithm %}
			// Verify algorithm: {{ component.algorithm }}
			{% if component.algorithm.startswith('HS') or component.algorithm.startswith('hmac') %}
			expectedAlg := "{{ component.algorithm.upper().replace('HMAC_SHA', 'HS') }}"
			if _, ok := token.Method.(*jwt.SigningMethodHMAC); !ok || token.Method.Alg() != expectedAlg {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% elif component.algorithm.startswith('RS') or component.algorithm.startswith('rsa') %}
			expectedAlg := "{{ component.algorithm.upper().replace('RSA_SHA', 'RS') }}"
			if _, ok := token.Method.(*jwt.SigningMethodRSA); !ok || token.Method.Alg() != expectedAlg {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% elif component.algorithm.startswith('ES') or component.algorithm.startswith('ecdsa') %}
			expectedAlg := "{{ component.algorithm.upper().replace('ECDSA_SHA', 'ES') }}"
			if _, ok := token.Method.(*jwt.SigningMethodECDSA); !ok || token.Method.Alg() != expectedAlg {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% else %}
			// Default HMAC check
			if _, ok := token.Method.(*jwt.SigningMethodHMAC); !ok {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% endif %}
			{% else %}
			// No algorithm specified, accept any HMAC
			if _, ok := token.Method.(*jwt.SigningMethodHMAC); !ok {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			{% endif %}
			
			{% if component.secret_key_env %}
			return []byte(viper.GetString("{{ component.secret_key_env }}")), nil
			{% else %}
			return []byte(viper.GetString("JWT_SECRET")), nil
			{% endif %}
		})

		if err != nil || !userJWT.Valid {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "user_token_invalid")
		}

		userClaims, ok := userJWT.Claims.(jwt.MapClaims)
		if !ok {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "user_token_invalid_claims")
		}

		{% if component.claims %}
		// New typed claims format
		{% for claim in component.claims %}
		if val, ok := userClaims["{{ claim.name }}"]; ok {
			{% if claim.type == 'uint' or claim.type == 'uint64' %}
			if floatVal, ok := val.(float64); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", uint(floatVal))
			}
			{% elif claim.type == 'int' or claim.type == 'int64' %}
			if floatVal, ok := val.(float64); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", int(floatVal))
			}
			{% elif claim.type == 'string' %}
			if strVal, ok := val.(string); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", strVal)
			}
			{% elif claim.type == 'bool' %}
			if boolVal, ok := val.(bool); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", boolVal)
			}
			{% elif claim.type == 'float64' %}
			if floatVal, ok := val.(float64); ok {
				c.Locals("{{ claim.context_key | default(claim.name) }}", floatVal)
			}
			{% else %}
			c.Locals("{{ claim.context_key | default(claim.name) }}", val)
			{% endif %}
			{% if claim.required %}
		} else {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "missing_claim_{{ claim.name }}")
			{% endif %}
		}
		{% endfor %}
		{% elif component.claims_required %}
		// Legacy claims_required format
		{% for claim in component.claims_required %}
		if val, ok := userClaims["{{ claim }}"]; ok {
			{% if claim == 'user_id' %}
			c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}", uint(val.(float64)))
			{% elif claim == 'email' %}
			c.Locals("{{ config.middleware.locals.email | default('email') }}", val)
			{% else %}
			c.Locals("{{ claim }}", val)
			{% endif %}
		} else {
			return errorspkg.SendError(c, fiber.StatusUnauthorized, "missing_claim_{{ claim }}")
		}
		{% endfor %}
		{% else %}
		// No claims specified - extract all
		for key, val := range userClaims {
			c.Locals(key, val)
		}
		{% endif %}

		{% endif %}
		{% endfor %}
		return c.Next()
	}
}

{% elif middleware_def.type == 'rate_limit' %}
// {{ middleware_def.name | capitalize }}Middleware - {{ middleware_def.description }}
func {{ middleware_def.name | capitalize }}Middleware() fiber.Handler {
	window, _ := time.ParseDuration("{{ middleware_def.window | default('1m') }}")
	return limiter.New(limiter.Config{
		Max:        {{ middleware_def.max_requests | default(60) }},
		Expiration: window,
		KeyGenerator: func(c *fiber.Ctx) string {
			{% if middleware_def.key_generator == 'ip' %}
			return c.IP()
			{% elif middleware_def.key_generator == 'user_id' %}
			if userID, ok := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint); ok {
				return fmt.Sprintf("user_%d", userID)
			}
			return c.IP()
			{% elif middleware_def.key_generator == 'api_key' %}
			return c.Get("X-API-Key")
			{% else %}
			return c.IP()
			{% endif %}
		},
		LimitReached: func(c *fiber.Ctx) error {
			return errorspkg.SendError(c, fiber.StatusTooManyRequests, "rate_limit_exceeded")
		},
	})
}

{% elif middleware_def.type == 'role_check' %}
// {{ middleware_def.name | capitalize }}Middleware - {{ middleware_def.description }}
// NOTE: Assumes User model has .IsAdmin field (if check_is_admin) or .Role field (if required_role)
func {{ middleware_def.name | capitalize }}Middleware() fiber.Handler {
	return func(c *fiber.Ctx) error {
		{% if middleware_def.check_is_admin %}
		// Check if user is admin
		isAdminVal := c.Locals("{{ config.middleware.locals.is_admin | default('is_admin') }}")
		if isAdmin, ok := isAdminVal.(bool); ok && isAdmin {
			return c.Next()
		}

		userID := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint)
		db := utilspkg.GetDB(c)
		user, err := cache.GetUser(userID, db)
		if err != nil || !user.IsAdmin {
			return errorspkg.SendError(c, fiber.StatusForbidden, "admin_access_required")
		}
		{% elif middleware_def.required_role %}
		// Check for specific role
		roleVal := c.Locals("{{ config.middleware.locals.role | default('role') }}")
		if userRole, ok := roleVal.(string); ok && userRole == "{{ middleware_def.required_role }}" {
			return c.Next()
		}

		userID := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint)
		db := utilspkg.GetDB(c)
		user, err := cache.GetUser(userID, db)
		if err != nil || user.Role != "{{ middleware_def.required_role }}" {
			return errorspkg.SendError(c, fiber.StatusForbidden, "insufficient_permissions")
		}
		{% endif %}
		return c.Next()
	}
}

{% elif middleware_def.type == 'ownership_check' %}
// {{ middleware_def.name | capitalize }}Middleware - {{ middleware_def.description }}
// NOTE: If allow_admin is true, assumes User model has .IsAdmin field
func {{ middleware_def.name | capitalize }}Middleware() fiber.Handler {
	return func(c *fiber.Ctx) error {
		userID := c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}").(uint)
		resourceID := c.Params("{{ middleware_def.resource_id_param }}")

		{% if middleware_def.allow_admin %}
		// Check if user is admin first
		db := utilspkg.GetDB(c)
		user, err := cache.GetUser(userID, db)
		if err == nil && user.IsAdmin {
			return c.Next()
		}
		{% endif %}

		// TODO: Implement resource ownership check
		// This would typically query the resource and check if {{ middleware_def.user_id_field }} matches userID

		return c.Next()
	}
}

{% elif middleware_def.type == 'header_check' %}
// {{ middleware_def.name | capitalize }}Middleware - {{ middleware_def.description }}
func {{ middleware_def.name | capitalize }}Middleware() fiber.Handler {
	return func(c *fiber.Ctx) error {
		{% for header in middleware_def.required_headers %}
		if c.Get("{{ header.name }}") == "" {
			return errorspkg.SendError(c, fiber.StatusBadRequest, "missing_header_{{ header.name | lower | replace('-', '_') }}")
		}
		{% if header.value %}
		if c.Get("{{ header.name }}") != "{{ header.value }}" {
			return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_header_{{ header.name | lower | replace('-', '_') }}")
		}
		{% endif %}
		{% endfor %}
		return c.Next()
	}
}

