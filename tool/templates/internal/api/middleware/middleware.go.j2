// SessionMiddleware extracts session and stores it in context
func SessionMiddleware(store *session.Store) fiber.Handler {
	return func(c *fiber.Ctx) error {
		sess, err := store.Get(c)
		if err != nil {
			return errorspkg.SendError(c, fiber.StatusInternalServerError, "session_retrieval_failed")
		}
		c.Locals("{{ config.middleware.locals.session | default('session') }}", sess)
		return c.Next()
	}
}

// WebRequireAuth ensures user is authenticated via session
func WebRequireAuth() fiber.Handler {
	return func(c *fiber.Ctx) error {
		sessVal := c.Locals("{{ config.middleware.locals.session | default('session') }}")
		if sessVal == nil {
			c.Set("HX-Redirect", "{{ config.middleware.web_auth.redirects.login | default('/login') }}")
			return c.Redirect("{{ config.middleware.web_auth.redirects.login | default('/login') }}")
		}
		sess := sessVal.(*session.Session)

		auth := sess.Get("{{ config.middleware.web_auth.session_keys.authenticated | default('authenticated') }}")
		userID := sess.Get("{{ config.middleware.web_auth.session_keys.user_id | default('user_id') }}")

		if auth != true || userID == nil {
			c.Set("HX-Redirect", "{{ config.middleware.web_auth.redirects.login | default('/login') }}")
			return c.Redirect("{{ config.middleware.web_auth.redirects.login | default('/login') }}")
		}

		c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}", userID)
		return c.Next()
	}
}

{% if config.middleware.web_auth.email_verification_enabled %}
// WebRequireAuthAndVerified ensures user is authenticated and verified
// NOTE: This assumes your User model has:
//   - user.Email field
//   - user.Verified field
//   - cache.GetUser(userID, db) function exists
// If your model is different, disable this and create custom middleware
func WebRequireAuthAndVerified() fiber.Handler {
	return func(c *fiber.Ctx) error {
		sessVal := c.Locals("{{ config.middleware.locals.session | default('session') }}")
		if sessVal == nil {
			c.Set("HX-Redirect", "{{ config.middleware.web_auth.redirects.login | default('/login') }}")
			return c.Redirect("{{ config.middleware.web_auth.redirects.login | default('/login') }}")
		}
		sess := sessVal.(*session.Session)

		auth := sess.Get("{{ config.middleware.web_auth.session_keys.authenticated | default('authenticated') }}")
		userID, ok := sess.Get("{{ config.middleware.web_auth.session_keys.user_id | default('user_id') }}").(uint)

		if auth != true || !ok || userID == 0 {
			c.Set("HX-Redirect", "{{ config.middleware.web_auth.redirects.login | default('/login') }}")
			return c.Redirect("{{ config.middleware.web_auth.redirects.login | default('/login') }}")
		}

		db := utilspkg.GetDB(c)
		user, err := cache.GetUser(userID, db)
		if err != nil {
			return c.Redirect("{{ config.middleware.web_auth.redirects.server_error | default('/server-error') }}")
		}

		c.Locals("{{ config.middleware.locals.user_id | default('user_id') }}", userID)
		c.Locals("{{ config.middleware.locals.email | default('email') }}", user.Email)

		if !user.Verified {
			path := c.Path()
			{% for exclude_path in config.middleware.web_auth.verify_exclude_paths %}
			if strings.HasPrefix(path, "{{ exclude_path }}") {
				return c.Next()
			}
			{% endfor %}
			c.Set("HX-Redirect", "{{ config.middleware.web_auth.redirects.verify_email | default('/auth/verify') }}")
			return c.Redirect("{{ config.middleware.web_auth.redirects.verify_email | default('/auth/verify') }}")
		}

		return c.Next()
	}
}
