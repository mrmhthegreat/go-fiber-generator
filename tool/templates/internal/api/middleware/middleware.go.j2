{% if config.middleware.maintenance.enabled %}
// BasicMiddleware handles maintenance mode and basic route filtering
func BasicMiddleware() fiber.Handler {
	return func(c *fiber.Ctx) error {
		if viper.GetBool("{{ config.middleware.maintenance.mode_key_env | default('MAINTENANCE_MODE') }}") {
			path := c.Path()
			
			// Check if path is excluded from maintenance mode
			{% for exclude_path in config.middleware.maintenance.exclude_paths %}
			if strings.HasPrefix(path, "{{ exclude_path }}") {
				return c.Next()
			}
			{% endfor %}
			
			// API routes return JSON error
			if strings.HasPrefix(path, "/api/") {
				return errorspkg.SendError(c, fiber.StatusServiceUnavailable, "{{ config.middleware.maintenance.api_error_code | default('service_unavailable_maintenance') }}")
			}
			
			// Web routes redirect to maintenance page
			c.Set("HX-Redirect", "{{ config.middleware.maintenance.redirect_path | default('/under-maintenance') }}")
			return c.Redirect("{{ config.middleware.maintenance.redirect_path | default('/under-maintenance') }}")
		}
		return c.Next()
	}
}
{% endif %}

