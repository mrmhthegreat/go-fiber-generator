// ============================================
// GLOBAL MIDDLEWARE SETUP
// ============================================

// SetupGlobalMiddleware configures global app-wide middleware
func SetupGlobalMiddleware(app *fiber.App, dbConn *db.GormDatabase) {
	app.Use(DBMiddleware(dbConn))
	app.Use(BasicMiddleware())
	{% if config.middleware.compression.enabled %}
	app.Use(compress.New(compress.Config{
		Level: compress.Level{{ config.middleware.compression.level | default('BestSpeed') | title }},
	}))
	{% endif %}
	{% if config.middleware.logging.enabled %}
	app.Use(logger.New(logger.Config{
		Format: "[${time}] ${status} - ${latency} ${method} ${path}\n",
		{% if config.middleware.logging.log_body %}TimeFormat: "2006-01-02 15:04:05",{% endif %}
	}))
	{% endif %}
	{% if config.middleware.cors.enabled %}
	app.Use(cors.New(cors.Config{
		AllowOrigins:     "{{ config.middleware.cors.allow_origins | default('*') }}",
		AllowHeaders:     "{{ config.middleware.cors.allow_headers | default('Origin, Content-Type, Accept, Authorization') }}",
		AllowMethods:     "{{ config.middleware.cors.allow_methods | default('GET, POST, PUT, DELETE, OPTIONS') }}",
		AllowCredentials: {{ config.middleware.cors.allow_credentials | default('false') | lower }},
	}))
	{% endif %}
}

// SetupWebMiddleware configures web-specific middleware
{% if config.middleware.web_auth.enabled or config.session.enabled %}
func SetupWebMiddleware(web fiber.Router, store *session.Store) {
	{% if config.session.cookie_secret_key_env %}
	web.Use(encryptcookie.New(encryptcookie.Config{
		Key: viper.GetString("{{ config.session.cookie_secret_key_env }}"),
	}))
	{% endif %}
	web.Use(SessionMiddleware(store))
	{% if config.middleware.csrf.enabled %}
	web.Use(CSRFMiddleware(store))
	{% endif %}
}
{% endif %}

