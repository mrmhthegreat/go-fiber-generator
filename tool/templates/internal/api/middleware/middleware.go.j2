// DBMiddleware injects the database connection into context locals
func DBMiddleware(dbConn *db.GormDatabase) fiber.Handler {
	return func(c *fiber.Ctx) error {
		c.Locals("{{ config.middleware.database.context_key | default('db') }}", dbConn)
		return c.Next()
	}
}
