package routes

import (
    "github.com/gofiber/fiber/v2"
    "github.com/gofiber/fiber/v2/middleware/session"
    "github.com/gofiber/contrib/websocket"

    "{{ config.project.module }}/controllers"
    "{{ config.project.module }}/middleware"
    "{{ config.project.module }}/webhandler"
    "{{ config.project.module }}/handlers"
    "{{ config.project.module }}/db"
    {% if config.fcm.enabled %}
    "{{ config.project.module }}/fcm"
    {% endif %}
    {% if config.imap.enabled %}
    "{{ config.project.module }}/imap"
    {% endif %}
    {% if config.authentication.rbac.enabled %}
    "{{ config.project.module }}/rbac"
    {% endif %}
)

// SetupRoutes initializes all application routes
func SetupRoutes(app *fiber.App, store *session.Store, dbConn *db.GormDatabase, rbacCtrl *rbac.RBACController) {
    // Global Middleware
    middleware.SetupGlobalMiddleware(app, dbConn)

    // API Routes
    setupAPIRoutes(app, store, rbacCtrl)

    // Web Routes
    {% if config.get('features', {}).get('web', {}).get('enabled') or config.get('routes', {}).get('web', {}).get('enabled') %}
    setupWebRoutes(app, store, rbacCtrl)
    {% endif %}

    // WebSocket Routes
    {% if config.get('chat', {}).get('websocket', {}).get('enabled') or config.get('routes', {}).get('websockets', {}).get('enabled') %}
    setupWebSocketRoutes(app)
    {% endif %}
}

// setupAPIRoutes configures all API routes
func setupAPIRoutes(app *fiber.App, store *session.Store, rbacCtrl *rbac.RBACController) {
    api := app.Group("/api")
    
    {% if config.middleware.rate_limit.enabled %}
    api.Use(middleware.NewRateLimiter(middleware.APIBaseLimiter))
    {% endif %}
    
    setupPublicAPIRoutes(api)
    setupProtectedAPIRoutes(api, rbacCtrl)
    
    // CRUD Endpoints (Dynamically generated)
    {% if config.endpoints %}
    {% for endpoint in config.endpoints %}
    {% set model_name = endpoint.model %}
    {% set model_lower = model_name | lower %}
    {% set route_prefix = endpoint.base_path | default('/' ~ model_lower ~ 's') %}
    {% if route_prefix.startswith('/api') %}
    {% set route_path = route_prefix.replace('/api', '', 1) %}
    {% else %}
    {% set route_path = route_prefix %}
    {% endif %}
    
    // Routes for {{ model_name }}
    {{ model_lower }}Group := api.Group("{{ route_path }}")
    
    {% if endpoint.middleware %}
    {% for m in endpoint.middleware %}
    {{ model_lower }}Group.Use(middleware.{{ m | capitalize }}Middleware())
    {% endfor %}
    {% endif %}
    
    {# Handle both list of strings or list of objects #}
    {% set ops = endpoint.operations | default(['list', 'get', 'create', 'update', 'delete']) %}
    {% for op in ops %}
    {% if op is string %}
        {% set op_type = op %}
        {% set op_method = '' %}
        {% set op_path = '/' %}
        {% if op == 'get' or op == 'update' or op == 'delete' %}
            {% set op_path = '/:id' %}
        {% endif %}
    {% else %}
        {% set op_type = op.type %}
        {% set op_method = op.method %}
        {% set op_path = op.path | default('/') %}
    {% endif %}

    {# Apply operation-specific middleware if it's an object #}
    {% if op is not string and op.middleware %}
    // Middleware for {{ op_type }} {{ model_name }}
    {% for m in op.middleware %}
    // {{ model_lower }}Group.{{ op_method | capitalize }}( "{{ op_path }}", ... ) with {{ m }}
    {% endfor %}
    {% endif %}

    {% if op_type == 'list' %}
    {{ model_lower }}Group.Get("{{ op_path }}", controllers.List{{ model_name }})
    {% elif op_type == 'get' %}
    {{ model_lower }}Group.Get("{{ op_path }}", controllers.Get{{ model_name }})
    {% elif op_type == 'create' %}
    {{ model_lower }}Group.Post("{{ op_path }}", controllers.Create{{ model_name }})
    {% elif op_type == 'update' %}
    {% set method = op_method | default('PUT') %}
    {{ model_lower }}Group.{{ method | capitalize }}("{{ op_path }}", controllers.Update{{ model_name }})
    {% elif op_type == 'delete' %}
    {{ model_lower }}Group.Delete("{{ op_path }}", controllers.Delete{{ model_name }})
    {% elif op_type == 'custom' %}
    {{ model_lower }}Group.{{ op_method | capitalize }}("{{ op_path }}", controllers.{{ op.name | default('Custom' ~ model_name) }})
    {% endif %}
    {% endfor %}
    
    {% endfor %}
    {% endif %}
}

// setupPublicAPIRoutes configures public API routes
func setupPublicAPIRoutes(api fiber.Router) {
    {% if config.webhooks %}
    // Webhook routes
    {% for webhook in config.webhooks %}
    api.{{ webhook.method | lower }}("{{ webhook.path }}", controllers.{{ webhook.handler }})
    {% endfor %}
    {% endif %}

    authGroup := api.Group("/auth")
    {% if config.middleware.rate_limit.enabled %}
    authLimit := middleware.NewRateLimiter(middleware.AuthLimiter)
    authGroup.Use(authLimit)
    {% endif %}

    authGroup.Get("/check-username", controllers.SearchUsername)
    authGroup.Post("/check-email", controllers.EmailCheck)

    {% if config.authentication.email_password.enabled %}
    authGroup.Post("/register", controllers.RegisterUser)
    authGroup.Post("/login", controllers.LoginUser)
    {% if config.authentication.email_password.forgot_password.enabled %}
    authGroup.Post("/forgot-password", controllers.ForgotPassword)
    authGroup.Post("/reset-password", controllers.ResetPassword)
    {% endif %}
    {% endif %}

    {% if config.authentication.refresh_token.enabled %}
    authGroup.Post("/refresh", controllers.RefreshToken)
    {% endif %}
    
    // Social Logins
    {% if config.authentication.social_auth.google.enabled %}
    authGroup.Post("/google", controllers.GoogleLogin)
    {% endif %}
    {% if config.authentication.social_auth.facebook.enabled %}
    authGroup.Post("/facebook", controllers.FacebookLogin)
    {% endif %}
    {% if config.get('authentication', {}).get('social_auth', {}).get('apple', {}).get('enabled') %}
    authGroup.Post("/apple", controllers.AppleLogin)
    {% endif %}
}

// setupProtectedAPIRoutes configures protected API routes
func setupProtectedAPIRoutes(api fiber.Router, rbacCtrl *rbac.RBACController) {
    userGroup := api.Group("/user")

    userGroup.Get("/profile", controllers.GetUserProfile)
    userGroup.Put("/profile", controllers.UpdateUserProfile)

    // Account verification
    userGroup.Post("/verify-email", controllers.SendVerificationEmail)
    userGroup.Post("/verify-otp", controllers.VerifyOTP)

    // Password management
    userGroup.Post("/change-password", controllers.ChangePassword)

    {% if config.chat.enabled %}
    // Dynamic Chat Mode Routes
    {% for mode_name, mode_cfg in config.chat.modes.items() %}
    {% if mode_cfg.enabled %}
    {{ mode_name }}Group := api.Group("{{ mode_cfg.base_path }}")
    {% if mode_cfg.middleware %}
    {% for m in mode_cfg.middleware %}
    {{ mode_name }}Group.Use(middleware.{{ m | capitalize }}Middleware())
    {% endfor %}
    {% endif %}
    {% if mode_cfg.GetUserConversations.enabled %}
    {{ mode_name }}Group.Get("{{ mode_cfg.GetUserConversations.path | default('/conversations') }}", controllers.GetUserConversations)
    {% endif %}
    {% if mode_cfg.GetUserChatHistory.enabled %}
    {{ mode_name }}Group.Get("{{ mode_cfg.GetUserChatHistory.path | default('/history/:id') }}", controllers.GetUserChatHistory)
    {% endif %}
    {% if mode_cfg.SendUserMessage.enabled %}
    {{ mode_name }}Group.Post("{{ mode_cfg.SendUserMessage.path | default('/send') }}", controllers.SendUserMessage)
    {% endif %}
    {% if mode_cfg.MarkConversationAsRead.enabled %}
    {{ mode_name }}Group.Post("{{ mode_cfg.MarkConversationAsRead.path | default('/mark-read/:id') }}", controllers.MarkConversationAsRead)
    {% endif %}
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if config.fcm.enabled %}
    // ── FCM API routes (/api/fcm/...) ─────────────────────
    fcmH := fcm.New()
    fcmGroup := api.Group("{{ config.fcm.controller.base_path | default('/fcm') | replace('/api','',1) }}")
    {% if config.fcm.controller.middleware %}
    {% for m in config.fcm.controller.middleware %}
    fcmGroup.Use(middleware.{{ m | capitalize }}Middleware())
    {% endfor %}
    {% endif %}
    {% if config.fcm.controller.SendFCM.enabled %}
    fcmGroup.Post("{{ config.fcm.controller.SendFCM.path | default('/send') }}", {% if config.authentication.rbac.enabled %}{% for p in config.fcm.controller.SendFCM.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}fcmH.SendNotification)
    {% endif %}
    {% if config.fcm.controller.SubscribeToTopic.enabled %}
    fcmGroup.Post("{{ config.fcm.controller.SubscribeToTopic.path | default('/subscribe') }}", {% if config.authentication.rbac.enabled %}{% for p in config.fcm.controller.SubscribeToTopic.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}fcmH.SubscribeToTopic)
    {% endif %}
    fcmGroup.Get("/users", fcmH.GetUsersWithTokens)
    {% endif %}

    {% if config.imap.enabled %}
    // ── IMAP/Email API routes (/api/emails/...) ────────────
    emailH := imap.New()
    emailGroup := api.Group("{{ config.imap.controller.base_path | default('/emails') | replace('/api','',1) }}")
    {% if config.imap.controller.middleware %}
    {% for m in config.imap.controller.middleware %}
    emailGroup.Use(middleware.{{ m | capitalize }}Middleware())
    {% endfor %}
    {% endif %}
    {% if config.imap.controller.GetEmailsList.enabled %}
    emailGroup.Get("{{ config.imap.controller.GetEmailsList.path | default('/') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.controller.GetEmailsList.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.GetEmailsList)
    {% endif %}
    {% if config.imap.controller.GetEmailDetail.enabled %}
    emailGroup.Get("{{ config.imap.controller.GetEmailDetail.path | default('/:id') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.controller.GetEmailDetail.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.GetEmailDetail)
    {% endif %}
    {% if config.imap.controller.SendEmail.enabled %}
    emailGroup.Post("{{ config.imap.controller.SendEmail.path | default('/compose') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.controller.SendEmail.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.ComposeEmail)
    {% endif %}
    {% if config.imap.controller.MarkEmailRead.enabled %}
    emailGroup.Patch("{{ config.imap.controller.MarkEmailRead.path | default('/:id/read') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.controller.MarkEmailRead.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.MarkEmailRead)
    {% endif %}
    {% if config.imap.controller.RefreshEmails.enabled %}
    emailGroup.Post("{{ config.imap.controller.RefreshEmails.path | default('/refresh') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.controller.RefreshEmails.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.RefreshEmails)
    {% endif %}
    {% endif %}

    {% if config.authentication.rbac.enabled and config.authentication.rbac.controller.enabled %}
    // ── RBAC API routes ───────────────────────────────────
    rbacAPIGroup := api.Group("{{ config.authentication.rbac.controller.base_path | default('/rbac') | replace('/api','',1) }}")
    {% set rc = config.authentication.rbac.controller %}
    {% if rc.ListRoles.enabled %}
    rbacAPIGroup.Get("{{ rc.ListRoles.path | default('/roles') }}", {% for p in rc.ListRoles.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.GetRoles)
    {% endif %}
    {% if rc.GetRole.enabled %}
    rbacAPIGroup.Get("{{ rc.GetRole.path | default('/roles/:id') }}", {% for p in rc.GetRole.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.GetRolePermissions)
    {% endif %}
    {% if rc.CreateRole.enabled %}
    rbacAPIGroup.Post("{{ rc.CreateRole.path | default('/roles') }}", {% for p in rc.CreateRole.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.CreateRole)
    {% endif %}
    {% if rc.BulkUpdateRolePermissions.enabled %}
    rbacAPIGroup.Put("{{ rc.BulkUpdateRolePermissions.path | default('/roles/:id/permissions/bulk') }}", {% for p in rc.BulkUpdateRolePermissions.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.UpdateRolePermissions)
    {% endif %}
    {% if rc.DeleteRole.enabled %}
    rbacAPIGroup.Delete("{{ rc.DeleteRole.path | default('/roles/:id') }}", {% for p in rc.DeleteRole.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.DeleteRole)
    {% endif %}
    {% if rc.ListPermissions.enabled %}
    rbacAPIGroup.Get("{{ rc.ListPermissions.path | default('/permissions') }}", {% for p in rc.ListPermissions.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.GetPermissions)
    {% endif %}
    {% if rc.GetUserOverrides.enabled %}
    rbacAPIGroup.Get("{{ rc.GetUserOverrides.path | default('/users/:userId/overrides') }}", {% for p in rc.GetUserOverrides.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.GetUserPermissionOverrides)
    {% endif %}
    {% if rc.SetUserOverride.enabled %}
    rbacAPIGroup.Post("{{ rc.SetUserOverride.path | default('/users/:userId/overrides') }}", {% for p in rc.SetUserOverride.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.CreateUserPermissionOverride)
    rbacAPIGroup.Put("{{ rc.SetUserOverride.path | default('/users/:userId/overrides') }}", {% for p in rc.SetUserOverride.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.UpdateUserPermissionOverrides)
    {% endif %}
    {% if rc.RemoveUserOverride.enabled %}
    rbacAPIGroup.Delete("{{ rc.RemoveUserOverride.path | default('/overrides/:overrideId') }}", {% for p in rc.RemoveUserOverride.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.DeleteUserPermissionOverride)
    {% endif %}
    {% if rc.InvalidateCache.enabled %}
    rbacAPIGroup.Post("{{ rc.InvalidateCache.path | default('/cache/invalidate/:userId') }}", {% for p in rc.InvalidateCache.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.InvalidateUserCache)
    {% endif %}
    {% if rc.GetUserPermissions.enabled %}
    rbacAPIGroup.Get("{{ rc.GetUserPermissions.path | default('/users/:userId/permissions') }}", {% for p in rc.GetUserPermissions.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.GetUserRolePermissions)
    {% endif %}
    rbacAPIGroup.Get("/me/permissions", rbacCtrl.GetMyPermissions)
    {% if rc.enabled or rw.ManageOverridesPage.enabled %}
    rbacAPIGroup.Get("/users/search", rbacCtrl.SearchUsers)
    {% endif %}
    {% endif %}
}

// setupWebRoutes configures web routes
func setupWebRoutes(app *fiber.App, store *session.Store, rbacCtrl *rbac.RBACController) {
    web := app.Group("/")
    middleware.SetupWebMiddleware(web, store)

    web.Get("/", webhandler.HomeHandler)
    web.Get("/login", webhandler.LoginHandler)

    {% if config.fcm.enabled and config.fcm.web_handler.enabled %}
    // ── FCM Web routes (/dashboard/notifications/...) ──────
    fcmH := fcm.New()
    notifGroup := web.Group("{{ config.fcm.web_handler.base_path | default('/dashboard/notifications') }}")
    {% if config.fcm.web_handler.middleware %}
    {% for m in config.fcm.web_handler.middleware %}
    notifGroup.Use(middleware.{{ m | capitalize }}Middleware())
    {% endfor %}
    {% endif %}
    {% if config.fcm.web_handler.GetNotificationPage.enabled %}
    notifGroup.Get("{{ config.fcm.web_handler.GetNotificationPage.path | default('/') }}", {% if config.authentication.rbac.enabled %}{% for p in config.fcm.web_handler.GetNotificationPage.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}fcmH.GetNotificationPage)
    {% endif %}
    {% if config.fcm.web_handler.SendFCM.enabled %}
    notifGroup.Post("{{ config.fcm.web_handler.SendFCM.path | default('/send') }}", {% if config.authentication.rbac.enabled %}{% for p in config.fcm.web_handler.SendFCM.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}fcmH.SendNotification)
    {% endif %}
    {% if config.fcm.web_handler.SubscribeToTopic.enabled %}
    notifGroup.Post("{{ config.fcm.web_handler.SubscribeToTopic.path | default('/subscribe') }}", {% if config.authentication.rbac.enabled %}{% for p in config.fcm.web_handler.SubscribeToTopic.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}fcmH.SubscribeToTopic)
    {% endif %}
    notifGroup.Get("/users", fcmH.GetUsersWithTokens)
    {% endif %}

    {% if config.imap.enabled and config.imap.web_handler.enabled %}
    // ── IMAP/Email Web routes (/dashboard/emails/...) ──────
    emailH := imap.New()
    emailWebGroup := web.Group("{{ config.imap.web_handler.base_path | default('/dashboard/emails') }}")
    {% if config.imap.web_handler.middleware %}
    {% for m in config.imap.web_handler.middleware %}
    emailWebGroup.Use(middleware.{{ m | capitalize }}Middleware())
    {% endfor %}
    {% endif %}
    {% if config.imap.web_handler.GetInboxPage.enabled %}
    emailWebGroup.Get("{{ config.imap.web_handler.GetInboxPage.path | default('/inbox') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.web_handler.GetInboxPage.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.GetInboxPage)
    {% endif %}
    {% if config.imap.web_handler.GetSentEmails.enabled %}
    emailWebGroup.Get("{{ config.imap.web_handler.GetSentEmails.path | default('/sent') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.web_handler.GetSentEmails.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.GetSentPage)
    {% endif %}
    {% if config.imap.web_handler.GetEmailsList.enabled %}
    emailWebGroup.Get("{{ config.imap.web_handler.GetEmailsList.path | default('/list') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.web_handler.GetEmailsList.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.GetEmailsList)
    {% endif %}
    {% if config.imap.web_handler.GetEmailDetail.enabled %}
    emailWebGroup.Get("{{ config.imap.web_handler.GetEmailDetail.path | default('/:id') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.web_handler.GetEmailDetail.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.GetEmailDetail)
    {% endif %}
    {% if config.imap.web_handler.SendEmail.enabled %}
    emailWebGroup.Post("{{ config.imap.web_handler.SendEmail.path | default('/compose') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.web_handler.SendEmail.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.ComposeEmail)
    {% endif %}
    {% if config.imap.web_handler.MarkEmailRead.enabled %}
    emailWebGroup.Patch("{{ config.imap.web_handler.MarkEmailRead.path | default('/:id/read') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.web_handler.MarkEmailRead.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.MarkEmailRead)
    {% endif %}
    {% if config.imap.web_handler.RefreshEmails.enabled %}
    emailWebGroup.Post("{{ config.imap.web_handler.RefreshEmails.path | default('/refresh') }}", {% if config.authentication.rbac.enabled %}{% for p in config.imap.web_handler.RefreshEmails.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}{% endif %}emailH.RefreshEmails)
    {% endif %}
    {% endif %}

    {% if config.authentication.rbac.enabled and config.authentication.rbac.web_handler.enabled %}
    // ── RBAC Web routes ──────────────────────────────────
    rbacWebGroup := web.Group("{{ config.authentication.rbac.web_handler.base_path | default('/dashboard/rbac') }}")
    {% set rw = config.authentication.rbac.web_handler %}
    {% if rw.ManageRolesPage.enabled %}
    rbacWebGroup.Get("{{ rw.ManageRolesPage.path | default('/roles') }}", {% for p in rw.ManageRolesPage.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.ShowRBACManagement)
    {% endif %}
    {% if rw.ManageOverridesPage.enabled %}
    rbacWebGroup.Get("{{ rw.ManageOverridesPage.path | default('/overrides') }}", {% for p in rw.ManageOverridesPage.permissions %}middleware.RequirePerm("{{ p }}"), {% endfor %}rbacCtrl.ShowRBACManagement)
    {% endif %}
    {% endif %}
}

// setupWebSocketRoutes configures websocket routes
func setupWebSocketRoutes(app *fiber.App) {
    ws := app.Group("/ws")
    ws.Use(func(c *fiber.Ctx) error {
        if websocket.IsWebSocketUpgrade(c) {
            return c.Next()
        }
        return fiber.ErrUpgradeRequired
    })
    
    {% if config.chat.websocket.enabled %}
    ws.Get("{{ config.chat.websocket.path | replace('/ws', '', 1) | default('/chat') }}", websocket.New(controllers.UnifiedWebSocketHandler))
    {% endif %}
    {% if config.chat.web_handler.enabled %}
    ws.Get("/admin-chat", websocket.New(controllers.AdminChatWebSocket))
    {% endif %}
}
