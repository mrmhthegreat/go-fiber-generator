// @Router   {{ global_ctrl.get('base_path', '/api/v1/chat') }}{{ ctrl.get('endpoints', {}).get('mark_as_read', {}).get('path', '/conversations/:id/read') }} [{{ ctrl.get('endpoints', {}).get('mark_as_read', {}).get('method', 'POST') }}]
func MarkConversationAsRead(c *fiber.Ctx) error {
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	convID, err := strconv.ParseUint(c.Params("id"), 10, 32)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_conversation_id")
	}

	userID, _ := c.Locals("user_id").(uint)

{% if user_ctrl_cfg.use_repo %}
	userRepo := utilspkg.Get{{ user_ctrl_cfg.repo_name }}(dbConn)
	if userRepo == nil {
		log.Println("{{ user_ctrl_cfg.repo_name }} not available")
		return fiber.NewError(fiber.StatusInternalServerError, "db_connection_failed")
	}
	user, err := userRepo.{{ user_ctrl_cfg.method }}(userID)
	if err != nil {
		return fiber.NewError(fiber.StatusInternalServerError, "internal_server_error")
	}
{% else %}
	return fiber.NewError(fiber.StatusInternalServerError, "internal_server_error")
{% endif %}

	chatRepo := utilspkg.GetChatRepository(dbConn)
	conversation, err := chatRepo.GetConversationByIDSimple(uint(convID))
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusNotFound, "conversation_not_found")
	}

	hasAccess := conversation.{{ conv_user_id_f.name | title | replace('_', '') }} == user.ID ||
		(conversation.{{ conv_receiver_id_f.name | title | replace('_', '') }} != nil && *conversation.{{ conv_receiver_id_f.name | title | replace('_', '') }} == user.ID)
	if !hasAccess {
		return errorspkg.SendError(c, fiber.StatusForbidden, "access_denied")
	}

	if err := chatRepo.MarkMessagesAsRead(uint(convID), "user"); err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	return c.JSON(fiber.Map{"success": true})
}

// ── Private helpers ──────────────────────────────────────────────────────────

func findOrCreateSupportConversation(dbConn *db.GormDatabase, userID uint) (*domain.Conversation, error) {
{# Resolve names inside helper #}
{% set conv_user_id_f     = conv_fields | selectattr('name', 'equalto', 'user_id') | first | default({'name': 'user_id'}) %}
{% set conv_receiver_id_f = conv_fields | selectattr('name', 'equalto', 'receiver_id') | first | default({'name': 'receiver_id'}) %}
{% set conv_type_f        = conv_fields | selectattr('name', 'equalto', 'conv_type') | first | default({'name': 'conv_type'}) %}
	var conversation domain.Conversation
	err := dbConn.DB.Where("{{ conv_user_id_f.name }} = ? AND {{ conv_receiver_id_f.name }} IS NULL AND {{ conv_type_f.name }} = 'support'", userID).
		First(&conversation).Error

	if err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) {
			newConv := &domain.Conversation{
				{{ conv_user_id_f.name | title | replace('_', '') }}:   userID,
				Status:   "open",
				{{ conv_type_f.name | title | replace('_', '') }}: "support",
			}
			chatRepo := utilspkg.GetChatRepository(dbConn)
			return chatRepo.CreateConversation(newConv)
		}
		return nil, err
	}
	return &conversation, nil
}

func findOrCreateUserConversation(dbConn *db.GormDatabase, userID1, userID2 uint) (*domain.Conversation, error) {
{# Resolve names inside helper #}
{% set conv_user_id_f     = conv_fields | selectattr('name', 'equalto', 'user_id') | first | default({'name': 'user_id'}) %}
{% set conv_receiver_id_f = conv_fields | selectattr('name', 'equalto', 'receiver_id') | first | default({'name': 'receiver_id'}) %}
{% set conv_type_f        = conv_fields | selectattr('name', 'equalto', 'conv_type') | first | default({'name': 'conv_type'}) %}
	chatRepo := utilspkg.GetChatRepository(dbConn)
	conversation, err := chatRepo.GetConversationBetweenUsers(userID1, userID2)
	if err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) || err.Error() == "conversation not found" {
			newConv := &domain.Conversation{
				{{ conv_user_id_f.name | title | replace('_', '') }}:     userID1,
				{{ conv_receiver_id_f.name | title | replace('_', '') }}: &userID2,
				Status:     "open",
				{{ conv_type_f.name | title | replace('_', '') }}:   "user_to_user",
			}
			return chatRepo.CreateConversation(newConv)
		}
		return nil, err
	}
	return conversation, nil
}
{% endif %}
