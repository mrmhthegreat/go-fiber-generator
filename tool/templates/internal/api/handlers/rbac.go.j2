{% if rc.SetUserOverride.enabled or rw.ManageOverridesPage.enabled %}
{% if rc.SetUserOverride.enabled %}
// CreateUserPermissionOverride creates a permission override for a user
// @Summary Create user permission override
// @Description Creates a specific allow/deny override for a user and a permission
// @Tags {{ config.rbac.controller.tag | default('RBAC Management') }}
// @Accept json
// @Produce json
// @Param userId path string true "User ID"
// @Param input body struct { PermissionKey string `json:"permission_key"`; Allow bool `json:"allow"`; Reason string `json:"reason"`; ExpiresAt *time.Time `json:"expires_at"` } true "Override details"
// @Success 201 {object} map[string]interface{}
// @Failure 400 {object} map[string]string
// @Failure 404 {object} map[string]string
// @Router {{ config.rbac.controller.base_path | default('/api/rbac') }}{{ config.rbac.controller.SetUserOverride.path | default('/users/{userId}/overrides') }} [post]
{% endif %}
func (ctrl *RBACController) CreateUserPermissionOverride(c *fiber.Ctx) error {
    userID := c.Params("userId")
    db := utilspkg.GetDB(c).DB

    var req struct {
        PermissionKey string     `json:"permission_key"`
        Allow         bool       `json:"allow"`
        Reason        string     `json:"reason"`
        ExpiresAt     *time.Time `json:"expires_at"`
    }
    if err := c.BodyParser(&req); err != nil {
        return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
            "error": "Invalid request body",
        })
    }

    uid, err := strconv.ParseUint(userID, 10, 32)
    if err != nil {
        return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
            "error": "Invalid user ID",
        })
    }

    var user domain.User
    if err := db.First(&user, uid).Error; err != nil {
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
            "error": "User not found",
        })
    }

    userRole := user.{{ config.rbac.model_field }}
    if userRole == "" {
        userRole =  {{ config.rbac.default_role }}
    }

    if req.Allow && !ctrl.rbacService.IsPermissionAllowedForRole(userRole, req.PermissionKey) {
        return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
            "error":   "Cannot grant permission: " + req.PermissionKey,
            "message": "Permission '" + req.PermissionKey + "' is not allowed for users with role '" + userRole + "'.",
        })
    }

    var perm domain.Permission
    if err := db.Where("key = ?", req.PermissionKey).First(&perm).Error; err != nil {
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
            "error": "Permission not found",
        })
    }

    override := domain.UserPermissionOverride{
        UserID:       uint(uid),
        PermissionID: perm.ID,
        Allow:        req.Allow,
        Reason:       req.Reason,
        ExpiresAt:    req.ExpiresAt,
    }

    if err := db.Create(&override).Error; err != nil {
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
            "error": "Failed to create override",
        })
    }

    ctx := context.Background()
    ctrl.rbacService.InvalidateUserCache(ctx, uint(uid))

    return c.Status(fiber.StatusCreated).JSON(fiber.Map{
        "message":  "Override created successfully",
        "override": override,
    })
}

