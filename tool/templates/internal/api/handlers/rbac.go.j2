{% if rc.enabled or rw.ManageOverridesPage.enabled %}
// SearchUsers searches for users by email, name, or ID
// @Summary Search users for RBAC
// @Description Search for users to manage their permissions or overrides
// @Tags {{ config.rbac.controller.tag | default('RBAC Management') }}
// @Produce json
// @Param q query string true "Search query"
// @Success 200 {object} map[string]interface{}
// @Router {{ config.rbac.controller.base_path | default('/api/rbac') }}/users/search [get]
func (ctrl *RBACController) SearchUsers(c *fiber.Ctx) error {
    query := c.Query("q")
    if query == "" {
        return c.JSON(fiber.Map{"users": []interface{}{}})
    }

    db := utilspkg.GetDB(c).DB
    var users []domain.User

    if id, err := strconv.ParseUint(query, 10, 32); err == nil {
        db.Where("id = ?", uint(id)).Limit(10).Find(&users)
    } else {
        searchTerm := "%" + query + "%"
        db.Where("email LIKE ? OR fullname LIKE ?", searchTerm, searchTerm).Limit(10).Find(&users)
    }

    var response []fiber.Map
    for _, user := range users {
        response = append(response, fiber.Map{
            "id":            user.ID,
            "name":          user.Fullname,
            "email":         user.Email,
            "fullname":      user.Fullname,
            "role":          user.{{ config.rbac.model_field }},
        })
    }

    return c.JSON(fiber.Map{"users": response})
}
{% endif %}

{% if rc.SetUserOverride.enabled or rw.ManageOverridesPage.enabled or rw.SetUserOverride.enabled %}
{% if rc.SetUserOverride.enabled %}
// UpdateUserPermissionOverrides updates all permission overrides for a user
// @Summary Bulk update user overrides
// @Description Replaces all existing overrides for a user with a new set
// @Tags {{ config.rbac.controller.tag | default('RBAC Management') }}
// @Accept json
// @Produce json
// @Param userId path string true "User ID"
// @Param input body struct { Overrides []struct { PermissionKey string `json:"permission_key"`; Allow bool `json:"allow"` } `json:"overrides"` } true "List of overrides"
// @Success 200 {object} map[string]interface{}
// @Failure 400 {object} map[string]string
// @Failure 403 {object} map[string]string
// @Router {{ config.rbac.controller.base_path | default('/api/rbac') }}{{ config.rbac.controller.SetUserOverride.path | default('/users/{userId}/overrides') }} [put]
{% endif %}
func (ctrl *RBACController) UpdateUserPermissionOverrides(c *fiber.Ctx) error {
    userID := c.Params("userId")
    db := utilspkg.GetDB(c).DB

    uid, err := strconv.ParseUint(userID, 10, 32)
    if err != nil {
        return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
            "error": "Invalid user ID",
        })
    }

    var req struct {
        Overrides []struct {
            PermissionKey string `json:"permission_key"`
            Allow         bool   `json:"allow"`
        } `json:"overrides"`
    }

    if err := c.BodyParser(&req); err != nil {
        return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
            "error": "Invalid request body",
        })
    }

    var user domain.User
    if err := db.First(&user, uid).Error; err != nil {
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
            "error": "User not found",
        })
    }

    userRole := user.{{ config.rbac.model_field }}
    if userRole == "" {
        userRole = {{config.rbac.default_role}}
    }

    for _, override := range req.Overrides {
        if override.Allow {
            if !ctrl.rbacService.IsPermissionAllowedForRole(userRole, override.PermissionKey) {
                return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
                    "error":   "Invalid permission override",
                    "message": "Cannot grant permission '" + override.PermissionKey + "' to user with role '" + userRole + "'.",
                })
            }
        }
    }

    permKeys := make([]string, 0, len(req.Overrides))
    for _, override := range req.Overrides {
        permKeys = append(permKeys, override.PermissionKey)
    }

    var permissions []domain.Permission
    if err := db.Where("key IN ?", permKeys).Find(&permissions).Error; err != nil {
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
            "error": "Failed to fetch permissions",
        })
    }

    permKeyToID := make(map[string]uint)
    for _, perm := range permissions {
        permKeyToID[perm.Key] = perm.ID
    }

    overridesToCreate := make([]domain.UserPermissionOverride, 0, len(req.Overrides))
    for _, override := range req.Overrides {
        permID, exists := permKeyToID[override.PermissionKey]
        if !exists {
            continue
        }

        overridesToCreate = append(overridesToCreate, domain.UserPermissionOverride{
            UserID:       uint(uid),
            PermissionID: permID,
            Allow:        override.Allow,
            Reason:       "Bulk update from admin panel",
        })
    }

    err = db.Transaction(func(tx *gorm.DB) error {
        if err := tx.Where("user_id = ?", uid).Delete(&domain.UserPermissionOverride{}).Error; err != nil {
            return err
        }

        if len(overridesToCreate) > 0 {
            if err := tx.Create(&overridesToCreate).Error; err != nil {
                return err
            }
        }

        return nil
    })

    if err != nil {
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
            "error": "Failed to update user overrides",
        })
    }

    ctx := context.Background()
    ctrl.rbacService.InvalidateUserCache(ctx, uint(uid))

    return c.JSON(fiber.Map{
        "success": true,
        "message": "User overrides updated successfully",
    })
}
{% endif %}

{% if rc.RemoveUserOverride.enabled or rw.ManageOverridesPage.enabled or rw.RemoveUserOverride.enabled %}
{% if rc.RemoveUserOverride.enabled %}
// DeleteUserPermissionOverride deletes a specific permission override
// @Summary Delete a user override
// @Description Removes a specific permission override by its ID
// @Tags {{ config.rbac.controller.tag | default('RBAC Management') }}
// @Produce json
// @Param overrideId path string true "Override ID"
// @Success 200 {object} map[string]string
// @Failure 404 {object} map[string]string
// @Router {{ config.rbac.controller.base_path | default('/api/rbac') }}{{ config.rbac.controller.RemoveUserOverride.path | default('/users/{userId}/overrides/{permId}') | replace(':userId', '{userId}') | replace(':permId', '{permId}') }} [delete]
{% endif %}
func (ctrl *RBACController) DeleteUserPermissionOverride(c *fiber.Ctx) error {
    overrideID := c.Params("overrideId")
    db := utilspkg.GetDB(c).DB

    var override domain.UserPermissionOverride
    if err := db.First(&override, overrideID).Error; err != nil {
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
            "error": "Override not found",
        })
    }

    userID := override.UserID

    if err := db.Delete(&override).Error; err != nil {
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
            "error": "Failed to delete override",
        })
    }

    ctx := context.Background()
    ctrl.rbacService.InvalidateUserCache(ctx, userID)

    return c.JSON(fiber.Map{
        "message": "Override deleted successfully",
    })
}
{% endif %}

