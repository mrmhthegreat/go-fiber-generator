{% if rc.ListPermissions.enabled or rw.ManageRolesPage.enabled or rw.ListPermissions.enabled %}
{% if rc.ListPermissions.enabled %}
// GetPermissions returns all permissions grouped by category
// @Summary Get all permissions
// @Description Retrieves all permissions, grouped by category, and shows role default permissions
// @Tags {{ config.rbac.controller.tag | default('RBAC Management') }}
// @Produce json
// @Success 200 {object} map[string]interface{}
// @Failure 500 {object} map[string]string
// @Router {{ config.rbac.controller.base_path | default('/api/rbac') }}{{ config.rbac.controller.ListPermissions.path | default('/permissions') }} [get]
{% endif %}
func (ctrl *RBACController) GetPermissions(c *fiber.Ctx) error {
    db := utilspkg.GetDB(c).DB

    var permissions []domain.Permission
    if err := db.Order("category, key").Find(&permissions).Error; err != nil {
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
            "error": "Failed to fetch permissions",
        })
    }

    grouped := make(map[string][]domain.Permission)
    for _, perm := range permissions {
        grouped[perm.Category] = append(grouped[perm.Category], perm)
    }

    roleAllowed := make(map[string][]string)
    for roleName := range ctrl.rbacService.Config.RoleDefaults {
        if roleName != "seller_allowed" && roleName != "moderator_allowed" && roleName != "admin_allowed" {
            roleAllowed[roleName] = ctrl.rbacService.GetRoleAllowedPermissions(roleName)
        }
    }

    return c.JSON(fiber.Map{
        "permissions":  permissions,
        "grouped":      grouped,
        "role_allowed": roleAllowed,
    })
}
{% endif %}

