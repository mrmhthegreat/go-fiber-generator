// DeleteRole deletes a role (only non-system roles)
// @Summary Delete a role
// @Description Deletes a custom role (system roles cannot be deleted)
// @Tags {{ config.rbac.controller.tag | default('RBAC Management') }}
// @Produce json
// @Param roleId path string true "Role ID"
// @Success 200 {object} map[string]string
// @Failure 403 {object} map[string]string
// @Failure 404 {object} map[string]string
// @Router {{ config.rbac.controller.base_path | default('/api/rbac') }}{{ config.rbac.controller.DeleteRole.path | default('/roles/:id') | replace(':id', '{roleId}') }} [delete]
{% endif %}
func (ctrl *RBACController) DeleteRole(c *fiber.Ctx) error {
    roleID := c.Params("roleId")
    db := utilspkg.GetDB(c).DB

    var role domain.Role
    if err := db.First(&role, roleID).Error; err != nil {
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
            "error": "Role not found",
        })
    }

    if role.IsSystem {
        return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
            "error": "Cannot delete system roles",
        })
    }

    if err := db.Delete(&role).Error; err != nil {
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
            "error": "Failed to delete role",
        })
    }

    return c.JSON(fiber.Map{
        "message": "Role deleted successfully",
    })
}
