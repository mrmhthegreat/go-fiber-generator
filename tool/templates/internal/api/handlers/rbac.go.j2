{% if rc.BulkUpdateRolePermissions.enabled or rw.ManageRolesPage.enabled or rw.BulkUpdateRolePermissions.enabled %}
{% if rc.BulkUpdateRolePermissions.enabled %}
// UpdateRolePermissions updates permissions for a role
// @Summary Update role permissions
// @Description Updates multiple permissions for a specific role at once
// @Tags {{ config.rbac.controller.tag | default('RBAC Management') }}
// @Accept json
// @Produce json
// @Param roleId path string true "Role ID"
// @Param input body struct { Permissions map[string]bool `json:"permissions"` } true "Permissions map"
// @Success 200 {object} map[string]string
// @Failure 400 {object} map[string]string
// @Failure 403 {object} map[string]string
// @Router {{ config.rbac.controller.base_path | default('/api/rbac') }}{{ config.rbac.controller.BulkUpdateRolePermissions.path | default('/roles/:id/permissions/bulk') | replace(':id', '{roleId}') }} [put]
{% endif %}
func (ctrl *RBACController) UpdateRolePermissions(c *fiber.Ctx) error {
    roleID := c.Params("roleId")
    db := utilspkg.GetDB(c).DB

    var role domain.Role
    if err := db.First(&role, roleID).Error; err != nil {
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
            "error": "Role not found",
        })
    }

    var req struct {
        Permissions map[string]bool `json:"permissions"`
    }
    if err := c.BodyParser(&req); err != nil {
        return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
            "error": "Invalid request body",
        })
    }

    for permKey, allow := range req.Permissions {
        if allow && !ctrl.rbacService.IsPermissionAllowedForRole(role.Name, permKey) {
            return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
                "error":   "Invalid permission for " + role.Name + " role",
                "message": "Permission '" + permKey + "' is not allowed for " + role.Name + ".",
            })
        }
    }

    if role.Name == "admin" || role.Name == "moderator" || role.Name == "superadmin" {
        for permKey, allow := range req.Permissions {
            if allow && strings.Contains(permKey, "_own") {
                return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
                    "error":   "Invalid permission for " + role.Name + " role",
                    "message": "Admin roles should not have '_own' permissions.",
                })
            }
        }
    }

    permKeys := make([]string, 0, len(req.Permissions))
    for permKey := range req.Permissions {
        permKeys = append(permKeys, permKey)
    }

    var permissions []domain.Permission
    if err := db.Where("key IN ?", permKeys).Find(&permissions).Error; err != nil {
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
            "error": "Failed to fetch permissions",
        })
    }

    permKeyToID := make(map[string]uint)
    for _, perm := range permissions {
        permKeyToID[perm.Key] = perm.ID
    }

    err := db.Transaction(func(tx *gorm.DB) error {
        var existingRolePerms []domain.RolePermission
        if err := tx.Where("role_id = ?", role.ID).
            Order("permission_id ASC").
            Clauses(clause.Locking{Strength: "UPDATE"}).
            Find(&existingRolePerms).Error; err != nil {
            return err
        }

        existingMap := make(map[uint]*domain.RolePermission)
        for i := range existingRolePerms {
            existingMap[existingRolePerms[i].PermissionID] = &existingRolePerms[i]
        }

        var toCreate []domain.RolePermission
        var idsToUpdate []uint
        var allowValues []bool

        for permKey, allow := range req.Permissions {
            permID, exists := permKeyToID[permKey]
            if !exists {
                continue
            }

            if existing, found := existingMap[permID]; found {
                idsToUpdate = append(idsToUpdate, existing.ID)
                allowValues = append(allowValues, allow)
            } else {
                toCreate = append(toCreate, domain.RolePermission{
                    RoleID:       role.ID,
                    PermissionID: permID,
                    Allow:        allow,
                })
            }
        }

        if len(toCreate) > 0 {
            if err := tx.Create(&toCreate).Error; err != nil {
                return err
            }
        }

        if len(idsToUpdate) > 0 {
            for i, id := range idsToUpdate {
                if err := tx.Model(&domain.RolePermission{}).
                    Where("id = ?", id).
                    Update("allow", allowValues[i]).Error; err != nil {
                    return err
                }
            }
        }

        return nil
    })

    if err != nil {
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
            "error": "Failed to update permissions",
        })
    }

    ctx := context.Background()
    ctrl.rbacService.InvalidateRoleCache(ctx, role.Name)

    return c.JSON(fiber.Map{
        "message": "Permissions updated successfully",
    })
}
{% endif %}

