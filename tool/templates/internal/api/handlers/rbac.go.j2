// @Router {{ config.rbac.controller.base_path | default('/api/rbac') }}{{ config.rbac.controller.GetRole.path | default('/roles/:id') | replace(':id', '{roleId}') }} [get]
{% endif %}
func (ctrl *RBACController) GetRolePermissions(c *fiber.Ctx) error {
    roleID := c.Params("roleId")
    db := utilspkg.GetDB(c).DB

    var role domain.Role
    if err := db.First(&role, roleID).Error; err != nil {
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
            "error": "Role not found",
        })
    }

    var rolePerms []domain.RolePermission
