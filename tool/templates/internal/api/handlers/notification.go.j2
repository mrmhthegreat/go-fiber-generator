// BulkMarkNotificationRead marks multiple notifications as read.
// @Summary  Bulk mark notifications as read
// @Tags     Notifications
// @Accept   json
// @Param    input  body  dtopkg.BulkMarkReadRequest  true  "IDs of notifications"
// @Success  200  {object}  resppkg.SuccessResponse
// @Router   {{ base }}{{ ctrl.get('endpoints', {}).get('bulk_mark_read', {}).get('path', '/bulk-read') }} [{{ ctrl.get('endpoints', {}).get('bulk_mark_read', {}).get('method', 'POST') }}]
func BulkMarkNotificationRead(c *fiber.Ctx) error {
	userID, ok := c.Locals("user_id").(uint)
	if !ok || userID == 0 {
		return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
	}

	var req dtopkg.BulkMarkReadRequest
	if err := c.BodyParser(&req); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_input")
	}

	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}
	notifRepo := utilspkg.GetNotificationRepository(dbConn)
	if notifRepo == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	if err := notifRepo.MarkNotificationsAsReadBulk(req.IDs, userID); err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "failed_to_mark_notifications")
	}
	return c.JSON(resppkg.SuccessResponse{Status: "success"})
}

