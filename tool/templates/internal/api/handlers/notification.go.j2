// GetNotifications returns notifications for the authenticated user.
// @Summary  List notifications
// @Tags     Notifications
// @Produce  json
// @Param    limit   query  int  false  "Page size"    default(20)
// @Param    offset  query  int  false  "Page offset"  default(0)
// @Success  200  {object}  resppkg.NotificationListResponse
// @Router   {{ base }}{{ ctrl.get('endpoints', {}).get('list', {}).get('path', '/list') }} [{{ ctrl.get('endpoints', {}).get('list', {}).get('method', 'GET') }}]
func GetNotifications(c *fiber.Ctx) error {
	// Safe assertion — panics if middleware didn't set user_id
	userID, ok := c.Locals("user_id").(uint)
	if !ok || userID == 0 {
		return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
	}

	limit  := c.QueryInt("limit",  {{ config.notifications.get('repository', {}).get('pagination', {}).get('default_limit', 20) }})
	offset := c.QueryInt("offset", 0)
	if limit > {{ config.notifications.get('repository', {}).get('pagination', {}).get('max_limit', 100) }} {
		limit = {{ config.notifications.get('repository', {}).get('pagination', {}).get('max_limit', 100) }}
	}

	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}
	notifRepo := utilspkg.GetNotificationRepository(dbConn)
	if notifRepo == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	notifications, hasMore, err := notifRepo.GetNotificationsByUserID(userID, limit, offset)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "failed_to_fetch_notifications")
	}

	return c.JSON(resppkg.NotificationListResponse{
		Notifications: resppkg.ConvertToNotificationResponses(notifications),
		HasMore:       hasMore,
	})
}
{% endif %}
{% if has_is_read and ctrl.get('endpoints', {}).get('mark_as_read', {}).get('enabled', true) %}

// MarkNotificationRead marks a specific notification as read.
// @Summary  Mark notification as read
// @Tags     Notifications
// @Param    id  path  int  true  "Notification ID"
// @Success  200  {object}  resppkg.SuccessResponse
// @Router   {{ base }}{{ ctrl.get('endpoints', {}).get('mark_as_read', {}).get('path', '/:id/read') }} [{{ ctrl.get('endpoints', {}).get('mark_as_read', {}).get('method', 'POST') }}]
func MarkNotificationRead(c *fiber.Ctx) error {
	userID, ok := c.Locals("user_id").(uint)
	if !ok || userID == 0 {
		return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
	}
	id, err := strconv.Atoi(c.Params("id"))
	if err != nil || id <= 0 {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_notification_id")
	}

	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}
	notifRepo := utilspkg.GetNotificationRepository(dbConn)
	if notifRepo == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	if err := notifRepo.MarkNotificationAsRead(uint(id), userID); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, err.Error())
	}
	return c.JSON(resppkg.SuccessResponse{Status: "success"})
}
{% endif %}
