// ForgotPassword handles forgot password request.
// @Summary Forgot password
// @Description Send OTP for password reset
// @Tags Authentication
// @Accept json
// @Produce json
// @Param input body dtopkg.ForgotPasswordInput true "User identifier"
// @Success 200 {object} resppkg.SuccessResponse "Reset code sent"
// @Failure 400 {object} resppkg.ErrorResponse "Invalid input"
// @Failure 500 {object} resppkg.ErrorResponse "Internal server error"
// @Router /api/auth/forgot-password [post]
func (h *AuthHandler) ForgotPassword(c *fiber.Ctx) error {
	var input dtopkg.ForgotPasswordInput
	if err := c.BodyParser(&input); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_json")
	}
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	{{ repo_var }} := dbConn.Auth
	if {{ repo_var }} == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
	}

	{% set forgot_fields = ['"email"'] %}
	{% if auth.email_password.forgot_password.identifier_field == 'email' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Email, {{ forgot_fields | join(', ') }})
	{% elif auth.email_password.forgot_password.identifier_field == 'username' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Username, {{ forgot_fields | join(', ') }})
	{% elif auth.email_password.forgot_password.identifier_field == 'email_or_username' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Identifier, {{ forgot_fields | join(', ') }})
	{% endif %}


	if err != nil {
		// Don't reveal if user exists
		return c.JSON(resppkg.SuccessResponse{
			Message: "if_exists_reset_code_sent",
		})
	}

	otp := authpkg.GenerateOTP()
	authpkg.StoreOTP(user.Email, otp)

	go func() {
		err := emailpkg.SendEmail(user.Email, "Password Reset", "{{ auth.email_password.forgot_password.email_template }}", fiber.Map{
			"code": otp,
		})
		if err != nil {
			log.Printf("Error sending password reset email: %v", err)
		}
	}()

	return c.JSON(resppkg.SuccessResponse{
		Message: "if_exists_reset_code_sent",
	})
}

// ResetPassword handles password reset with OTP.
// @Summary Reset password
// @Description Reset user password with OTP and new password
// @Tags Authentication
// @Accept json
// @Produce json
// @Param input body dtopkg.ResetPasswordInput true "OTP and new password"
// @Success 200 {object} resppkg.SuccessResponse "Password reset successfully"
// @Failure 400 {object} resppkg.ErrorResponse "Invalid OTP or weak password"
// @Failure 500 {object} resppkg.ErrorResponse "Internal server error"
// @Router /api/auth/reset-password [post]
func (h *AuthHandler) ResetPassword(c *fiber.Ctx) error {
	var input dtopkg.ResetPasswordInput
	if err := c.BodyParser(&input); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_json")
	}
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	{{ repo_var }} := dbConn.Auth
	if {{ repo_var }} == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
	}

	// Get user
	{% if auth.email_password.forgot_password.identifier_field == 'email' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Email, "id", "email")
	{% elif auth.email_password.forgot_password.identifier_field == 'username' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Username, "id", "email")
	{% elif auth.email_password.forgot_password.identifier_field == 'email_or_username' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Identifier, "id", "email")
	{% endif %}
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_credentials")
	}

	if !authpkg.VerifyOTP(user.Email, input.OTP) {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_or_expired_otp")
	}

{% if auth.email_password.password_validation %}
	if err := authpkg.ValidatePassword(input.NewPassword); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "weak_password", err.Error())
	}
{% endif %}

	hashedPassword, err := authpkg.HashPassword(input.NewPassword)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "password_hash_failed")
	}
	if err := {{ repo_var }}.UpdateUserPassword(user.ID, hashedPassword); err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "password_update_failed")
	}
	return c.JSON(resppkg.SuccessResponse{
		Message: "password_reset_successfully",
	})
}
{% endif %}

{% if auth.email_password.change_password.enabled %}
// ChangePassword handles the change password request for a logged-in user.
// @Summary Change password
// @Description Change password for authenticated user
// @Tags Authentication
// @Accept json
// @Produce json
// @Security FullAuth
// @Param input body dtopkg.ChangePasswordInput true "Password change details"
// @Success 200 {object} resppkg.SuccessResponse "Password changed successfully"
// @Failure 400 {object} resppkg.ErrorResponse "Invalid input or weak password"
// @Failure 401 {object} resppkg.ErrorResponse "Unauthorized or incorrect old password"
// @Failure 500 {object} resppkg.ErrorResponse "Internal server error"
// @Router /api/user/change-password [post]
func (h *AuthHandler) ChangePassword(c *fiber.Ctx) error {
	var input dtopkg.ChangePasswordInput
	if err := c.BodyParser(&input); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_input")
	}

	validator := validator.New()
	if err := validator.Struct(&input); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "validation_failed", err.Error())
	}

	{% if auth.email_password.password_validation %}
		if err := authpkg.ValidatePassword(input.NewPassword); err != nil {
			return errorspkg.SendError(c, fiber.StatusBadRequest, "weak_password", err.Error())
		}
	{% endif %}

	userID := c.Locals('user_id'). (uint)

	if userID == 0 {
		return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
	}

	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	{{ repo_var }} := dbConn.Auth
	if {{ repo_var }} == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
	}

{% if auth.email_password.change_password.require_old_password %}
	userData, err := {{ repo_var }}.GetByID(userID, "id", "password")
{% else %}
	userData, err := {{ repo_var }}.GetByID(userID, "id")
{% endif %}
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusNotFound, "user_not_found")
	}

{% if auth.email_password.change_password.require_old_password %}
	if userData.Password == nil || !authpkg.CheckPasswordHash(input.OldPassword, *userData.Password) {
		return errorspkg.SendError(c, fiber.StatusUnauthorized, "incorrect_old_password")
	}
{% endif %}

	hashedPassword, err := authpkg.HashPassword(input.NewPassword)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "password_hash_failed")
	}

	if err := {{ repo_var }}.UpdateUserPassword(userData.ID, hashedPassword); err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "password_update_failed")
	}

	return c.JSON(resppkg.SuccessResponse{
		Message: "password_changed_successfully",
	})
}
{% endif %}

{% if auth.refresh_token.enabled %}
// RefreshToken handles token refresh.
// @Summary Refresh access token
// @Description Get new access token using refresh token
// @Tags Authentication
// @Accept json
// @Produce json
// @Param input body dtopkg.RefreshTokenInput true "Refresh token"
// @Success 200 {object} dtopkg.AuthUserResponse "Token refreshed"
// @Failure 400 {object} resppkg.ErrorResponse "Invalid token"
// @Failure 500 {object} resppkg.ErrorResponse "Internal server error"
// @Router /api/auth/refresh-token [post]
func (h *AuthHandler) RefreshToken(c *fiber.Ctx) error {
	var input dtopkg.RefreshTokenInput
	if err := c.BodyParser(&input); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_json")
	}

	claims, err := jwtpkg.ValidateRefreshToken(input.RefreshToken)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusUnauthorized, "invalid_refresh_token")
	}

	jwtPayload := jwtpkg.TokenPayload{
		UserID: userID,
	}
{% set use_email = config.authentication.email_password.enabled or config.authentication.social_auth.google.enabled or config.authentication.social_auth.facebook.enabled %}
{% if use_email %}
	if val, ok := claims["email"]; ok {
		if str, ok := val.(string); ok {
			jwtPayload.Email = str
		}
	}
{% endif %}
{% if config.rbac.enabled %}
	if val, ok := claims["role"]; ok {
		if str, ok := val.(string); ok {
			jwtPayload.Role = str
		}
	}
{% endif %}
{% if config.authentication.email_verification.enabled %}
	if val, ok := claims["verified"]; ok {
		if b, ok := val.(bool); ok {
			jwtPayload.Verified = b
		}
	}
{% endif %}
{% for c in config.authentication.jwt.claims %}
{% if c.name not in ['user_id', 'email', 'role', 'verified'] %}
{% set field_name = c.name | replace('_', ' ') | title | replace(' ', '') %}
	if val, ok := claims["{{ c.name }}"]; ok {
{% if c.type == 'uint' or c.type == 'int' %}
		if num, ok := val.(float64); ok {
			jwtPayload.{{ field_name }} = {{ c.type }}(num)
		}
{% elif c.type == 'bool' %}
		if b, ok := val.(bool); ok {
			jwtPayload.{{ field_name }} = b
		}
{% else %}
		if str, ok := val.({{ c.type }}); ok {
			jwtPayload.{{ field_name }} = str
		}
{% endif %}
	}
{% endif %}
{% endfor %}

	// Generate new tokens
	token, err := jwtpkg.GenerateJWT(jwtPayload)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "token_generation_failed")
	}

{% if auth.refresh_token.rotate_on_refresh %}
	newRefreshToken, err := jwtpkg.GenerateRefreshJWT(jwtPayload)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "token_generation_failed")
	}
{% endif %}

	return c.JSON(dtopkg.AuthUserResponse{
		Token: token,
{% if auth.refresh_token.rotate_on_refresh %}
		RefreshToken: newRefreshToken,
{% else %}
		RefreshToken: input.RefreshToken,
{% endif %}
	})
}
{% endif %}

{% if auth.logout.enabled %}
// Logout handles user logout.
// @Summary Logout
// @Description Logout user (client should clear tokens)
// @Tags Authentication
// @Accept json
// @Produce json
// @Security FullAuth
// @Success 200 {object} resppkg.SuccessResponse "Logged out successfully"
// @Router /api/auth/logout [post]
func (h *AuthHandler) Logout(c *fiber.Ctx) error {
	// In stateless JWT, logout is handled on client side
	// If using token blacklist/database storage, invalidate token here
	return c.JSON(resppkg.SuccessResponse{
		Message: "logged_out_successfully",
	})
}
