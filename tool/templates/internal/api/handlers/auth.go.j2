// SearchUsers searches for users by dynamic fields
// @Summary Search users
// @Description Search for users with dynamic filtering, pagination and field selection
// @Tags Authentication
// @Produce json
// @Param q query string false "Search query"
// @Param limit query int false "Limit" default(20)
// @Param offset query int false "Offset" default(0)
// @Param search_fields query string false "Comma separated search fields (id,email,username,fullname,fcm_token)"
// @Param return_fields query string false "Comma separated return fields"
// @Success 200 {object} map[string]interface{}
// @Router /api/auth/users/search [get]
func (h *AuthHandler) SearchUsers(c *fiber.Ctx) error {
	query := c.Query("q")
	limit, _ := strconv.Atoi(c.Query("limit", "20"))
	offset, _ := strconv.Atoi(c.Query("offset", "0"))
	searchFieldsRaw := c.Query("search_fields")
	returnFieldsRaw := c.Query("return_fields")

	var searchFields []string
	if searchFieldsRaw != "" {
		searchFields = strings.Split(searchFieldsRaw, ",")
	} else {
		// Default search fields
		searchFields = []string{"id"}
		{% if _uses_email %}
		searchFields = append(searchFields, "email")
		{% endif %}
		{% if _uses_username %}
		searchFields = append(searchFields, "username")
		{% endif %}
		{% if _name_field %}
		searchFields = append(searchFields, "{{ _name_field }}")
		{% endif %}
		
		{% if _uses_fcm %}
		searchFields = append(searchFields, "fcm_token")
		{% endif %}
	}

	var returnFields []string
	if returnFieldsRaw != "" {
		returnFields = strings.Split(returnFieldsRaw, ",")
	}

	repo := utilspkg.GetRepo(c).Auth
	users, hasMore, err := repo.SearchUsers(repository.UserSearchOptions{
		Query:        query,
		SearchFields: searchFields,
		ReturnFields: returnFields,
		Limit:        limit,
		Offset:       offset,
	})

	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "search_failed")
	}

	return c.JSON(fiber.Map{
		"users":    users,
		"has_more": hasMore,
	})
}