// GoogleLogin handles Google OAuth login (for mobile/SPA - accepts ID token)
// @Summary Google OAuth login
// @Description Login with Google ID token
// @Tags Social Authentication
// @Accept json
// @Produce json
// @Param input body dtopkg.GoogleLoginInput true "Google ID token"
// @Success 200 {object} dtopkg.AuthUserResponse "Login successful"
// @Failure 400 {object} resppkg.ErrorResponse "Invalid token"
// @Failure 500 {object} resppkg.ErrorResponse "Internal server error"
// @Router /api/auth/google [post]
func GoogleLogin(c *fiber.Ctx) error {
	var input dtopkg.GoogleLoginInput
	if err := c.BodyParser(&input); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_json")
	}

	// Verify Google ID token
	googleUser, err := utilspkg.VerifyGoogleIDToken(input.Token)
	if err != nil {
		log.Printf("Error verifying Google token: %v", err)
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_google_token")
	}

	{{ repo_var }} := utilspkg.Get{{ config.project.repository_name }}(c)
	if {{ repo_var }} == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
	}

	// Try to find existing user by Google ID
	user, err := {{ repo_var }}.{{ auth.social_auth.google.repository_method }}(googleUser.ID)
	
	if err != nil {
		// User doesn't exist - create new user
{% set field_mapping = auth.social_auth.google.field_mapping %}
		newUser := domain.{{ config.project.user_model_name }}{
{% for mapping in field_mapping %}
{% if mapping.source == 'email' %}
			{{ mapping.target }}: googleUser.Email,
{% elif mapping.source == 'name' %}
			{{ mapping.target }}: googleUser.Name,
{% elif mapping.source == 'picture' %}
			{{ mapping.target }}: googleUser.Picture,
{% elif mapping.source == 'id' %}
			{{ mapping.target }}: &googleUser.ID,
{% endif %}
{% endfor %}
			AuthProvider: "google",
{% if auth.email_password.email_verification.enabled %}
			{{ auth.email_password.email_verification.model_field }}: true, // Google emails are pre-verified
{% endif %}
{% if config.rbac.enabled %}
			{{ config.rbac.model_field }}: "{{ config.rbac.default_role | default('user') }}",
{% endif %}
		}

		user, err = {{ repo_var }}.CreateUser(&newUser)
		if err != nil {
			log.Printf("Error creating Google user: %v", err)
			return errorspkg.SendError(c, fiber.StatusInternalServerError, "user_creation_failed")
		}
	}

	// Generate JWT tokens
	token, err := jwtpkg.GenerateJWT(user.ID, user.Fullname, user.Email, true)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "token_generation_failed")
	}

{% if auth.refresh_token.enabled %}
	refreshToken, err := jwtpkg.GenerateRefreshJWT(user.ID, user.Fullname, user.Email, true)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "token_generation_failed")
	}
{% endif %}

	return c.JSON(dtopkg.AuthUserResponse{
		Token: token,
{% if auth.refresh_token.enabled %}
		RefreshToken: refreshToken,
{% endif %}
		User: &dtopkg.dtopkg.UserResponse{
			ID:       user.ID,
			Email:    user.Email,
			Fullname: user.Fullname,
		},
	})
}

// GoogleLoginWeb initiates Google OAuth flow (for web)
// @Summary Initiate Google OAuth (Web)
// @Description Redirects to Google OAuth consent screen
// @Tags Social Authentication
// @Router /auth/google/login [get]
func GoogleLoginWeb(c *fiber.Ctx) error {
	// Generate a random state and store it in session to prevent CSRF
	state := utilspkg.GenerateRandomState()
{% if auth.session.enabled %}
	sess, _ := utilspkg.GetSession(c)
	sess.Set("oauth_state", state)
	sess.Save()
{% endif %}
	url := googleOauthConfig.AuthCodeURL(state, oauth2.AccessTypeOffline)
	return c.Redirect(url)
}

// GoogleCallbackWeb handles Google OAuth callback (for web)
// @Summary Google OAuth callback (Web)
// @Description Handles Google OAuth redirect and creates session
// @Tags Social Authentication
// @Router /auth/google/callback [get]
func GoogleCallbackWeb(c *fiber.Ctx) error {
	code := c.Query("code")
	state := c.Query("state")

	// Verify state to prevent CSRF
{% if auth.session.enabled %}
	sess, _ := utilspkg.GetSession(c)
	storedState, _ := sess.Get("oauth_state").(string)
	if state == "" || state != storedState {
		return c.Redirect("/login?error=invalid_state")
	}
	sess.Set("oauth_state", nil)
	sess.Save()
{% endif %}
	
	// Exchange code for token
	token, err := googleOauthConfig.Exchange(c.Context(), code)
	if err != nil {
		log.Printf("Error exchanging code: %v", err)
		return c.Redirect("/login?error=oauth_failed")
	}

	// Get user info from Google
	client := googleOauthConfig.Client(c.Context(), token)
	resp, err := client.Get("https://www.googleapis.com/oauth2/v2/userinfo")
	if err != nil {
		log.Printf("Error getting user info: %v", err)
		return c.Redirect("/login?error=oauth_failed")
	}
	defer resp.Body.Close()

	var googleUser struct {
		ID      string `json:"id"`
		Email   string `json:"email"`
		Name    string `json:"name"`
		Picture string `json:"picture"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&googleUser); err != nil {
		log.Printf("Error decoding user info: %v", err)
		return c.Redirect("/login?error=oauth_failed")
	}

	{{ repo_var }} := utilspkg.Get{{ config.project.repository_name }}(c)
	if {{ repo_var }} == nil {
		return c.Redirect("/login?error=server_error")
	}

	// Find or create user
	user, err := {{ repo_var }}.{{ auth.social_auth.google.repository_method }}(googleUser.ID)
	if err != nil {
		// Create new user
{% set field_mapping = auth.social_auth.google.field_mapping %}
		newUser := domain.{{ config.project.user_model_name }}{
{% for mapping in field_mapping %}
{% if mapping.source == 'email' %}
			{{ mapping.target }}: googleUser.Email,
{% elif mapping.source == 'name' %}
			{{ mapping.target }}: googleUser.Name,
{% elif mapping.source == 'picture' %}
			{{ mapping.target }}: googleUser.Picture,
{% elif mapping.source == 'id' %}
			{{ mapping.target }}: &googleUser.ID,
{% endif %}
{% endfor %}
			AuthProvider: "google",
{% if auth.email_password.email_verification.enabled %}
			{{ auth.email_password.email_verification.model_field }}: true,
{% endif %}
{% if config.rbac.enabled %}
			{{ config.rbac.model_field }}: "{{ config.rbac.default_role }}",
{% endif %}
		}

		user, err = {{ repo_var }}.CreateUser(&newUser)
		if err != nil {
			log.Printf("Error creating user: %v", err)
			return c.Redirect("/login?error=user_creation_failed")
		}
	}

	// Set session for web flow
{% if auth.session.enabled %}
	sess, err := utilspkg.GetSession(c)
	if err != nil {
		return c.Redirect("/login?error=session_error")
	}
	sess.Destroy()
	sess.Set("authenticated", true)
	sess.Set("user_id", user.ID)
	sess.Set("email", user.Email)
{% if auth.email_password.email_verification.enabled %}
	sess.Set("is_verified", true) // Google accounts are pre-verified
{% endif %}
{% if config.rbac.enabled %}
	sess.Set("role", user.{{ config.rbac.model_field }})
{% endif %}
	sess.Save()
{% endif %}
	return c.Redirect("{{ auth.social_auth.google.success_redirect }}")
}
{% endif %}

