{% if auth.social_auth.google.endpoints.api.enabled %}
// GoogleLogin handles Google OAuth login (for mobile/SPA - accepts ID token)
// @Summary Google OAuth login
// @Description Login with Google ID token
// @Tags Social Authentication
// @Accept json
// @Produce json
// @Param input body dtopkg.GoogleLoginInput true "Google ID token"
// @Success 200 {object} dtopkg.AuthUserResponse "Login successful"
// @Failure 400 {object} resppkg.ErrorResponse "Invalid token"
// @Failure 500 {object} resppkg.ErrorResponse "Internal server error"
// @Router {{ auth.social_auth.google.endpoints.api.path }} [{{ auth.social_auth.google.endpoints.api.method }}]
func (h *SocialAuthHandler) GoogleLogin(c *fiber.Ctx) error {
	var input dtopkg.GoogleLoginInput
	if err := c.BodyParser(&input); err != nil {
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_json")
	}

	// Verify Google ID token
	googleUser, err := utilspkg.VerifyGoogleIDToken(input.Token)
	if err != nil {
		log.Printf("Error verifying Google token: %v", err)
		return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_google_token")
	}
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	{{ repo_var }} := dbConn.Auth

	if {{ repo_var }} == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
	}

	{% set google_jwt_fields = ['"id"', '"email"', '"auth_provider"'] %}
	{% set _ = google_jwt_fields.append('"' ~ config.authentication.identifier.name_field | lower ~ '"') if config.authentication.identifier.name_field else google_jwt_fields.append('"fullname"') %}
	{% for c in config.authentication.jwt.claims %}
		{% if c.name != 'user_id' and c.name != 'verified' %}
			{% set _ = google_jwt_fields.append('"' ~ c.name ~ '"') %}
		{% endif %}
	{% endfor %}
	// Try to find existing user by Google ID
	user, err := {{ repo_var }}.{{ auth.social_auth.google.repository_method }}(googleUser.ID, {{ google_jwt_fields | join(', ') }})
	
	if err != nil {
		// User doesn't exist - create new user
		{% set field_mapping = auth.social_auth.google.field_mapping %}
		newUser := domain.{{ config.project.user_model_name }}{
			GoogleID:     &googleUser.ID,
			Email:        googleUser.Email,
{% for mapping in field_mapping %}
{% if mapping.source == 'name' %}
			{{ mapping.target }}: googleUser.Name,
{% elif mapping.source == 'picture' %}
			{{ mapping.target }}: googleUser.Picture,
{% endif %}
{% endfor %}
			AuthProvider: "google",
{% if auth.email_verification.enabled %}
			Verified: true, // Google emails are pre-verified
{% endif %}
{% if config.rbac.enabled %}
			Role: "{{ config.rbac.default_role | default('user') }}",
{% endif %}
		}

		user, err = {{ repo_var }}.CreateUser(&newUser)
		if err != nil {
			log.Printf("Error creating Google user: %v", err)
			return errorspkg.SendError(c, fiber.StatusInternalServerError, "user_creation_failed")
		}
	}

	// Generate JWT tokens
	jwtPayload := jwtpkg.TokenPayload{
		UserID: user.ID,
{% set use_email = config.authentication.email_password.enabled or config.authentication.social_auth.google.enabled or config.authentication.social_auth.facebook.enabled %}
{% if use_email %}
		Email:  user.Email,
{% endif %}
{% if config.rbac.enabled %}
		Role:   user.Role,
{% endif %}
{% if auth.email_verification.enabled %}
		Verified: true, // Social auth emails are typically verified
{% endif %}
{% for c in config.authentication.jwt.claims %}
{% if c.name not in ['user_id', 'email', 'role', 'verified'] %}
{% set field_name = c.name | replace('_', ' ') | title | replace(' ', '') %}
		{{ field_name }}: user.{{ field_name }},
{% endif %}
{% endfor %}
	}

	token, err := jwtpkg.GenerateJWT(jwtPayload)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "token_generation_failed")
	}

{% if auth.refresh_token.enabled %}
	refreshToken, err := jwtpkg.GenerateRefreshJWT(jwtPayload)
	if err != nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "token_generation_failed")
	}
{% endif %}

	return c.JSON(dtopkg.AuthUserResponse{
		Token: token,
{% if auth.refresh_token.enabled %}
		RefreshToken: refreshToken,
{% endif %}
		
	})
}
{% endif %}
{% if auth.social_auth.google.endpoints.web.enabled %}
// GoogleLoginWeb initiates Google OAuth flow (for web)
// @Summary Initiate Google OAuth (Web)
// @Description Redirects to Google OAuth consent screen
// @Tags Social Authentication
// @Router {{ auth.social_auth.google.endpoints.web.login_path }} [get]
func (h *SocialAuthHandler) GoogleLoginWeb(c *fiber.Ctx) error {
	// Generate a random state and store it in session to prevent CSRF
	state := utilspkg.GenerateRandomState()
{% if auth.session.enabled %}
	sess, _ := authpkg.GetSession(c)
	sess.Set("oauth_state", state)
	sess.Save()
{% endif %}
	url := googleOauthConfig.AuthCodeURL(state, oauth2.AccessTypeOffline)
	return c.Redirect(url)
}
// GoogleCallbackWeb handles Google OAuth callback (for web)
// @Summary Google OAuth callback (Web)
// @Description Handles Google OAuth redirect and creates session
// @Tags Social Authentication
// @Router {{ auth.social_auth.google.endpoints.web.callback_path }} [get]
func (h *SocialAuthHandler) GoogleCallbackWeb(c *fiber.Ctx) error {
	code := c.Query("code")
	state := c.Query("state")

	// Verify state to prevent CSRF
{% if auth.session.enabled %}
	sess, _ := authpkg.GetSession(c)
	storedState, _ := sess.Get("oauth_state").(string)
	if state == "" || state != storedState {
		return c.Redirect("/login?error=invalid_state")
	}
	sess.Set("oauth_state", nil)
	sess.Save()
{% endif %}
	
	// Exchange code for token
	token, err := googleOauthConfig.Exchange(c.Context(), code)
	if err != nil {
		log.Printf("Error exchanging code: %v", err)
		return c.Redirect("/login?error=oauth_failed")
	}

	// Get user info from Google
	client := googleOauthConfig.Client(c.Context(), token)
	resp, err := client.Get("https://www.googleapis.com/oauth2/v2/userinfo")
	if err != nil {
		log.Printf("Error getting user info: %v", err)
		return c.Redirect("/login?error=oauth_failed")
	}
	defer resp.Body.Close()

	var googleUser struct {
		ID      string `json:"id"`
		Email   string `json:"email"`
		Name    string `json:"name"`
		Picture string `json:"picture"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&googleUser); err != nil {
		log.Printf("Error decoding user info: %v", err)
		return c.Redirect("/login?error=oauth_failed")
	}
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return errorspkg.SendError(c, fiber.StatusInternalServerError, "server_error")
	}

	{{ repo_var }} := dbConn.Auth
	if {{ repo_var }} == nil {
		return c.Redirect("/login?error=server_error")
	}

	{% set google_sess_fields = ['"id"', '"email"', '"auth_provider"'] %}
	{% set _ = google_sess_fields.append('"' ~ config.authentication.identifier.name_field | lower ~ '"') if config.authentication.identifier.name_field else google_sess_fields.append('"fullname"') %}
	{% if config.rbac.enabled %}
		{% set _ = google_sess_fields.append('"role"') %}
	{% endif %}
	{% if auth.session.claims %}
		{% for claim in auth.session.claims %}
			{% if claim.name not in ['user_id', 'role', 'is_verified', 'authenticated', 'exp', 'iat', 'type', 'verified'] %}
				{% set _ = google_sess_fields.append('"' ~ claim.name ~ '"') %}
			{% endif %}
		{% endfor %}
	{% endif %}
	// Find or create user
	user, err := {{ repo_var }}.{{ auth.social_auth.google.repository_method }}(googleUser.ID, {{ google_sess_fields | join(', ') }})
	if err != nil {
		{% set field_mapping = auth.social_auth.google.field_mapping %}
		newUser := domain.{{ config.project.user_model_name }}{
			GoogleID:     &googleUser.ID,
			Email:        googleUser.Email,
{% for mapping in field_mapping %}
{% if mapping.source == 'name' %}
			{{ mapping.target }}: googleUser.Name,
{% elif mapping.source == 'picture' %}
			{{ mapping.target }}: googleUser.Picture,
{% endif %}
{% endfor %}
			AuthProvider: "google",
{% if auth.email_verification.enabled %}
			Verified: true,
{% endif %}
{% if config.rbac.enabled %}
			Role: "{{ config.rbac.default_role }}",
{% endif %}
		}

		user, err = {{ repo_var }}.CreateUser(&newUser)
		if err != nil {
			log.Printf("Error creating user: %v", err)
			return c.Redirect("/login?error=user_creation_failed")
		}
	}

	// Set session for web flow
{% if auth.session.enabled %}
	sess, err := authpkg.GetSession(c)
	if err != nil {
		return c.Redirect("/login?error=session_error")
	}
	sess.Destroy()
	sess.Set("authenticated", true)
	sess.Set("user_id", user.ID)
{% if auth.email_verification.enabled %}
	sess.Set("is_verified", true) // Google accounts are pre-verified
{% endif %}
{% if config.rbac.enabled %}
	sess.Set("role", user.Role)
{% endif %}
{% set use_email = config.authentication.email_password.enabled or config.authentication.social_auth.google.enabled or config.authentication.social_auth.facebook.enabled %}
{% if use_email %}
	sess.Set("email", user.Email)
{% endif %}
{% if auth.session.claims %}
{% for claim in auth.session.claims %}
{% if claim.name not in ['user_id', 'exp', 'iat', 'type', 'role', 'verified', 'is_verified', 'email'] %}
{% set field_name = claim.name | replace('_', ' ') | title | replace(' ', '') %}
	sess.Set("{{ claim.name }}", user.{{ field_name }})
{% endif %}
{% endfor %}
{% endif %}
	sess.Save()
{% endif %}
	return c.Redirect("{{ auth.social_auth.google.success_redirect }}")
}
{% endif %}
{% endif %}

