{# ────────────────────────────────────────────────────────────── #}
{# Helper: Get repository from context for API controllers         #}
{# ────────────────────────────────────────────────────────────── #}
{% macro getRepo(modelName) %}
    dbConn := utilspkg.GetDB(c)
    if dbConn == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }
    
    repo := utilspkg.Get{{ modelName }}Repository(dbConn)
    if repo == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }
{% endmacro %}

{# ── parse_param macro ──────────────────────────────────────────────── #}
{# Emits the Go code to read one param from the right source            #}
{% macro parse_param(p) %}{% if p.source == 'claim' %}
    {{ p.var_name }}, ok := c.Locals("user_id").({{ p.go_type }})
    if !ok {
        return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
    }
{% elif p.source == 'path' %}{% if p.go_type in ('uint', 'int', 'int64') %}
    {{ p.var_name }}Raw, err := c.ParamsInt("{{ p.name }}")
    if err != nil || {{ p.var_name }}Raw <= 0 {
        return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_{{ p.name }}")
    }
    {{ p.var_name }} := {{ p.go_type }}({{ p.var_name }}Raw)
{% else %}
    {{ p.var_name }} := c.Params("{{ p.name }}")
    if {{ p.var_name }} == "" {
        return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_{{ p.name }}")
    }
{% endif %}{% elif p.source == 'query' %}{% if p.go_type in ('uint','int','int64') %}
    {{ p.var_name }} := {{ p.go_type }}(c.QueryInt("{{ p.name }}", 0))
{% else %}
    {{ p.var_name }} := c.Query("{{ p.name }}", "")
{% endif %}{% endif %}{% endmacro %}

// {{ ctrl.model }}Controller handles API requests for {{ ctrl.model }}
type {{ ctrl.model }}Controller struct {
}

// New{{ ctrl.model }}Controller creates a new {{ ctrl.model }}Controller
func New{{ ctrl.model }}Controller() *{{ ctrl.model }}Controller {
    return &{{ ctrl.model }}Controller{}
}

// Register registers all routes for {{ ctrl.model }}
func (h *{{ ctrl.model }}Controller) Register(router fiber.Router) {
{% for ep in ctrl.endpoints %}
{% set rp = ep.path | replace(ctrl.base_path, '') %}
    router.{{ ep.method }}("{{ rp if rp else '/' }}", h.{{ ep.func_name }})
{% endfor %}
{% for ep in ctrl.getter_endpoints %}
    router.{{ ep.method }}("{{ ep.path | replace(ctrl.base_path, '') }}", h.{{ ep.func_name }})
{% endfor %}
}

// ============================================================================
// CRUD Endpoints
// ============================================================================

{% for ep in ctrl.endpoints %}
{# ───────────────────── CREATE ───────────────────── #}
{% if ep.type == 'create' %}
// {{ ep.func_name }} creates a new {{ ep.model | lower }}.
// @Summary Create {{ ep.model | lower }}
// @Tags {{ ep.tag }}
// @Accept {% if ep.has_file_uploads %}multipart/form-data{% else %}json{% endif %}
// @Produce json
{% for mw in ep.middleware %}
// @Security {{ mw | capitalize }}Auth
{% endfor %}
{% if ep.has_file_uploads %}
{% for f in ep.file_uploads %}
// @Param {{ f.form_field }} formData file true "{{ f.field }} file"
{% endfor %}
// @Param input formData dtopkg.{{ ep.dto_name }} true "{{ ep.model }} data"
{% else %}
// @Param input body dtopkg.{{ ep.dto_name }} true "{{ ep.model }} data"
{% endif %}
// @Success 201 {object} resppkg.{{ ep.resppkg.struct }}
// @Failure 400 {object} resppkg.ErrorResponse
// @Failure 401 {object} resppkg.ErrorResponse
// @Failure 500 {object} resppkg.ErrorResponse
// @Router {{ ep.path }} [{{ ep.method | lower }}]
func (h *{{ ep.model }}Controller) {{ ep.func_name }}(c *fiber.Ctx) error {
{% if ep.needs_claim %}
    userID, ok := c.Locals("user_id").(uint)
    if !ok {
        return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
    }
{% endif %}

    // Get repository from context
    dbConn := utilspkg.GetDB(c)
    if dbConn == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }
    repo := utilspkg.Get{{ ep.model }}Repository(dbConn)
    if repo == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }

    var input dtopkg.{{ ep.dto_name }}
    if err := c.BodyParser(&input); err != nil {
        return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_input", err.Error())
    }
{% if ep.validation.use_validator %}
    if err := validator.New().Struct(&input); err != nil {
        return errorspkg.SendError(c, fiber.StatusBadRequest, "validation_failed", err.Error())
    }
{% endif %}

{% for f in ep.file_uploads %}
    var {{ f.field | lower }}URL string
    if fh, ferr := c.FormFile("{{ f.form_field }}"); ferr == nil {
        if fh.Size > int64({{ f.max_size_mb }}*1024*1024) {
            return errorspkg.SendError(c, fiber.StatusBadRequest, "file_too_large", "{{ f.field }} max {{ f.max_size_mb }}MB")
        }
{% if f.allowed_types %}
        ct := fh.Header.Get("Content-Type")
        allowed := false
{% for at in f.allowed_types %}
        if strings.HasPrefix(ct, "{{ at }}") { allowed = true }
{% endfor %}
        if !allowed {
            return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_file_type")
        }
{% endif %}
        saved, serr := storagepkg.SaveUploadedFile(fh, "{{ f.storage_path }}")
        if serr != nil {
            return errorspkg.SendError(c, fiber.StatusInternalServerError, "file_upload_failed")
        }
        {{ f.field | lower }}URL = saved


    }
    {% if f.required %}
    else {
        return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "{{ f.field | lower }}_required"})
    }
{% endif %}
{% endfor %}

    {{ ep.model | lower }} := models.{{ ep.model }}{}
    input.ApplyTo(&{{ ep.model | lower }})
{% if ep.ownership.enabled %}
    {{ ep.model | lower }}.{{ ep.ownership.go_field }} = userID
{% endif %}
{% for af in ep.auto_fields %}
{% if af.generator == 'uuid' %}
    {{ ep.model | lower }}.{{ af.name | replace('_',' ') | title | replace(' ','') }} = uuid.New().String()
{% elif af.source == 'context' and not ep.ownership.enabled %}
    {{ ep.model | lower }}.{{ af.name | replace('_',' ') | title | replace(' ','') }} = userID
{% endif %}
{% endfor %}
{% for f in ep.file_uploads %}
    {{ ep.model | lower }}.{{ f.field }} = {{ f.field | lower }}URL
{% endfor %}

    if err := repo.Create(&{{ ep.model | lower }}); err != nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "create_failed", err.Error())
    }

{% if ep.resppkg.converter %}
    return c.Status(fiber.StatusCreated).JSON(resppkg.{{ ep.resppkg.converter }}(&{{ ep.model | lower }}))
{% else %}
    return c.Status(fiber.StatusCreated).JSON(resppkg.SuccessResponse{Message: "{{ ep.model }} created"})
{% endif %}
}

{# ───────────────────── GET ───────────────────── #}
{% elif ep.type == 'get' %}
// {{ ep.func_name }} retrieves a {{ ep.model | lower }}.
// @Summary Get {{ ep.model | lower }}
// @Tags {{ ep.tag }}
// @Produce json
{% for mw in ep.middleware %}
// @Security {{ mw | capitalize }}Auth
{% endfor %}
{% for p in ep.params %}
{% if p.source == 'path' %}
// @Param {{ p.name }} path {{ p.swagger_type }} true "{{ p.name }}"
{% elif p.source == 'query' %}
// @Param {{ p.name }} query {{ p.swagger_type }} false "{{ p.name }}"
{% endif %}
{% endfor %}
// @Success 200 {object} resppkg.{{ ep.resppkg.struct }}
// @Failure 400 {object} resppkg.ErrorResponse
// @Failure 404 {object} resppkg.ErrorResponse
// @Router {{ ep.path }} [get]
func (h *{{ ep.model }}Controller) {{ ep.func_name }}(c *fiber.Ctx) error {
{% for p in ep.params %}
{{ parse_param(p) }}
{% endfor %}

    dbConn := utilspkg.GetDB(c)
    if dbConn == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }
    repo := utilspkg.Get{{ ep.model }}Repository(dbConn)
    if repo == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }

    {{ ep.model | lower }}, err := repo.{{ ep.repo_method.method }}({{ ep.repo_method.args_str }})
    if err != nil {
        if errors.Is(err, gorm.ErrRecordNotFound) {
            return errorspkg.SendError(c, fiber.StatusNotFound, "{{ ep.model | lower }}_not_found")
        }
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "fetch_failed", err.Error())
    }

{% if ep.ownership.enabled and ep.ownership.verify == 'field' %}
{% for p in ep.params %}
{% if p.source == 'claim' %}
    if {{ ep.model | lower }}.{{ ep.ownership.go_field }} != {{ p.var_name }} {
        return errorspkg.SendError(c, fiber.StatusForbidden, "access_denied")
    }
{% endif %}
{% endfor %}
{% endif %}

{% if ep.resppkg.converter %}
    return c.Status(fiber.StatusOK).JSON(resppkg.{{ ep.resppkg.converter }}({{ ep.model | lower }}))
{% else %}
    return c.Status(fiber.StatusOK).JSON({{ ep.model | lower }})
{% endif %}
}

