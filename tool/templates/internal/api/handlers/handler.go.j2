{% endfor %}
{% for p in ep.params %}
{% if p.source == 'path' %}
// @Param {{ p.name }} path {{ p.swagger_type }} true "{{ p.name }}"
{% endif %}
{% endfor %}
{% if ep.has_file_uploads %}
{% for f in ep.file_uploads %}
// @Param {{ f.form_field }} formData file false "{{ f.field }} file"
{% endfor %}
// @Param input formData dtopkg.{{ ep.dto_name }} false "Update data"
{% else %}
// @Param input body dtopkg.{{ ep.dto_name }} false "Update data"
{% endif %}
// @Success 200 {object} resppkg.{{ ep.resppkg.struct }}
// @Failure 400 {object} resppkg.ErrorResponse
