{% endif %}
{% for p in ep.query_params %}
{% if p.enum_values %}
// @Param {{ p.name }} query {{ p.swagger_type }} false "{{ p.name }}" Enums({{ p.enum_values | join(', ') }}){% if p.default %} default({{ p.default }}){% endif %}

{% elif p.type == 'date' %}
// @Param {{ p.name }} query string false "{{ p.name }}" format(date)
{% else %}
// @Param {{ p.name }} query {{ p.swagger_type }} false "{{ p.name }}"{% if p.default and p.default != '' %} default({{ p.default }}){% endif %}

{% endif %}
{% endfor %}
// @Success 200 {object} resppkg.{{ ep.resppkg.struct }}
// @Failure 400 {object} resppkg.ErrorResponse
