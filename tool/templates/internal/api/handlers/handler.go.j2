// @Router {{ ep.path }} [delete]
func (h *{{ ep.model }}Controller) {{ ep.func_name }}(c *fiber.Ctx) error {
{% for p in ep.params %}
{{ parse_param(p) }}
{% endfor %}

    dbConn := utilspkg.GetDB(c)
    if dbConn == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }
    repo := utilspkg.Get{{ ep.model }}Repository(dbConn)
    if repo == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }

{% if ep.ownership.enabled %}
    existing, err := repo.{{ ep.repo_method.method }}({{ ep.repo_method.args_str }})
    if err != nil {
        if errors.Is(err, gorm.ErrRecordNotFound) {
            return errorspkg.SendError(c, fiber.StatusNotFound, "{{ ep.model | lower }}_not_found")
        }
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "fetch_failed", err.Error())
    }
{% if ep.ownership.verify == 'field' %}
{% for p in ep.params %}
{% if p.source == 'claim' %}
    if existing.{{ ep.ownership.go_field }} != {{ p.var_name }} {
        return errorspkg.SendError(c, fiber.StatusForbidden, "access_denied")
    }
{% endif %}
{% endfor %}
{% endif %}
    _ = existing
{% endif %}

{% set id_param = namespace(found=none) %}
{% for p in ep.params %}{% if p.source == 'path' and id_param.found is none %}{% set id_param.found = p %}{% endif %}{% endfor %}
{% if ep.hard_delete %}
    if err := repo.HardDelete({{ id_param.found.var_name if id_param.found else 'id' }}); err != nil {
{% else %}
    if err := repo.Delete({{ id_param.found.var_name if id_param.found else 'id' }}); err != nil {
{% endif %}
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "delete_failed", err.Error())
    }

    return c.Status(fiber.StatusOK).JSON(resppkg.SuccessResponse{Message: "{{ ep.model }} deleted"})
}

{# ───────────────────── BATCH DELETE ───────────────────── #}
{% elif ep.type == 'batch_delete' %}
// {{ ep.func_name }} batch-deletes {{ ep.model | lower }}s.
// @Summary Batch delete {{ ep.model | lower }}s
// @Tags {{ ep.tag }}
{% for mw in ep.middleware %}
// @Security {{ mw | capitalize }}Auth
{% endfor %}
// @Param input body object true "IDs to delete"
// @Success 200 {object} resppkg.SuccessResponse
// @Failure 400 {object} resppkg.ErrorResponse
// @Router {{ ep.path }} [delete]
func (h *{{ ep.model }}Controller) {{ ep.func_name }}(c *fiber.Ctx) error {
{% if ep.needs_claim %}
    userID, ok := c.Locals("user_id").(uint)
    if !ok {
        return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
    }
    _ = userID
{% endif %}

    dbConn := utilspkg.GetDB(c)
    if dbConn == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }
    repo := utilspkg.Get{{ ep.model }}Repository(dbConn)
    if repo == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }

    var req struct {
        IDs []string `json:"ids"`
    }
    if err := c.BodyParser(&req); err != nil || len(req.IDs) == 0 {
        return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_input", "ids required")
    }

    var ids []uint
    for _, s := range req.IDs {
        if v, err := strconv.ParseUint(s, 10, 64); err == nil {
            ids = append(ids, uint(v))
        }
    }
    if len(ids) == 0 {
        return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_ids")
    }

{% if ep.hard_delete %}
    if err := repo.HardDeleteMultiple(ids); err != nil {
{% else %}
    if err := repo.DeleteMultiple(ids); err != nil {
{% endif %}
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "batch_delete_failed", err.Error())
    }

    return c.Status(fiber.StatusOK).JSON(resppkg.SuccessResponse{Message: "Batch delete successful"})
}

{% endif %}
{% endfor %}

