func (h *{{ ep.model }}Controller) {{ ep.func_name }}(c *fiber.Ctx) error {
{% if ep.ownership.enabled %}
    userID, ok := c.Locals("user_id").(uint)
    if !ok {
        return errorspkg.SendError(c, fiber.StatusUnauthorized, "unauthorized")
    }
{% endif %}

{% for pp in ep.path_params %}
{% if pp.type in ('uint', 'int', 'int64') %}
    {{ pp.name }}Raw, err := c.ParamsInt("{{ pp.name }}")
    if err != nil || {{ pp.name }}Raw <= 0 {
        return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_{{ pp.name }}")
    }
    {{ pp.name }} := {{ pp.type }}({{ pp.name }}Raw)
{% else %}
    {{ pp.name }} := c.Params("{{ pp.name }}")
    if {{ pp.name }} == "" {
        return errorspkg.SendError(c, fiber.StatusBadRequest, "invalid_{{ pp.name }}")
    }
{% endif %}
{% endfor %}

{% if ep.has_pagination %}
    page := c.QueryInt("page", 1)
    pageSize := c.QueryInt("page_size", 10)
    if page < 1 { page = 1 }
    if pageSize < 1 || pageSize > 100 { pageSize = 10 }
{% endif %}

{% for p in ep.query_params %}
{% if p.name not in ('sort_by', 'sort_order') %}
{% if p.type == 'date' %}
    var {{ p.name }}Val *time.Time
    if s := c.Query("{{ p.name }}"); s != "" {
        if t, terr := time.Parse("{{ p.format | default('2006-01-02') }}", s); terr == nil {
            {{ p.name }}Val = &t
        }
    }
{% elif p.go_parse == 'int' %}
    {{ p.name }}Val := {{ p.type }}(c.QueryInt("{{ p.name }}", {{ p.default | default(0) }}))
{% elif p.go_parse == 'bool' %}
    var {{ p.name }}Val *bool
    if s := c.Query("{{ p.name }}", ""); s != "" {
        b := s == "true"
        {{ p.name }}Val = &b
    }
{% else %}
    {{ p.name }}Val := c.Query("{{ p.name }}", "{{ p.default | default('') }}")
{% endif %}
{% endif %}
{% endfor %}

{% if ep.options_type %}
    opts := repository.{{ ep.options_type }}{
{% if ep.has_pagination %}
        Page:     page,
        PageSize: pageSize,
{% endif %}
{% for p in ep.query_params %}
{% if p.name == 'sort_by' %}
        SortBy:    c.Query("sort_by", "{{ p.default | default('created_at') }}"),
{% elif p.name == 'sort_order' %}
        SortOrder: c.Query("sort_order", "{{ p.default | default('desc') }}"),
{% else %}
        {{ p.name | replace('_',' ') | title | replace(' ','') }}: {{ p.name }}Val,
{% endif %}
{% endfor %}
{% if ep.ownership.enabled %}
        {{ ep.ownership.field | replace('_',' ') | title | replace(' ','') }}: &userID,
{% endif %}
    }
{% endif %}

    dbConn := utilspkg.GetDB(c)
    if dbConn == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }
    repo := utilspkg.Get{{ ep.model }}Repository(dbConn)
    if repo == nil {
        return errorspkg.SendError(c, fiber.StatusInternalServerError, "db_connection_failed")
    }

{% if ep.unique %}
    result, err := repo.{{ ep.getter_name }}({% for pp in ep.path_params %}{{ pp.name }}{% if not loop.last %}, {% endif %}{% endfor %})
{% elif ep.options_type %}
    results, hasMore, err := repo.{{ ep.getter_name }}({% for pp in ep.path_params %}{{ pp.name }}{% if not loop.last %}, {% endif %}{% endfor %}{% if ep.path_params %}, {% endif %}opts)
{% else %}
    results, hasMore, err := repo.{{ ep.getter_name }}({% for pp in ep.path_params %}{{ pp.name }}{% if not loop.last %}, {% endif %}{% endfor %})
{% endif %}

    if err != nil {
        return errorspkg.SendError(c, fiber.StatusNotFound, "not_found", err.Error())
    }

{% if ep.unique %}
{% if ep.resppkg.converter %}
    return c.Status(fiber.StatusOK).JSON(resppkg.{{ ep.resppkg.converter }}(result))
{% else %}
    return c.Status(fiber.StatusOK).JSON(result)
{% endif %}
{% else %}
{% if ep.resppkg.converter %}
    items := resppkg.{{ ep.resppkg.converter }}(results)
{% else %}
    items := results
{% endif %}
    return c.Status(fiber.StatusOK).JSON(fiber.Map{
        "data":      items,
        "has_more":  hasMore,
{% if ep.has_pagination %}
        "page":      page,
        "page_size": pageSize,
{% endif %}
    })
{% endif %}
}

{% endfor %}
