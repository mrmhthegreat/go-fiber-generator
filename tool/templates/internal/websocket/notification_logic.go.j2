package websocket

import (
	"fmt"
	"log"
	"time"

	"{{ config.project.module }}/config"
{% if config.notifications.get('push', {}).get('enabled', false) or config.get('fcm', {}).get('enabled', false) %}

	fcmpkg "{{ config.project.module }}/pkg/fcm"
{% endif %}
{% if config.notifications.enabled or config.notifications.get('push', {}).get('enabled', false) or config.get('fcm', {}).get('enabled', false) %}
	"{{ config.project.module }}/internal/domain"
{% endif %}
)

// GlobalNotify persists a notification, broadcasts it in real-time via WebSocket,
// and optionally sends a push notification.
func GlobalNotify(notif map[string]interface{}, pushToken *string) {
	// 1. Persist to database
{% if config.notifications.enabled %}
	// notifications.enabled = true — persist to DB via model
	dbNotif := domain.Notification{}
{% for field in config.notifications.model.fields %}
{% if not field.get('primary_key') %}
	if v, ok := notif["{{ field.get('json_tag', field.name) }}"].({{ field.type }}); ok { dbNotif.{{ field.name | title | replace('_', '') }} = v }
{% endif %}
{% endfor %}
	if err := config.DB.Create(&dbNotif).Error; err != nil {
		log.Printf("GlobalNotify: failed to persist notification: %v", err)
		// Continue — we still want to attempt real-time delivery.
	}
{% else %}
	// notifications.enabled = false — skipping DB persist
{% endif %}

	// 2. Real-time WebSocket broadcast (async)
	isOnline := false
{% if config.websocket.enabled and config.notifications.websocket.enabled %}
	userID, _ := notif["user_id"].(uint)
	isOnline = IsUserOnline(userID)
	if isOnline {
		go func() {
			select {
			case Hub.broadcastNotify <- notif:
			case <-time.After(100 * time.Millisecond):
				log.Println("GlobalNotify: WebSocket broadcast dropped (channel full)")
			}
		}()
	}
{% endif %}

{% set push_cfg  = config.notifications.get('push', {}) %}
{% set legacy_fcm = config.get('fcm', {}) %}
{% if push_cfg.get('enabled', false) or legacy_fcm.get('enabled', false) %}
	// 3. Push notification
	if pushToken != nil && *pushToken != "" {
		{% set provider = push_cfg.get('provider', 'fcm' if legacy_fcm.get('enabled', false) else 'none') %}
		{% if push_cfg.get('triggers') %}
		{% set triggers = push_cfg.triggers %}
		{% else %}
		{% set triggers = [{'event': 'notification_created', 'condition': 'user_offline'}] %}
		{% endif %}

		{% for trigger in triggers %}
		// Trigger: {{ trigger.event }}
		{
			sendPush := false
			{% if trigger.condition == 'always' %}
			sendPush = true
			{% elif trigger.condition == 'user_offline' %}
			sendPush = !isOnline
			{% elif trigger.condition == 'custom' %}
			// Custom condition — implement {{ trigger.custom_condition_function | default('customPushCondition') }} here
			sendPush = true
			{% endif %}

			_ = sendPush // suppress unused-variable warning if push is conditional
			if sendPush {
				title, _ := notif["title"].(string)
				message, _ := notif["message"].(string)
				token := *pushToken
				go func() {
					{% if provider == 'fcm' %}
					if err := fcmpkg.SendToDevice(config.FCM, token, title, message); err != nil {
						log.Printf("GlobalNotify: FCM push failed: %v", err)
					}
					{% elif provider == 'apns' %}
					log.Printf("GlobalNotify: APNS push triggered for user %v", notif["user_id"])
					{% else %}
					log.Printf("GlobalNotify: custom push provider '{{ provider }}' for user %v", notif["user_id"])
					{% endif %}
				}()
			}
		}
		{% endfor %}
	}
{% endif %}
}

// TriggerNotification creates and dispatches a notification for a given event.
// `data` carries context-specific values such as receiver_id, conversation_id, etc.
func TriggerNotification(event string, data map[string]interface{}) {
{% set triggers = config.notifications.get('triggers', []) %}
{% if triggers %}
	switch event {
{% for trigger in triggers %}
{% if trigger.get('enabled', true) %}
	case "{{ trigger.event }}":
		{
			shouldTrigger := false
			{% if trigger.condition == 'always' %}
			shouldTrigger = true
			{% elif trigger.condition == 'receiver_offline' %}
			if receiverID, ok := toUint(data["receiver_id"]); ok && receiverID != 0 {
				shouldTrigger = !IsUserOnline(receiverID)
			}
			{% elif trigger.condition == 'custom' %}
			// Custom condition for event '{{ trigger.event }}'
			shouldTrigger = true
			{% endif %}

			if shouldTrigger {
				userID := uint(0)
				if rid, ok := toUint(data["receiver_id"]); ok && rid != 0 {
					userID = rid
				} else if uid, ok := toUint(data["user_id"]); ok {
					userID = uid
				}

				if userID != 0 {
					notif := map[string]interface{}{
						"user_id": userID,
						"title":   fmt.Sprintf("{{ trigger.notification.title_template }}"),
						"message": fmt.Sprintf("{{ trigger.notification.message_template }}"),
						"type":    "{{ trigger.notification.type }}",
					}

					{% if trigger.notification.reference_id_field %}
					if refID, ok := toUint(data["{{ trigger.notification.reference_id_field }}"]); ok && refID != 0 {
						notif["reference_id"] = &refID
					}
					{% endif %}

					{% if trigger.notification.reference_type %}
					refType := "{{ trigger.notification.reference_type }}"
					notif["reference_type"] = &refType
					{% endif %}

					var user domain.User
					if err := config.DB.Select("fcm_token").First(&user, userID).Error; err == nil {
						GlobalNotify(notif, user.FCMToken)
					} else {
						GlobalNotify(notif, nil)
					}
				}
			}
		}
{% endif %}
{% endfor %}
	}
{% endif %}
}

// toUint safely converts common numeric types stored in map[string]interface{} to uint.
func toUint(v interface{}) (uint, bool) {
	switch val := v.(type) {
	case uint:
		return val, true
	case int:
		return uint(val), val >= 0
	case int64:
		return uint(val), val >= 0
	case float64:
		return uint(val), val >= 0
	case float32:
		return uint(val), val >= 0
	}
	return 0, false
}
