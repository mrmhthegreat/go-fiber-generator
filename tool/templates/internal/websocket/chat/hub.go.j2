package chat
import (
	"fmt"
	"log"
	"sync"
	"time"

	"github.com/gofiber/contrib/websocket"

	"{{ config.project.module }}/config"

	fcmpkg "{{ config.project.module }}/pkg/fcm"
	"{{ config.project.module }}/internal/domain"
	resppkg "{{ config.project.module }}/pkg/response"
	ws "{{ config.project.module }}/websocket"
)

{% if config.websocket.enabled %}
{# ────────────────────────────────────────────────────────────── #}
{# Resolve pool/channel names once at template level              #}
{# ────────────────────────────────────────────────────────────── #}
{% set ns = namespace(
    admin_pool=None,
    user_pool=None,
    admin_chan=None,
    user_chan=None,
    status_chan=None,
    notify_chan=None
) %}
{% for pool in config.websocket.hub.pools %}
{% if pool.enabled %}
    {% if 'admin' in pool.name | lower %}{% set ns.admin_pool = pool %}{% endif %}
    {% if 'user' in pool.name | lower and 'admin' not in pool.name | lower %}{% set ns.user_pool = pool %}{% endif %}
{% endif %}
{% endfor %}
{% for channel in config.websocket.hub.channels %}
{% if channel.get('enabled', true) %}
    {% if 'admin' in channel.name | lower %}{% set ns.admin_chan = channel %}{% endif %}
    {% if 'user' in channel.name | lower and 'admin' not in channel.name | lower %}{% set ns.user_chan = channel %}{% endif %}
    {% if 'status' in channel.name | lower %}{% set ns.status_chan = channel %}{% endif %}
    {% if 'notify' in channel.name | lower %}{% set ns.notify_chan = channel %}{% endif %}
{% endif %}
{% endfor %}

{# ────────────────────────────────────────────────────────────── #}
{# Shared types (both modes)                                      #}
{# ────────────────────────────────────────────────────────────── #}
{% if config.websocket.get('presence', {}).get('enabled', false) %}
type StatusUpdate struct {
	UserID   uint `json:"user_id"`
	IsOnline bool `json:"is_online"`
}
{% endif %}

type UserConn struct {
	UserID uint
	Conn   WSWriter
}

{# 1. ChatHub — user↔user and user↔system chat messages            #}
{# ──────────────────────────────────────────────────────────────── #}
{% if config.chat.enabled and config.websocket.get('dedicated', {}).get('chat', {}).get('enabled', true) %}

// ChatHub manages user connections and chat message broadcasting.
type ChatHub struct {
{% if ns.user_pool %}
	{{ ns.user_pool.name }} map[uint]WSWriter
	register{{ ns.user_pool.name | title }}   chan *UserConn
	unregister{{ ns.user_pool.name | title }} chan *UserConn
{% endif %}
{% if ns.user_chan %}
	{{ ns.user_chan.name }} chan domain.Message
{% endif %}
{% if ns.status_chan and config.websocket.get('presence', {}).get('enabled', false) %}
	{{ ns.status_chan.name }} chan StatusUpdate
{% endif %}
	mu sync.RWMutex
}

var ChatHubInst = ChatHub{
{% if ns.user_pool %}
	{{ ns.user_pool.name }}: make(map[uint]WSWriter),
	register{{ ns.user_pool.name | title }}:   make(chan *UserConn),
	unregister{{ ns.user_pool.name | title }}: make(chan *UserConn),
{% endif %}
{% if ns.user_chan %}
	{{ ns.user_chan.name }}: make(chan domain.Message, {{ ns.user_chan.buffer_size }}),
{% endif %}
{% if ns.status_chan and config.websocket.get('presence', {}).get('enabled', false) %}
	{{ ns.status_chan.name }}: make(chan StatusUpdate, {{ ns.status_chan.buffer_size }}),
{% endif %}
}

func (h *ChatHub) Run() {
	for {
		select {
{% if ns.user_pool %}
		case userConn := <-h.register{{ ns.user_pool.name | title }}:
			h.mu.Lock()
			h.{{ ns.user_pool.name }}[userConn.UserID] = userConn.Conn
			h.mu.Unlock()
{% if config.websocket.get('presence', {}).get('enabled', false) and config.websocket.get('presence', {}).get('broadcast_on_connect', false) %}
			go h.BroadcastStatus(userConn.UserID, true)
{% endif %}

		case userConn := <-h.unregister{{ ns.user_pool.name | title }}:
			h.mu.Lock()
			if conn, ok := h.{{ ns.user_pool.name }}[userConn.UserID]; ok && conn == userConn.Conn {
				delete(h.{{ ns.user_pool.name }}, userConn.UserID)
				conn.Close()
{% if config.websocket.get('presence', {}).get('enabled', false) and config.websocket.get('presence', {}).get('broadcast_on_disconnect', false) %}
				go h.BroadcastStatus(userConn.UserID, false)
{% endif %}
			}
			h.mu.Unlock()
{% endif %}

{% if ns.user_chan %}
		case msg := <-h.{{ ns.user_chan.name }}:
			h.mu.RLock()
			var conversation domain.Conversation
			if err := config.DB.First(&conversation, msg.ConversationID).Error; err == nil {
				targetID := conversation.UserID
				{% set receiver_id_field = config.chat.domain.conversation.fields | selectattr('name', 'equalto', 'receiver_id') | first %}
				{% if receiver_id_field %}
				if msg.SenderID == conversation.UserID && conversation.ReceiverID != nil {
					targetID = *conversation.ReceiverID
				}
				{% endif %}
{% if ns.user_pool %}
				if conn, online := h.{{ ns.user_pool.name }}[targetID]; online {
					if err := conn.WriteJSON(resppkg.ConvertToMessageResponse(&msg)); err != nil {
						h.mu.RUnlock()
						h.mu.Lock()
						delete(h.{{ ns.user_pool.name }}, targetID)
						h.mu.Unlock()
						conn.Close()
						h.mu.RLock()
					}
				} else {
					go h.SendOfflineNotification(targetID, msg)
				}
{% endif %}
			}
			h.mu.RUnlock()
{% endif %}

{% if config.websocket.get('presence', {}).get('enabled', false) and ns.status_chan %}
		case status := <-h.{{ ns.status_chan.name }}:
			// Presence update — forward to SupportHub via registry so admins see it
			go func(s StatusUpdate) {
				if ws.BroadcastRegistry.Admin != nil {
					ws.BroadcastRegistry.Admin.BroadcastToAdmins(map[string]interface{}{
						"type":      "status_update",
						"user_id":   s.UserID,
						"is_online": s.IsOnline,
					})
				}
			}(status)
{% endif %}
		}
	}
}

{% if config.websocket.get('presence', {}).get('enabled', false) and ns.status_chan %}
func (h *ChatHub) BroadcastStatus(userID uint, isOnline bool) {
	select {
	case h.{{ ns.status_chan.name }} <- StatusUpdate{UserID: userID, IsOnline: isOnline}:
	case <-time.After(100 * time.Millisecond):
		log.Printf("Dropped status update for user %d (channel full)", userID)
	}
}
{% endif %}

func (h *ChatHub) SendOfflineNotification(userID uint, msg domain.Message) {
	var user domain.User
	if err := config.DB.Select("id", "fcm_token").First(&user, userID).Error; err == nil {
		if user.FCMToken != nil && *user.FCMToken != "" {
			title := "New Message"
			if msg.SenderType == "admin" {
				title = "Support Message"
			}
			data := map[string]string{"conversation_id": fmt.Sprintf("%d", msg.ConversationID)}
			fcmpkg.SendPushNotification(*user.FCMToken, title, msg.Content, data)
		}
	}
}

func (h *ChatHub) BroadcastToUser(userID uint, msg interface{}) {
	h.mu.RLock()
	defer h.mu.RUnlock()
{% if ns.user_pool %}
	if userID == 0 {
		// userID=0 means broadcast to all connected users
		for _, conn := range h.{{ ns.user_pool.name }} {
			_ = conn.WriteJSON(msg)
		}
		return
	}
	if conn, online := h.{{ ns.user_pool.name }}[userID]; online {
		_ = conn.WriteJSON(msg)
	}
{% endif %}
}

// IsUserOnline satisfies the UserBroadcaster interface.
func (h *ChatHub) IsUserOnline(userID uint) bool {
	h.mu.RLock()
	defer h.mu.RUnlock()
{% if ns.user_pool %}
	_, ok := h.{{ ns.user_pool.name }}[userID]
	return ok
{% else %}
	return false
{% endif %}
}

func NotifyUser(msg domain.Message) {
{% if ns.user_chan %}
	select {
	case ChatHubInst.{{ ns.user_chan.name }} <- msg:
	case <-time.After(100 * time.Millisecond):
		log.Println("Dropped message to User channel (full)")
	}
{% endif %}
}

func NotifyTargetUser(targetUserID uint, msg domain.Message) {
	NotifyUser(msg)
}

func NotifyTargetUserAction(targetUserID uint, conversationID uint, action string) {
	ChatHubInst.mu.RLock()
{% if ns.user_pool %}
	conn, ok := ChatHubInst.{{ ns.user_pool.name }}[targetUserID]
{% else %}
	var conn WSWriter
	ok := false
{% endif %}
	ChatHubInst.mu.RUnlock()

	if ok {
		resp := resppkg.MessageResponse{
			ConversationID: conversationID,
			Action:         action,
			SenderType:     "system",
			CreatedAt:      time.Now().Format(time.RFC3339),
			UpdatedAt:      time.Now().Format(time.RFC3339),
		}
		if err := conn.WriteJSON(resp); err != nil {
			log.Printf("Error sending action to user %d: %v", targetUserID, err)
		}
	}
}

func StartChatHub() {
	ws.RegisterUserBroadcaster(&ChatHubInst)
	go ChatHubInst.Run()
}

{% endif %}{# dedicated.chat #}

{% endif %}{# websocket.enabled #}
