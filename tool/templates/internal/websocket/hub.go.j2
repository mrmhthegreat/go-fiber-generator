{# DEDICATED MODE — separate focused hubs per concern              #}
{#                                                                  #}
{# ChatHub    — user pool + message channels (user↔user chat)      #}
{# SupportHub — admin pool + message channels (admin↔user support) #}
{# EventsHub  — notify channel + user pool ref (custom events)     #}
{# ════════════════════════════════════════════════════════════════ #}
{% if config.websocket.handler_type == 'dedicated' %}
{# ──────────────────────────────────────────────────────────────── #}
{# 1. ChatHub — user↔user and user↔system chat messages            #}
{# ──────────────────────────────────────────────────────────────── #}
{% if config.chat.enabled and config.websocket.get('dedicated', {}).get('chat', {}).get('enabled', true) %}
// ChatHub manages user connections and chat message broadcasting.
type ChatHub struct {
{% if ns.user_pool %}
	{{ ns.user_pool.name }} map[uint]WSWriter
	register{{ ns.user_pool.name | title }}   chan *UserConn
	unregister{{ ns.user_pool.name | title }} chan *UserConn
{% endif %}
{% if ns.user_chan %}
	{{ ns.user_chan.name }} chan domain.Message
{% endif %}
{% if ns.status_chan and config.websocket.presence.enabled %}
	{{ ns.status_chan.name }} chan StatusUpdate
{% endif %}
	mu sync.RWMutex
}
var ChatHubInst = ChatHub{
{% if ns.user_pool %}
	{{ ns.user_pool.name }}: make(map[uint]WSWriter),
	register{{ ns.user_pool.name | title }}:   make(chan *UserConn),
	unregister{{ ns.user_pool.name | title }}: make(chan *UserConn),
{% endif %}
{% if ns.user_chan %}
	{{ ns.user_chan.name }}: make(chan domain.Message, {{ ns.user_chan.buffer_size }}),
{% endif %}
{% if ns.status_chan and config.websocket.presence.enabled %}
	{{ ns.status_chan.name }}: make(chan StatusUpdate, {{ ns.status_chan.buffer_size }}),
{% endif %}
}
func (h *ChatHub) Run() {
	for {
		select {
{% if ns.user_pool %}
		case userConn := <-h.register{{ ns.user_pool.name | title }}:
			h.mu.Lock()
			h.{{ ns.user_pool.name }}[userConn.UserID] = userConn.Conn
			h.mu.Unlock()
{% if config.websocket.presence.enabled and config.websocket.presence.broadcast_on_connect %}
			go h.BroadcastStatus(userConn.UserID, true)
{% endif %}
		case userConn := <-h.unregister{{ ns.user_pool.name | title }}:
			h.mu.Lock()
			if conn, ok := h.{{ ns.user_pool.name }}[userConn.UserID]; ok && conn == userConn.Conn {
				delete(h.{{ ns.user_pool.name }}, userConn.UserID)
				conn.Close()
{% if config.websocket.presence.enabled and config.websocket.presence.broadcast_on_disconnect %}
				go h.BroadcastStatus(userConn.UserID, false)
{% endif %}
			}
			h.mu.Unlock()
{% endif %}
{% if ns.user_chan %}
		case msg := <-h.{{ ns.user_chan.name }}:
			h.mu.RLock()
			var conversation domain.Conversation
			if err := config.DB.First(&conversation, msg.ConversationID).Error; err == nil {
				targetID := conversation.UserID
				{% set receiver_id_field = config.chat.models.conversation.fields | selectattr('name', 'equalto', 'receiver_id') | first %}
				{% if receiver_id_field %}
				if msg.SenderID == conversation.UserID && conversation.ReceiverID != nil {
					targetID = *conversation.ReceiverID
				}
				{% endif %}
{% if ns.user_pool %}
				if conn, online := h.{{ ns.user_pool.name }}[targetID]; online {
					if err := conn.WriteJSON(resppkg.ConvertToMessageResponse(&msg)); err != nil {
						h.mu.RUnlock()
						h.mu.Lock()
						delete(h.{{ ns.user_pool.name }}, targetID)
						h.mu.Unlock()
						conn.Close()
						h.mu.RLock()
					}
				} else {
					go h.SendOfflineNotification(targetID, msg)
				}
{% endif %}
			}
			h.mu.RUnlock()
{% endif %}
{% if config.websocket.presence.enabled and ns.status_chan %}
		case status := <-h.{{ ns.status_chan.name }}:
			// Presence update — forward to SupportHub via registry so admins see it
			go func(s StatusUpdate) {
				if ws.BroadcastRegistry.Admin != nil {
					ws.BroadcastRegistry.Admin.BroadcastToAdmins(map[string]interface{}{
						"type":      "status_update",
						"user_id":   s.UserID,
						"is_online": s.IsOnline,
					})
				}
			}(status)
{% endif %}
		}
	}
}
