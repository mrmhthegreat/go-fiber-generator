package websocket
import (
	"fmt"
	"log"
	"sync"
	"time"
	"github.com/gofiber/contrib/websocket"
	"{{ config.project.module }}/config"
	fcmpkg "{{ config.project.module }}/pkg/fcm"
	"{{ config.project.module }}/internal/domain"
	resppkg "{{ config.project.module }}/pkg/response"
{% if config.notifications.enabled %}
	notifpkg "{{ config.project.module }}/pkg/notification"
{% endif %}
)
{% if config.websocket.enabled %}
{# ────────────────────────────────────────────────────────────── #}
{# Resolve pool/channel names once at template level              #}
{# ────────────────────────────────────────────────────────────── #}
{% set ns = namespace(
    admin_pool=None,
    user_pool=None,
    admin_chan=None,
    user_chan=None,
    status_chan=None,
    notify_chan=None
) %}
{% for pool in config.websocket.hub.pools %}
{% if pool.enabled %}
    {% if 'admin' in pool.name | lower %}{% set ns.admin_pool = pool %}{% endif %}
    {% if 'user' in pool.name | lower and 'admin' not in pool.name | lower %}{% set ns.user_pool = pool %}{% endif %}
{% endif %}
{% endfor %}
{% for channel in config.websocket.hub.channels %}
{% if channel.get('enabled', true) %}
    {% if 'admin' in channel.name | lower %}{% set ns.admin_chan = channel %}{% endif %}
    {% if 'user' in channel.name | lower and 'admin' not in channel.name | lower %}{% set ns.user_chan = channel %}{% endif %}
    {% if 'status' in channel.name | lower %}{% set ns.status_chan = channel %}{% endif %}
    {% if 'notify' in channel.name | lower %}{% set ns.notify_chan = channel %}{% endif %}
{% endif %}
{% endfor %}
{# ────────────────────────────────────────────────────────────── #}
{# Shared types (both modes)                                      #}
{# ────────────────────────────────────────────────────────────── #}
{% if config.websocket.presence.enabled %}
type StatusUpdate struct {
	UserID   uint `json:"user_id"`
	IsOnline bool `json:"is_online"`
}
{% endif %}
type UserConn struct {
	UserID uint
	Conn   WSWriter
}
{# ════════════════════════════════════════════════════════════════ #}
{# UNIFIED MODE — single ChatHub for everything                    #}
{# ════════════════════════════════════════════════════════════════ #}
{% if config.websocket.handler_type == 'unified' %}
// ChatHub manages all WebSocket connections and broadcasting.
type ChatHub struct {
{% for pool in config.websocket.hub.pools %}
{% if pool.enabled %}
{% if pool.key_by == 'connection' %}
	{{ pool.name }} map[*websocket.Conn]bool
{% elif pool.key_by == 'user_id' %}
	{{ pool.name }} map[uint]WSWriter
{% elif pool.key_by == 'room_id' %}
	{{ pool.name }} map[string]map[WSWriter]bool
{% endif %}
{% endif %}
{% endfor %}
	// Registration channels
{% for pool in config.websocket.hub.pools %}
{% if pool.enabled and pool.key_by in ['connection', 'user_id'] %}
{% if pool.key_by == 'connection' %}
	register{{ pool.name | title }}   chan *websocket.Conn
	unregister{{ pool.name | title }} chan *websocket.Conn
{% else %}
	register{{ pool.name | title }}   chan *UserConn
	unregister{{ pool.name | title }} chan *UserConn
{% endif %}
{% endif %}
{% endfor %}
	// Broadcast channels
{% for channel in config.websocket.hub.channels %}
{% if channel.get('enabled', true) %}
{% set cname = channel.name | lower %}
{% if 'admin' in cname or ('user' in cname and 'admin' not in cname) %}
	{{ channel.name }} chan domain.Message
{% elif 'status' in cname %}
	{{ channel.name }} chan StatusUpdate
{% elif 'notify' in cname %}
	{{ channel.name }} chan map[string]interface{}
{% else %}
	{{ channel.name }} chan interface{}
{% endif %}
{% endif %}
{% endfor %}
	mu sync.RWMutex
}
var Hub = ChatHub{
{% for pool in config.websocket.hub.pools %}
{% if pool.enabled %}
{% if pool.key_by == 'connection' %}
	{{ pool.name }}: make(map[*websocket.Conn]bool),
{% elif pool.key_by == 'user_id' %}
	{{ pool.name }}: make(map[uint]WSWriter),
{% elif pool.key_by == 'room_id' %}
	{{ pool.name }}: make(map[string]map[WSWriter]bool),
{% endif %}
{% endif %}
{% endfor %}
{% for pool in config.websocket.hub.pools %}
{% if pool.enabled and pool.key_by in ['connection', 'user_id'] %}
{% if pool.key_by == 'connection' %}
	register{{ pool.name | title }}:   make(chan *websocket.Conn),
	unregister{{ pool.name | title }}: make(chan *websocket.Conn),
{% else %}
	register{{ pool.name | title }}:   make(chan *UserConn),
	unregister{{ pool.name | title }}: make(chan *UserConn),
{% endif %}
{% endif %}
{% endfor %}
{% for channel in config.websocket.hub.channels %}
{% if channel.get('enabled', true) %}
{% set cname = channel.name | lower %}
{% if 'admin' in cname or ('user' in cname and 'admin' not in cname) %}
	{{ channel.name }}: make(chan domain.Message, {{ channel.buffer_size }}),
{% elif 'status' in cname %}
	{{ channel.name }}: make(chan StatusUpdate, {{ channel.buffer_size }}),
{% elif 'notify' in cname %}
	{{ channel.name }}: make(chan map[string]interface{}, {{ channel.buffer_size }}),
{% else %}
	{{ channel.name }}: make(chan interface{}, {{ channel.buffer_size }}),
{% endif %}
{% endif %}
{% endfor %}
}
func (h *ChatHub) Run() {
	for {
		select {
{% for pool in config.websocket.hub.pools %}
{% if pool.enabled and pool.key_by in ['connection', 'user_id'] %}
{% if pool.key_by == 'connection' %}
		case conn := <-h.register{{ pool.name | title }}:
			h.mu.Lock()
			h.{{ pool.name }}[conn] = true
			h.mu.Unlock()
		case conn := <-h.unregister{{ pool.name | title }}:
			h.mu.Lock()
			if _, ok := h.{{ pool.name }}[conn]; ok {
				delete(h.{{ pool.name }}, conn)
				conn.Close()
			}
			h.mu.Unlock()
{% else %}
		case userConn := <-h.register{{ pool.name | title }}:
			h.mu.Lock()
			h.{{ pool.name }}[userConn.UserID] = userConn.Conn
			h.mu.Unlock()
{% if config.websocket.presence.enabled and config.websocket.presence.broadcast_on_connect %}
			go h.BroadcastStatus(userConn.UserID, true)
{% endif %}
		case userConn := <-h.unregister{{ pool.name | title }}:
			h.mu.Lock()
			if conn, ok := h.{{ pool.name }}[userConn.UserID]; ok && conn == userConn.Conn {
				delete(h.{{ pool.name }}, userConn.UserID)
				conn.Close()
{% if config.websocket.presence.enabled and config.websocket.presence.broadcast_on_disconnect %}
				go h.BroadcastStatus(userConn.UserID, false)
{% endif %}
			}
			h.mu.Unlock()
{% endif %}
{% endif %}
{% endfor %}
		// ── Broadcast: Admin messages ───────────────────────────────
{% if config.chat.enabled and ns.admin_chan %}
		case msg := <-h.{{ ns.admin_chan.name }}:
			resp := resppkg.ConvertToMessageResponse(&msg)
{% if ns.admin_pool %}
			h.mu.RLock()
			var staleAdmins []*websocket.Conn
			for conn := range h.{{ ns.admin_pool.name }} {
				if err := conn.WriteJSON(resp); err != nil {
					staleAdmins = append(staleAdmins, conn)
				}
			}
			h.mu.RUnlock()
			if len(staleAdmins) > 0 {
				h.mu.Lock()
				for _, conn := range staleAdmins {
					delete(h.{{ ns.admin_pool.name }}, conn)
					conn.Close()
				}
				h.mu.Unlock()
			}
{% endif %}
{% endif %}
		// ── Broadcast: User messages ────────────────────────────────
{% if config.chat.enabled and ns.user_chan %}
		case msg := <-h.{{ ns.user_chan.name }}:
			h.mu.RLock()
			var conversation domain.Conversation
			if err := config.DB.First(&conversation, msg.ConversationID).Error; err == nil {
				targetID := conversation.UserID
				{% set receiver_id_field = config.chat.models.conversation.fields | selectattr('name', 'equalto', 'receiver_id') | first %}
				{% if receiver_id_field %}
				if msg.SenderID == conversation.UserID && conversation.ReceiverID != nil {
					targetID = *conversation.ReceiverID
				}
				{% endif %}
{% if ns.user_pool %}
				if conn, online := h.{{ ns.user_pool.name }}[targetID]; online {
					if err := conn.WriteJSON(resppkg.ConvertToMessageResponse(&msg)); err != nil {
						h.mu.RUnlock()
						h.mu.Lock()
						delete(h.{{ ns.user_pool.name }}, targetID)
						h.mu.Unlock()
						conn.Close()
						h.mu.RLock()
					}
				} else {
					go h.SendOfflineNotification(targetID, msg)
				}
{% endif %}
			}
			h.mu.RUnlock()
{% endif %}
		// ── Broadcast: Presence status ──────────────────────────────
{% if config.websocket.presence.enabled and ns.status_chan %}
		case status := <-h.{{ ns.status_chan.name }}:
			h.mu.RLock()
{% if ns.admin_pool %}
			for conn := range h.{{ ns.admin_pool.name }} {
				_ = conn.WriteJSON(map[string]interface{}{
					"type":      "status_update",
					"user_id":   status.UserID,
					"is_online": status.IsOnline,
				})
			}
{% endif %}
			h.mu.RUnlock()
{% endif %}
		// ── Broadcast: Notifications ────────────────────────────────
{% if config.notifications.enabled and config.notifications.websocket.enabled and ns.notify_chan %}
		case notif := <-h.{{ ns.notify_chan.name }}:
			h.mu.RLock()
			userID, _ := notif["user_id"].(uint)
			if userID != 0 {
{% if ns.user_pool %}
				if conn, online := h.{{ ns.user_pool.name }}[userID]; online {
					_ = conn.WriteJSON(map[string]interface{}{"type": "notification", "data": notif})
				}
{% endif %}
			} else {
{% if ns.admin_pool %}
				for conn := range h.{{ ns.admin_pool.name }} {
					_ = conn.WriteJSON(map[string]interface{}{"type": "notification", "data": notif})
				}
{% endif %}
			}
			h.mu.RUnlock()
{% endif %}
		}
	}
}
{% if config.websocket.presence.enabled and ns.status_chan %}
func (h *ChatHub) BroadcastStatus(userID uint, isOnline bool) {
	select {
	case h.{{ ns.status_chan.name }} <- StatusUpdate{UserID: userID, IsOnline: isOnline}:
	case <-time.After(100 * time.Millisecond):
		log.Printf("Dropped status update for user %d (channel full)", userID)
	}
}
func IsUserOnline(userID uint) bool {
	Hub.mu.RLock()
	defer Hub.mu.RUnlock()
{% if ns.user_pool %}
	_, ok := Hub.{{ ns.user_pool.name }}[userID]
	return ok
{% else %}
	return false
{% endif %}
}
{% endif %}
{% if config.chat.enabled %}
func (h *ChatHub) SendOfflineNotification(userID uint, msg domain.Message) {
	var user domain.User
	if err := config.DB.Select("id", "fcm_token").First(&user, userID).Error; err == nil {
		if user.FCMToken != nil && *user.FCMToken != "" {
			title := "New Message"
			if msg.SenderType == "admin" {
				title = "Support Message"
			}
			data := map[string]string{"conversation_id": fmt.Sprintf("%d", msg.ConversationID)}
			fcmpkg.SendPushNotification(*user.FCMToken, title, msg.Content, data)
		}
	}
}
func NotifyUser(msg domain.Message) {
{% if ns.user_chan %}
	select {
	case Hub.{{ ns.user_chan.name }} <- msg:
	case <-time.After(100 * time.Millisecond):
		log.Println("Dropped message to User channel (full)")
	}
{% endif %}
}
func NotifyAdmins(msg domain.Message) {
{% if ns.admin_chan %}
	select {
	case Hub.{{ ns.admin_chan.name }} <- msg:
	case <-time.After(100 * time.Millisecond):
		log.Println("Dropped message to Admin channel (full)")
	}
{% endif %}
}
func NotifyTargetUser(targetUserID uint, msg domain.Message) {
	NotifyUser(msg)
}
func NotifyTargetUserAction(targetUserID uint, conversationID uint, action string) {
	Hub.mu.RLock()
{% if ns.user_pool %}
	conn, ok := Hub.{{ ns.user_pool.name }}[targetUserID]
{% else %}
	var conn WSWriter
	ok := false
{% endif %}
	Hub.mu.RUnlock()
	if ok {
		resp := resppkg.MessageResponse{
			ConversationID: conversationID,
			Action:         action,
			SenderType:     "system",
			CreatedAt:      time.Now().Format(time.RFC3339),
			UpdatedAt:      time.Now().Format(time.RFC3339),
		}
		if err := conn.WriteJSON(resp); err != nil {
			log.Printf("Error sending action to user %d: %v", targetUserID, err)
		}
	}
}
func (h *ChatHub) BroadcastAll(msg interface{}) {
	h.mu.RLock()
	defer h.mu.RUnlock()
{% if ns.admin_pool %}
	for conn := range h.{{ ns.admin_pool.name }} {
		_ = conn.WriteJSON(msg)
	}
{% endif %}
{% if ns.user_pool %}
	for _, conn := range h.{{ ns.user_pool.name }} {
		_ = conn.WriteJSON(msg)
	}
{% endif %}
}
func (h *ChatHub) BroadcastToAdmins(msg interface{}) {
	h.mu.RLock()
	defer h.mu.RUnlock()
{% if ns.admin_pool %}
	for conn := range h.{{ ns.admin_pool.name }} {
		_ = conn.WriteJSON(msg)
	}
{% endif %}
}
func (h *ChatHub) BroadcastToUser(userID uint, msg interface{}) {
	h.mu.RLock()
	defer h.mu.RUnlock()
{% if ns.user_pool %}
	if conn, online := h.{{ ns.user_pool.name }}[userID]; online {
		_ = conn.WriteJSON(msg)
	}
{% endif %}
}
{% endif %}
// StartChatHub starts the unified hub's event loop.
func StartChatHub() {
{% if config.notifications.enabled and config.notifications.websocket.enabled %}
	notifpkg.WsBroadcastHook = func(userID uint, msg map[string]interface{}) {
		Hub.BroadcastToUser(userID, msg)
	}
	notifpkg.IsUserOnlineHook = IsUserOnline
{% endif %}
	go Hub.Run()
}
{% endif %}{# end unified #}
