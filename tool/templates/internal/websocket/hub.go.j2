func (h *ChatHub) BroadcastToUser(userID uint, msg interface{}) {
	h.mu.RLock()
	defer h.mu.RUnlock()
{% if ns.user_pool %}
	if userID == 0 {
		// userID=0 means broadcast to all connected users
		for _, conn := range h.{{ ns.user_pool.name }} {
			_ = conn.WriteJSON(msg)
		}
		return
	}
	if conn, online := h.{{ ns.user_pool.name }}[userID]; online {
		_ = conn.WriteJSON(msg)
	}
{% endif %}
}
// IsUserOnline satisfies the UserBroadcaster interface.
func (h *ChatHub) IsUserOnline(userID uint) bool {
	h.mu.RLock()
	defer h.mu.RUnlock()
{% if ns.user_pool %}
	_, ok := h.{{ ns.user_pool.name }}[userID]
	return ok
{% else %}
	return false
{% endif %}
}
