{# Admin Chat WebSocket Handler (server-side rendered admin UI)   #}
{# ────────────────────────────────────────────────────────────── #}
{% if config.chat.get('web_handler', {}).get('enabled', false) %}
{% set ns2 = namespace(admin_pool=None) %}
{% for pool in config.websocket.hub.pools %}
{% if 'admin' in pool.name | lower and pool.enabled %}{% set ns2.admin_pool = pool %}{% endif %}
{% endfor %}
// AdminChatWebSocket handles admin connections for the support chat interface.
func AdminChatWebSocket(c *websocket.Conn) {
{% if ns2.admin_pool %}
	Hub.register{{ ns2.admin_pool.name | title }} <- c
	defer func() { Hub.unregister{{ ns2.admin_pool.name | title }} <- c }()
{% endif %}
	for {
		type InputMsg struct {
			ConversationID uint                     `json:"conversation_id"`
			Content        string                   `json:"content"`
		}
		var input InputMsg
		if err := c.ReadJSON(&input); err != nil {
			break
		}
		if input.Content == "" || input.ConversationID == 0 {
			continue
		}
	
		msg := domain.Message{
			ConversationID: input.ConversationID,
			SenderID:       0, // system/admin sender
			SenderType:     "admin",
			Content:        input.Content,
		}
		if err := config.DB.Create(&msg).Error; err != nil {
			log.Println("AdminChatWebSocket DB error:", err)
			continue
		}
		{% set last_message_field = config.chat.models.conversation.fields | selectattr('name', 'equalto', 'last_message') | first %}
		{% if last_message_field %}
		config.DB.Model(&domain.Conversation{}).
			Where("id = ?", input.ConversationID).
			Updates(domain.Conversation{LastMessage: input.Content})
		{% endif %}
		NotifyUser(msg)
		NotifyAdmins(msg) // echo back to all admins for UI sync
	}
}
{% endif %}