{# Dynamic JWT Validation with Configurable Claims                #}
{# ────────────────────────────────────────────────────────────── #}
// ValidateUnifiedTokens validates JWT tokens with dynamic configuration
func ValidateUnifiedTokens(appToken, authHeader string) (uint, error) {
{% if config.websocket.authentication.app_token.enabled %}
	// Validate app token if provided
	if appToken != "" {
		appSecret, err := getAppTokenSecret()
		if err != nil {
			return 0, err
		}

		appJWT, err := jwt.Parse(appToken, func(token *jwt.Token) (interface{}, error) {
			// Validate algorithm
			if token.Method.Alg() != "{{ config.websocket.authentication.jwt.algorithm }}" {
				return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
			}
			return appSecret, nil
		})
		if err != nil || !appJWT.Valid {
			return 0, fmt.Errorf("invalid_app_token: %w", err)
		}
	}{% if config.websocket.authentication.app_token.required %} else {
		return 0, fmt.Errorf("app_token_required")
	}{% endif %}
{% endif %}

	// Extract JWT from header
{% if config.websocket.authentication.jwt.extraction.header_prefix %}
	if !strings.HasPrefix(authHeader, "{{ config.websocket.authentication.jwt.extraction.header_prefix }}") {
		return 0, fmt.Errorf("invalid_auth_header_format")
	}
	bearerToken := strings.TrimPrefix(authHeader, "{{ config.websocket.authentication.jwt.extraction.header_prefix }}")
{% else %}
	bearerToken := authHeader
{% endif %}

	if bearerToken == "" {
		return 0, fmt.Errorf("missing_auth_token")
	}

	// Get JWT secret
	jwtSecret, err := getJWTSecret()
	if err != nil {
		return 0, err
	}

	// Parse and validate JWT
	userJWT, err := jwt.Parse(bearerToken, func(token *jwt.Token) (interface{}, error) {
		// Validate algorithm
		if token.Method.Alg() != "{{ config.websocket.authentication.jwt.algorithm }}" {
			return nil, fmt.Errorf("unexpected signing method: %v", token.Header["alg"])
		}
		return jwtSecret, nil
	})
	if err != nil || !userJWT.Valid {
		return 0, fmt.Errorf("invalid_user_token: %w", err)
	}

	claims, ok := userJWT.Claims.(jwt.MapClaims)
	if !ok {
		return 0, fmt.Errorf("invalid_claims")
	}

	// Extract user_id from configured claim
{% set user_id_claim = config.websocket.authentication.jwt.claims.user_id %}
{% if user_id_claim.type == 'float64' %}
	userIDFloat, ok := claims["{{ user_id_claim.claim_name }}"].(float64)
	if !ok {
{% if user_id_claim.required %}
		return 0, fmt.Errorf("invalid_or_missing_user_id_claim")
{% else %}
		return 0, nil  // Optional claim not present
{% endif %}
	}
	return uint(userIDFloat), nil
{% elif user_id_claim.type == 'string' %}
	userIDStr, ok := claims["{{ user_id_claim.claim_name }}"].(string)
	if !ok {
{% if user_id_claim.required %}
		return 0, fmt.Errorf("invalid_or_missing_user_id_claim")
{% else %}
		return 0, nil
{% endif %}
	}
	// Convert string to uint (you may need custom logic here)
	var userID uint
	fmt.Sscanf(userIDStr, "%d", &userID)
	return userID, nil
{% elif user_id_claim.type == 'int' %}
	userIDInt, ok := claims["{{ user_id_claim.claim_name }}"].(int)
	if !ok {
{% if user_id_claim.required %}
		return 0, fmt.Errorf("invalid_or_missing_user_id_claim")
{% else %}
		return 0, nil
{% endif %}
	}
	return uint(userIDInt), nil
{% endif %}
}

// ExtractClaim extracts a claim from JWT token (helper for custom handlers)
func ExtractClaim(claims jwt.MapClaims, claimName string, claimType string) (interface{}, error) {
	value, ok := claims[claimName]
	if !ok {
		return nil, fmt.Errorf("claim %s not found", claimName)
	}
	
	// Type assertion based on configured type
	switch claimType {
	case "string":
		if v, ok := value.(string); ok {
			return v, nil
		}
	case "float64":
		if v, ok := value.(float64); ok {
			return v, nil
		}
	case "int":
		if v, ok := value.(int); ok {
			return v, nil
		}
	case "bool":
		if v, ok := value.(bool); ok {
			return v, nil
		}
	}
	
	return nil, fmt.Errorf("claim %s has unexpected type", claimName)
}
