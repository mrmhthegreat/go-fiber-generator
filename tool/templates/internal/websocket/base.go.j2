// getJWTSecret retrieves JWT secret from configured source
func getJWTSecret() ([]byte, error) {
	secret := viper.GetString("{{ config.websocket.authentication.jwt.secret_key }}")
	if secret == "" {
		return nil, fmt.Errorf("JWT secret not found in environment variable {{ config.websocket.authentication.jwt.secret_key }}")
	}
	return []byte(secret), nil

}

