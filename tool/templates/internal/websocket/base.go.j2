{# Allows dedicated hubs in separate packages to call each other  #}
{# without import cycles. Each hub registers itself on startup.   #}
{# ────────────────────────────────────────────────────────────── #}

// UserBroadcaster can deliver messages to a specific user.
type UserBroadcaster interface {
	BroadcastToUser(userID uint, msg interface{})
	IsUserOnline(userID uint) bool
}

// AdminBroadcaster can deliver messages to all connected admins.
type AdminBroadcaster interface {
	BroadcastToAdmins(msg interface{})
}

// BroadcastRegistry holds references to dedicated hub instances
// so EventsHub and others can route across package boundaries.
var BroadcastRegistry struct {
	User  UserBroadcaster
	Admin AdminBroadcaster
}

// RegisterUserBroadcaster is called by ChatHub on startup.
func RegisterUserBroadcaster(b UserBroadcaster) {
	BroadcastRegistry.User = b
}

// RegisterAdminBroadcaster is called by SupportHub on startup.
func RegisterAdminBroadcaster(b AdminBroadcaster) {
	BroadcastRegistry.Admin = b
}
{% endif %}

{% if config.websocket.handler_type == 'dedicated' %}
// IsUserOnline is available in the base websocket package so notification_logic
// and other base-package code can check presence without importing chat.
func IsUserOnline(userID uint) bool {
	if BroadcastRegistry.User != nil {
		return BroadcastRegistry.User.IsUserOnline(userID)
	}
	return false
}
{% endif %}