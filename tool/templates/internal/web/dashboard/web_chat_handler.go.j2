{% if ep.enabled %}
// GetChatPage renders the admin chat interface.
func (h *WebChatHandler) GetChatPage(c *fiber.Ctx) error {
	userID, ok := c.Locals("user_id").(uint)
	if !ok || userID == 0 {
		return c.Redirect("/login", fiber.StatusSeeOther)
	}



	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return fiber.NewError(fiber.StatusInternalServerError, "db_connection_failed")
	}

{% if ctx_cfg.get('needs_user', false) %}
{% if user_ctx.use_repo %}
	userRepo := dbConn.{{ config.project.user_model_name }}
	if userRepo == nil {
		log.Println("{{ user_ctx.repo_name }} not available")
		return fiber.NewError(fiber.StatusInternalServerError, "db_connection_failed")
	}
	user, err := userRepo.{{ user_ctx.method }}(userID)
	if err != nil {
		return fiber.NewError(fiber.StatusInternalServerError, "internal_server_error")
	}
{% else %}
	return fiber.NewError(fiber.StatusInternalServerError, "internal_server_error")
{% endif %}
{% endif %}

	renderContext := fiber.Map{}

{% if ctx_cfg.get('needs_csrf', false) %}
	renderContext["csrfToken"] = c.Locals("csrf").(string)
{% endif %}

{% if ctx_cfg.get('needs_user', false) %}
	renderContext["user"] = user
{% endif %}

{% if ctx_cfg.get('needs_perms', false) %}
	perms := rbacpkg.GetUserPermsForTemplate(c,h.RBACService)
	permsJSON, _ := sonic.Marshal(perms)
	renderContext["perms"] = string(permsJSON)
{% endif %}

{% if ctx_cfg.get('needs_dashbase', false) and rbac_cfg.get('enabled', false) %}
	dashBase := rbacpkg.GetDashboardBasePath(user.Role)
	renderContext["dashBase"] = dashBase
{% endif %}

{% for data in ctx_cfg.get('custom_data', []) %}
	// Fetch {{ data.name }}
	{{ data.repo | lower }}Repo := dbConn.{{ data.model_name | default(data.repo | replace('Repository', '')) }}
	if {{ data.repo | lower }}Repo == nil {
		log.Println("{{ data.repo }}Repository not available")
	} else {
		{{ data.var }}, err := {{ data.repo | lower }}Repo.{{ data.method }}({{ data.args | join(', ') }})
		if err != nil {
			log.Printf("Error fetching {{ data.var }}: %v", err)
		} else {
{% if data.get('marshal') %}
			{{ data.var }}Data, _ := sonic.Marshal({{ data.var }})
			renderContext["{{ data.var }}"] = string({{ data.var }}Data)
{% else %}
			renderContext["{{ data.var }}"] = {{ data.var }}
{% endif %}
		}
	}
{% endfor %}

	return c.Render("{{ ep.get('template', 'admin/chat/index') }}", renderContext)
}

{% if ep.get('endpoints', {}).get('list_conversations', {}).get('enabled', false) %}
// GetConversations returns paginated conversations for the admin view.
func (h *WebChatHandler) GetConversations(c *fiber.Ctx) error {
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	options := db.ListConversationOptions{
		Search:    strings.TrimSpace(c.Query("search")),
		Status:    strings.TrimSpace(c.Query("status")),
		ConvType:  strings.TrimSpace(c.Query("type", "chat")),
		SortBy:    strings.TrimSpace(c.Query("sort_by", "updated_at")),
		SortOrder: strings.TrimSpace(c.Query("sort_order", "desc")),
		Offset:    c.QueryInt("offset", 0),
		Limit:     c.QueryInt("limit", 20),
	}

	chatRepo := dbConn.Chat
	if chatRepo == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	conversations, hasMore, total, err := chatRepo.GetAdminConversations(options)
	if err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "fetch_failed"})
	}

	chatResponses := resppkg.ConvertToChatResponses(conversations)
{% if config.chat.get('websocket', {}).get('enabled', false) %}
	for i := range chatResponses {
		chatResponses[i].User.IsOnline = project_ws.IsUserOnline(chatResponses[i].{{ conv_user_id_f.name | title | replace('_', '') }})
	}
{% endif %}

	return c.JSON(fiber.Map{
		"conversations": chatResponses,
		"has_more":      hasMore,
		"total":         total,
	})
}
{% endif %}

{% if ep.get('list_messages', {}).get('enabled', false) %}
// GetMessages returns messages for a specific conversation (admin view).
func (h *WebChatHandler) GetMessages(c *fiber.Ctx) error {
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	id, err := strconv.ParseUint(c.Params("id"), 10, 32)
	if err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_conversation_id"})
	}

	options := db.ListMessageOptions{
		ConversationID: uint(id),
		SortBy:         strings.TrimSpace(c.Query("sort_by", "created_at")),
		SortOrder:      strings.TrimSpace(c.Query("sort_order", "asc")),
		Offset:         c.QueryInt("offset", 0),
		Limit:          c.QueryInt("limit", 50),
	}

	chatRepo := dbConn.Chat
	if chatRepo == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	messages, hasMore, total, err := chatRepo.ListMessages(options)
	if err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "fetch_failed"})
	}

	return c.JSON(fiber.Map{
		"messages": resppkg.ConvertToMessageResponses(messages),
		"has_more": hasMore,
		"total":    total,
	})
}
{% endif %}

{% if ep.get('send_message', {}).get('enabled', false) %}
// SendMessage lets an admin send a message into a conversation.
func (h *WebChatHandler) SendMessage(c *fiber.Ctx) error {
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	convID, err := strconv.ParseUint(c.Params("id"), 10, 32)
	if err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_conversation_id"})
	}

	var req dtopkg.SendMessageRequest
	if err := c.BodyParser(&req); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_request"})
	}
	if strings.TrimSpace(req.Content) == "" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "content_cannot_be_empty"})
	}

	adminID, _ := c.Locals("user_id").(uint)

	chatRepo := dbConn.Chat
	if chatRepo == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	msg := &domain.Message{
		{{ msg_conv_id_f.name | title | replace('_', '') }}: uint(convID),
		SenderID:       adminID,
		SenderType:     "admin",
		Content:        req.Content,
	}

	created, err := chatRepo.CreateMessage(msg)
	if err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "send_failed"})
	}

{% if config.get('notifications', {}).get('enabled', false) %}
	// Notify target user via WebSocket / push.
	conv, convErr := chatRepo.GetConversationByIDSimple(uint(convID))
{% if config.chat.get('websocket', {}).get('enabled', false) %}
	if convErr == nil && conv != nil {
		project_ws.NotifyUser(*created)
	}
{% endif %}
{% endif %}

	return c.JSON(resppkg.ConvertToMessageResponse(created))
}
{% endif %}

{% if ep.get('mark_as_read', {}).get('enabled', false) %}
// MarkConversationRead lets an admin mark all messages in a conversation as read.
func (h *WebChatHandler) MarkConversationRead(c *fiber.Ctx) error {
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	convID, err := strconv.ParseUint(c.Params("id"), 10, 32)
	if err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_conversation_id"})
	}

	chatRepo := dbConn.Chat
	if chatRepo == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	if err := chatRepo.MarkMessagesAsRead(uint(convID), "admin"); err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	return c.JSON(fiber.Map{"success": true})
}
{% endif %}

{% if ep.get('close_conversation', {}).get('enabled', false) %}
// CloseConversation sets a conversation status to "closed".
func (h *WebChatHandler) CloseConversation(c *fiber.Ctx) error {
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	convID, err := strconv.ParseUint(c.Params("id"), 10, 32)
	if err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_conversation_id"})
	}

	chatRepo := dbConn.Chat
	if chatRepo == nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	conv, err := chatRepo.GetConversationByIDSimple(uint(convID))
	if err != nil {
		return c.Status(fiber.StatusNotFound).JSON(fiber.Map{"error": "conversation_not_found"})
	}

	conv.Status = "closed"
	if err := dbConn.DB.Save(conv).Error; err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "server_error"})
	}

	// Notify user that conversation was closed.
{% if config.chat.get('websocket', {}).get('enabled', false) %}
	project_ws.NotifyTargetUserAction(conv.{{ conv_user_id_f.name | title | replace('_', '') }}, uint(convID), "conversation_closed")
{% endif %}

	return c.JSON(fiber.Map{"success": true})
}
{% endif %}


