{# ============ DELETE ============ #}
{% elif ep.type == 'delete' %}
// {{ ep.func_name }} handles deleting a {{ ep.model | lower }}.
func (h *{{ ep.model }}Handler) {{ ep.func_name }}(c *fiber.Ctx) error {
    userID, ok := c.Locals("user_id").(uint)
    if !ok {
{% if ep.return_type == 'json' %}
        return c.Status(fiber.StatusUnauthorized).JSON(fiber.Map{"error": "unauthorized"})
{% else %}
        return c.Redirect("{{ handler.auth_redirect }}", fiber.StatusSeeOther)
{% endif %}
    }

{% for param in ep.path_params %}
{% if param.type in ['uint', 'int', 'int64'] %}
    {{ param.name }}Raw, err := c.ParamsInt("{{ param.name }}")
    if err != nil || {{ param.name }}Raw <= 0 {
        return c.Status(fiber.StatusBadRequest).SendString("Invalid {{ param.name }}")
    }
    {{ param.name }} := {{ param.type }}({{ param.name }}Raw)
{% else %}
    {{ param.name }} := c.Params("{{ param.name }}")
{% endif %}
{% endfor %}



    // Get database and repository
    dbConn := utilspkg.GetDB(c)
    if dbConn == nil {
        log.Println("Database connection not available")
{% if ep.return_type == 'json' %}
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "db_connection_failed"})
{% else %}
        return c.Status(fiber.StatusInternalServerError).SendString("Database connection failed")
{% endif %}
    }

    repo := utilspkg.Get{{ ep.model }}Repository(dbConn)
    if repo == nil {
        log.Println("{{ ep.model }}Repository not available")
{% if ep.return_type == 'json' %}
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "db_connection_failed"})
{% else %}
        return c.Status(fiber.StatusInternalServerError).SendString("Database connection failed")
{% endif %}
    }

{% if ep.ownership.enabled %}
    // Ownership check
{% if ep.ownership.verify == 'param' and ep.ownership.repo_method %}
    {# ──── ownership via repo method (e.g. GetByUserAndID) ──── #}
    existing, err := repo.{{ ep.ownership.repo_method }}({{ ep.ownership.repo_method_args_str }})
    if err != nil {
{% if ep.return_type == 'json' %}
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{"error": "not_found"})
{% else %}
        return c.Status(fiber.StatusNotFound).SendString("Not found")
{% endif %}
    }
{% else %}
    {# ──── ownership via field comparison ──── #}
    existing, err := repo.GetByID({{ ep.path_params[0].name }})
    if err != nil {
{% if ep.return_type == 'json' %}
        return c.Status(fiber.StatusNotFound).JSON(fiber.Map{"error": "not_found"})
{% else %}
        return c.Status(fiber.StatusNotFound).SendString("Not found")
{% endif %}
    }
    if existing.{{ ep.ownership.go_field }} != userID {
{% if ep.return_type == 'json' %}
        return c.Status(fiber.StatusForbidden).JSON(fiber.Map{"error": "access_denied"})
{% else %}
        return c.Status(fiber.StatusForbidden).SendString("Access denied")
{% endif %}
    }
{% endif %}
{% endif %}

    if err := repo.Delete({{ ep.path_params[0].name }}); err != nil {
{% if ep.return_type == 'json' %}
        return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "delete_failed"})
{% else %}
        return c.Redirect("{{ handler.base_path }}?error=delete_failed", fiber.StatusSeeOther)
{% endif %}
    }

{% if ep.return_type == 'json' %}
    return c.Status(fiber.StatusOK).JSON(fiber.Map{"success": true})
{% else %}
    return c.Redirect("{{ ep.redirect_on_success }}", fiber.StatusSeeOther)
{% endif %}
}

{% endif %}
    
{% endfor %}

