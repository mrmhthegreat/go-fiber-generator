// LoginPage renders the login page
func (h *WebAuthHandler) LoginPage(c *fiber.Ctx) error {
{% if auth.session.enabled %}
	sess, err := authpkg.GetSession(c)
	if err != nil {
		return fiber.NewError(fiber.StatusInternalServerError, "internal_server_error")
	}
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	
	// Redirect already-authenticated users
	if sess.Get("authenticated") == true {
		userID, _ := sess.Get("user_id").(uint)
		if userID != 0 {
			{{ repo_var }} := dbConn.Auth
		{% if config.rbac.enabled %}
			user, _ := {{ repo_var }}.GetByID(userID, "id", "role")
		{% else %}
			user, _ := {{ repo_var }}.GetByID(userID, "id")
		{% endif %}
			if user != nil {
		{% if config.rbac.enabled %}
						return c.Redirect(rbacpkg.GetDashboardBasePath(user.Role))
		{% else %}
						return c.Redirect("/dashboard")
		{% endif %}
					}
					sess.Destroy()
				}
			}
{% endif %}

{% if web.get('use_translations', False) %}
