// HandleForgotPassword sends a password-reset OTP to the user
func (h *WebAuthHandler) HandleForgotPassword(c *fiber.Ctx) error {
	var input dtopkg.ForgotPasswordInput
	if err := c.BodyParser(&input); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_input"})
	}
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	{{ repo_var }} := dbConn.Auth
	if {{ repo_var }} == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	{% set forgot_fields = ['"email"', '"fullname"', '"auth_provider"'] %}
	{% if auth.email_password.forgot_password.identifier_field == 'email' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Email, {{ forgot_fields | join(', ') }})
	{% elif auth.email_password.forgot_password.identifier_field == 'username' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Username, {{ forgot_fields | join(', ') }})
	{% elif auth.email_password.forgot_password.identifier_field == 'email_or_username' %}
		user, err := {{ repo_var }}.{{auth.email_password.forgot_password.repository_method}}(input.Identifier, {{ forgot_fields | join(', ') }})
	{% endif %}

	if err != nil {
		// Don't reveal whether the account exists
		return c.Status(fiber.StatusOK).JSON(fiber.Map{})
	}

	if user.AuthProvider != "local" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "use_" + user.AuthProvider + "_login"})
	}

	otp := authpkg.GenerateOTP()
	authpkg.StoreOTP(user.Email, otp)
	go func() {
		if err := emailpkg.SendEmail(user.Email, "Password Reset", "{{ auth.email_password.forgot_password.email_template }}", fiber.Map{
			"code": otp,
		}); err != nil {
			log.Printf("Error sending reset email: %v", err)
		}
	}()

	{% if auth.session.enabled %}
		sess, _ := authpkg.GetSession(c)
		sess.Set("otpemail", user.Email)
		sess.Save()
	{% endif %}

	c.Set("HX-Redirect", "/auth/reset-password")
	return c.Status(fiber.StatusOK).JSON(fiber.Map{})
}
{% endif %}

