// HandleResetPassword applies the new password after OTP verification
func HandleResetPassword(c *fiber.Ctx) error {
	var input dtopkg.ResetPasswordInput
	if err := c.BodyParser(&input); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_input"})
	}

	{{ repo_var }} := utilspkg.Get{{ config.project.repository_name }}(c)
	if {{ repo_var }} == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

{% if auth.email_password.forgot_password.identifier_field == 'email' %}
	user, err := {{ repo_var }}.GetUserByEmail(input.Email)
{% elif auth.email_password.forgot_password.identifier_field == 'username' %}
	user, err := {{ repo_var }}.GetUserByUsername(input.Username)
{% elif auth.email_password.forgot_password.identifier_field == 'email_or_username' %}
	user, err := {{ repo_var }}.GetUserByEmailOrUsername(input.Identifier)
{% endif %}
	if err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_credentials"})
	}

	if !authpkg.VerifyOTP(user.Email, input.OTP) {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_otp"})
	}

	hashedPassword, err := authpkg.HashPassword(input.NewPassword)
	if err != nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	if err := {{ repo_var }}.UpdateUserPassword(user.Email, hashedPassword); err != nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	authpkg.DeleteOTP(user.Email)

{% if auth.session.enabled %}
	sess, _ := utilspkg.GetSession(c)
	sess.Set("otpemail", nil)
	sess.Save()
{% endif %}

	c.Set("HX-Redirect", "/login")
	return c.Status(fiber.StatusOK).JSON(fiber.Map{})
}
{% endif %}

