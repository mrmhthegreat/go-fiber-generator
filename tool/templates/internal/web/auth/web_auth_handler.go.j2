// LoginPage renders the login page
func LoginPage(c *fiber.Ctx) error {
{% if auth.session.enabled %}
	sess, err := utilspkg.GetSession(c)
	if err != nil {
		return fiber.NewError(fiber.StatusInternalServerError, "internal_server_error")
	}

	// Redirect already-authenticated users
	if sess.Get("authenticated") == true {
		userID, _ := sess.Get("user_id").(uint)
		if userID != 0 {
			{{ repo_var }} := utilspkg.Get{{ config.project.repository_name }}(c)
			user, _ := {{ repo_var }}.GetByID(userID)
			if user != nil {
{% if config.rbac.enabled %}
				return c.Redirect(rbacpkg.GetDashboardBasePath(user.{{ config.rbac.model_field }}))
{% else %}
				return c.Redirect("/dashboard")
{% endif %}
			}
			sess.Destroy()
		}
	}
{% endif %}

{% if web.get('use_translations', False) %}
	# translation := i18npkg.MergeMaps(
	# 	i18npkg.TranslateMap(c, config.BasicEveryTranslations),
	# 	i18npkg.TranslateMap(c, config.BasicAuthTranslations),
	# )
	# transJSON, _ := sonic.Marshal(translation)
	return c.Render("basic/signin", fiber.Map{
		"csrfToken": c.Locals("csrf").(string),
		# "trans":     string(transJSON),
	})
{% else %}
	return c.Render("basic/signin", fiber.Map{
		"csrfToken": c.Locals("csrf").(string),
	})
{% endif %}
}

// HandleLogin processes the login form
func HandleLogin(c *fiber.Ctx) error {
	var input dtopkg.LoginUserInput
	if err := c.BodyParser(&input); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_input"})
	}

	{{ repo_var }} := utilspkg.Get{{ config.project.repository_name }}(c)
	if {{ repo_var }} == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

{% set enabled_login = config._enabled_login_method %}
{% if enabled_login %}
{% if enabled_login.get('json_field') %}
	user, err := {{ repo_var }}.{{ enabled_login.repository_method }}(input.{{ enabled_login.json_field | title }})
{% else %}
	user, err := {{ repo_var }}.{{ enabled_login.repository_method }}(input.{{ enabled_login.field | title }})
{% endif %}
	if err != nil {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{"{{ enabled_login.get('json_field', enabled_login.field) }}": true})
	}

	if user.AuthProvider != "local" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "use_" + user.AuthProvider + "_login"})
	}

	if user.Password == nil || !authpkg.CheckPasswordHash(input.Password, *user.Password) {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{"password": true})
	}

{% if auth.email_password.email_verification.enabled %}
	if !user.{{ auth.email_password.email_verification.model_field }} {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{"error": "email_not_verified"})
	}
{% endif %}

{% if auth.session.enabled %}
	sess, err := utilspkg.GetSession(c)
	if err != nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}
	sess.Destroy() // Regenerate session ID to prevent fixation attacks
	sess.Set("authenticated", true)
	sess.Set("user_id", user.ID)
	sess.Set("email", user.Email)
{% if auth.email_password.email_verification.enabled %}
	sess.Set("is_verified", user.{{ auth.email_password.email_verification.model_field }})
{% endif %}
{% if config.rbac.enabled %}
	sess.Set("role", user.{{ config.rbac.model_field }})
{% endif %}
	sess.Save()
{% endif %}

{% if config.rbac.enabled %}
	c.Set("HX-Redirect", rbacpkg.GetDashboardBasePath( user.{{ config.rbac.model_field }}))
{% else %}
	c.Set("HX-Redirect", "/dashboard")
{% endif %}
	return c.Status(fiber.StatusOK).JSON(fiber.Map{})
{% else %}
	return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "no_login_method_configured"})
{% endif %}
}
{% endif %}

