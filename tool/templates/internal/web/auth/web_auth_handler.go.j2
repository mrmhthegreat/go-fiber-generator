{% else %}
	return c.Render("basic/signin", fiber.Map{
		"csrfToken": c.Locals("csrf").(string),
	})
{% endif %}
}

// HandleLogin processes the login form
func (h *WebAuthHandler) HandleLogin(c *fiber.Ctx) error {
	var input dtopkg.LoginUserInput
	if err := c.BodyParser(&input); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_input"})
	}
	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	{{ repo_var }} := dbConn.Auth
	if {{ repo_var }} == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

{% set enabled_login = config._enabled_login_method %}
{% if enabled_login %}
	{% set login_fields = ['"id"', '"password"', '"auth_provider"'] %}
	{% if auth.email_verification.enabled %}
		{% set _ = login_fields.append('"verified"') %}
	{% endif %}
	{% if config.rbac.enabled %}
		{% set _ = login_fields.append('"role"') %}
	{% endif %}
	{% if auth.session.claims %}
		{% for claim in auth.session.claims %}
			{% if claim.name not in ['user_id', 'role', 'is_verified', 'authenticated'] %}
				{% set _ = login_fields.append('"' ~ claim.name ~ '"') %}
			{% endif %}
		{% endfor %}
	{% endif %}
	{% if enabled_login.get('json_field') %}
		user, err := {{ repo_var }}.{{ enabled_login.repository_method }}(input.{{ enabled_login.json_field | title }}, {{ login_fields | join(', ') }})
	{% else %}
		user, err := {{ repo_var }}.{{ enabled_login.repository_method }}(input.{{ enabled_login.field | title }}, {{ login_fields | join(', ') }})
	{% endif %}
	if err != nil {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{"{{ enabled_login.get('json_field', enabled_login.field) }}": true})
	}

	if user.AuthProvider != "local" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "use_" + user.AuthProvider + "_login"})
	}

	if user.Password == nil || !authpkg.CheckPasswordHash(input.Password, *user.Password) {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{"password": true})
	}

	{% if auth.email_verification.enabled %}
		if !user.Verified {
			return c.Status(fiber.StatusForbidden).JSON(fiber.Map{"error": "email_not_verified"})
		}
	{% endif %}

	{% if auth.session.enabled %}
		sess, err := authpkg.GetSession(c)
		if err != nil {
			c.Set("HX-Redirect", "/server-error")
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
		}
		sess.Destroy() // Regenerate session ID to prevent fixation attacks
		sess.Set("authenticated", true)
		sess.Set("user_id", user.ID)
		{% if auth.email_verification.enabled %}
			sess.Set("is_verified", user.Verified)
		{% endif %}
		{% if config.rbac.enabled %}
			sess.Set("role", user.Role)
		{% endif %}
		{% if auth.session.claims %}
{% set use_email = config.authentication.email_password.enabled or config.authentication.social_auth.google.enabled or config.authentication.social_auth.facebook.enabled %}
{% if use_email %}
			sess.Set("email", user.Email)
{% endif %}
			{% for claim in auth.session.claims %}
			{% if claim.name not in ['user_id', 'role', 'is_verified', 'authenticated', 'email', 'verified'] %}
			{% set field_name = claim.name | replace('_', ' ') | title | replace(' ', '') %}
				sess.Set("{{ claim.name }}", user.{{ field_name }})
			{% endif %}
			{% endfor %}
		{% endif %}
		sess.Save()
	{% endif %}

	{% if config.rbac.enabled %}
		c.Set("HX-Redirect", rbacpkg.GetDashboardBasePath( user.Role))
	{% else %}
		c.Set("HX-Redirect", "/dashboard")
	{% endif %}
	
   	return c.Status(fiber.StatusOK).JSON(fiber.Map{})
   {% else %}
   	return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"error": "no_login_method_configured"})
   {% endif %}
}
{% endif %}

