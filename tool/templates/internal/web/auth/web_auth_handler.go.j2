// HandleSignup processes the signup form
func (h *WebAuthHandler) HandleSignup(c *fiber.Ctx) error {

	dbConn := utilspkg.GetDB(c)
	if dbConn == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	{{ repo_var }} := dbConn.Auth
	if {{ repo_var }} == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	var input dtopkg.RegisterUserInput
	if err := c.BodyParser(&input); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_input"})
	}

	// Check uniqueness for fields that require it
{% for field in identifier.register_fields %}
{% if field.get('unique', False) and field.get('repository_check') and not field.get('file_upload', False) %}
{% if field.dto_type.startswith('*') %}
	if input.{{ field.field | title }} != nil {
		if _, err := {{ repo_var }}.{{ field.repository_check }}(*input.{{ field.field | title }}); err == nil {
			return c.Status(fiber.StatusConflict).JSON(fiber.Map{"{{ field.field }}": true})
		}
	}
{% else %}
	if _, err := {{ repo_var }}.{{ field.repository_check }}(input.{{ field.field | title }}); err == nil {
		return c.Status(fiber.StatusConflict).JSON(fiber.Map{"{{ field.field }}": true})
	}
{% endif %}
{% endif %}
{% endfor %}

	hashedPassword, err := authpkg.HashPassword(input.Password)
	if err != nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	user := domain.{{ model }}{
{% for field in identifier.register_fields %}
{% if not field.get('sensitive', False) and not field.get('file_upload', False) %}
		{{ field.field | title }}: input.{{ field.field | title }},
{% endif %}
{% endfor %}
		Password:     &hashedPassword,
		AuthProvider: "local",
{% if auth.email_verification.enabled %}
		Verified: false,
{% endif %}
{% if config.rbac.enabled %}
		Role: "{{ config.rbac.default_role | default('user') }}",
{% endif %}
	}

	u, err := {{ repo_var }}.CreateUser(&user)
	if err != nil {
		log.Printf("Error creating user: %v", err)
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

{% if auth.email_verification.enabled %}
	// Send verification OTP
	otp := authpkg.GenerateOTP()
	authpkg.StoreOTP(u.Email, otp)
	go func() {
		if err := emailpkg.SendEmail(u.Email, "Email Verification", "{{ auth.email_verification.email_template }}", fiber.Map{
			"code": otp,
		}); err != nil {
			log.Printf("Error sending verification email: %v", err)
		}
	}()
{% endif %}

{% if auth.session.enabled %}
	sess, _ := authpkg.GetSession(c)
	sess.Set("authenticated", true)
	sess.Set("user_id", u.ID)
{% if auth.email_verification.enabled %}
	sess.Set("is_verified", false)
{% endif %}
{% if config.rbac.enabled %}
	sess.Set("role", u.Role)
{% endif %}
{% if auth.session.claims %}
{% set use_email = config.authentication.email_password.enabled or config.authentication.social_auth.google.enabled or config.authentication.social_auth.facebook.enabled %}
{% if use_email %}
	sess.Set("email", u.Email)
{% endif %}
{% for claim in auth.session.claims %}
{% if claim.name not in ['user_id', 'role', 'is_verified', 'authenticated', 'email', 'verified'] %}
{% set field_name = claim.name | replace('_', ' ') | title | replace(' ', '') %}
	sess.Set("{{ claim.name }}", u.{{ field_name }})
{% endif %}
{% endfor %}
{% endif %}
	sess.Save()
{% endif %}

	c.Set("HX-Redirect", "/dashboard")
	return c.Status(fiber.StatusOK).JSON(fiber.Map{})
}
{% endif %}

