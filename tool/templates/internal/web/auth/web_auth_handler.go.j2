// HandleVerifyEmail processes the OTP submitted on the verification page
func HandleVerifyEmail(c *fiber.Ctx) error {
	var input dtopkg.VerifyEmailInput
	if err := c.BodyParser(&input); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_input"})
	}

{% if auth.session.enabled %}
	sess, _ := utilspkg.GetSession(c)
	userID, ok := sess.Get("user_id").(uint)
	if !ok || userID == 0 {
		return c.Redirect("/login")
	}
{% endif %}

	{{ repo_var }} := utilspkg.Get{{ config.project.repository_name }}(c)
	if {{ repo_var }} == nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

{% if auth.session.enabled %}
	user, err := {{ repo_var }}.GetByID(userID)
	if err != nil || user == nil {
		return c.Redirect("/login")
	}
	if user.{{ auth.email_password.email_verification.model_field }} {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "already_verified"})
	}

	if !authpkg.VerifyOTP(user.Email, input.OTP) {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_otp"})
	}

	if err := {{ repo_var }}.UpdateUserVerification(user.Email, true); err != nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}

	sess.Set("is_verified", true)
	sess.Save()
{% else %}
	email := c.FormValue("email")
	if !authpkg.VerifyOTP(email, input.OTP) {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"error": "invalid_otp"})
	}
	if err := {{ repo_var }}.UpdateUserVerification(email, true); err != nil {
		c.Set("HX-Redirect", "/server-error")
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{})
	}
{% endif %}

	authpkg.DeleteOTP(user.Email)
	c.Set("HX-Redirect", "/dashboard")
	return c.Status(fiber.StatusOK).JSON(fiber.Map{})
}
{% endif %}

