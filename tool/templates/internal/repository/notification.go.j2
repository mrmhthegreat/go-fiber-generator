	"fmt"

	"gorm.io/gorm"

	"{{ config.project.module }}/internal/domain"
)

{% if config.notifications.enabled %}
{% set user_fields = config.notifications.model.fields %}
{% set base_fields = [
    {'name': 'id', 'type': 'uint', 'primary_key': true, 'auto_increment': true},
    {'name': 'user_id', 'type': 'uint', 'required': true, 'index': true},
    {'name': 'title', 'type': 'string', 'required': true},
    {'name': 'message', 'type': 'string', 'required': true},
    {'name': 'type', 'type': 'string', 'required': true},
    {'name': 'is_read', 'type': 'bool', 'default': false}
] %}
{% set user_field_names = user_fields | map(attribute='name') | list %}
{% set model_fields = user_fields | list %}
{% for base in base_fields %}
    {% if base.name not in user_field_names %}
        {% set _ = model_fields.append(base) %}
    {% endif %}
{% endfor %}

{% set id_field = model_fields | selectattr('primary_key', 'defined') | selectattr('primary_key', 'equalto', true) | first | default({'name': 'id'}) %}
{% set user_id_field = model_fields | selectattr('name', 'equalto', 'user_id') | first | default({'name': 'user_id'}) %}
{% set is_read_field = model_fields | selectattr('name', 'equalto', 'is_read') | first | default(none) %}
{% set has_is_read = is_read_field is not none %}
{% set has_user_id = user_id_field is not none %}

// NotificationRepository defines the interface for notification database operations.
type NotificationRepository interface {
	CreateNotification(notif *domain.Notification) error
GetNotificationsByUserID(userID uint, limit, offset int, fields ...string) ([]domain.Notification, bool, error)
{% if has_is_read %}
	MarkNotificationAsRead(id uint, userID uint) error
	MarkNotificationsAsReadBulk(ids []uint, userID uint) error
	MarkAllNotificationsAsRead(userID uint) error
	GetUnreadNotificationCount(userID uint) (int64, error)
{% endif %}
	DeleteNotification(id uint, userID uint) error
	DeleteNotificationsBulk(ids []uint, userID uint) error
{% if config.notifications.repository.get('custom_methods') %}
{% for method in config.notifications.repository.custom_methods %}
	// {{ method.description }}
	{{ method.name }}(userID uint) error
{% endfor %}
{% endif %}
}

type notificationRepository struct {
	db *gorm.DB
}

// NewNotificationRepository creates a new NotificationRepository backed by the given *gorm.DB.
func NewNotificationRepository(db *gorm.DB) NotificationRepository {
	return &notificationRepository{db: db}
}

// CreateNotification persists a new notification record.
func (r *notificationRepository) CreateNotification(notif *domain.Notification) error {
	if err := r.db.Create(notif).Error; err != nil {
		return fmt.Errorf("CreateNotification: %w", err)
	}
	return nil
}

// GetNotificationsByUserID retrieves paginated notifications for a user, newest first.
func (r *notificationRepository) GetNotificationsByUserID(userID uint, limit, offset int, fields ...string) ([]domain.Notification, bool, error) {
	var notifications []domain.Notification

	query := r.db.Where("{{ user_id_field.name }} = ?", userID)
	if len(fields) > 0 {
		query = query.Select(fields)
	}
	err := query.
		Order("created_at desc").
		Limit(limit + 1).
		Offset(offset).
		Find(&notifications).Error
	if err != nil {
		return nil, false, fmt.Errorf("GetNotificationsByUserID: %w", err)
	}
	hasMore := len(notifications) > limit
	if hasMore {
		notifications = notifications[:limit]
	}
	return notifications, hasMore, nil
}

{% if has_is_read %}
// MarkNotificationAsRead marks a single notification as read, scoped to the owner.
func (r *notificationRepository) MarkNotificationAsRead(id uint, userID uint) error {
	result := r.db.Model(&domain.Notification{}).
		Where("{{ id_field.name }} = ? AND {{ user_id_field.name }} = ?", id, userID).
		Update("{{ is_read_field.name }}", true)
	if result.Error != nil {
		return fmt.Errorf("MarkNotificationAsRead: %w", result.Error)
	}
	if result.RowsAffected == 0 {
		return fmt.Errorf("notification %d not found or access denied", id)
	}
	return nil
}

// MarkAllNotificationsAsRead marks every unread notification for a user as read.
func (r *notificationRepository) MarkAllNotificationsAsRead(userID uint) error {
	if err := r.db.Model(&domain.Notification{}).
		Where("{{ user_id_field.name }} = ? AND {{ is_read_field.name }} = ?", userID, false).
		Update("{{ is_read_field.name }}", true).Error; err != nil {
		return fmt.Errorf("MarkAllNotificationsAsRead: %w", err)
	}
	return nil
}

// MarkNotificationsAsReadBulk marks multiple notifications as read, scoped to the owner.
func (r *notificationRepository) MarkNotificationsAsReadBulk(ids []uint, userID uint) error {
	if len(ids) == 0 {
		return nil
	}
	if err := r.db.Model(&domain.Notification{}).
		Where("{{ id_field.name }} IN ? AND {{ user_id_field.name }} = ?", ids, userID).
		Update("{{ is_read_field.name }}", true).Error; err != nil {
		return fmt.Errorf("MarkNotificationsAsReadBulk: %w", err)
	}
	return nil
}

// GetUnreadNotificationCount returns the number of unread notifications for a user.
func (r *notificationRepository) GetUnreadNotificationCount(userID uint) (int64, error) {
	var count int64
	if err := r.db.Model(&domain.Notification{}).
		Where("{{ user_id_field.name }} = ? AND {{ is_read_field.name }} = ?", userID, false).
		Count(&count).Error; err != nil {
		return 0, fmt.Errorf("GetUnreadNotificationCount: %w", err)
	}
	return count, nil
}
{% endif %}

// DeleteNotification soft-deletes a notification scoped to the owner.
func (r *notificationRepository) DeleteNotification(id uint, userID uint) error {
	result := r.db.Where("{{ id_field.name }} = ? AND {{ user_id_field.name }} = ?", id, userID).Delete(&domain.Notification{})
	if result.Error != nil {
		return fmt.Errorf("DeleteNotification: %w", result.Error)
	}
	if result.RowsAffected == 0 {
		return fmt.Errorf("notification %d not found or access denied", id)
	}
	return nil
}

// DeleteNotificationsBulk soft-deletes multiple notifications scoped to the owner.
func (r *notificationRepository) DeleteNotificationsBulk(ids []uint, userID uint) error {
	if len(ids) == 0 {
		return nil
	}
	if err := r.db.Where("{{ id_field.name }} IN ? AND {{ user_id_field.name }} = ?", ids, userID).Delete(&domain.Notification{}).Error; err != nil {
		return fmt.Errorf("DeleteNotificationsBulk: %w", err)
	}
	return nil
}

