    UpdatedTo   *time.Time `json:"updated_to,omitempty" form:"updated_to"`
}

// List retrieves {{ model.name | lower }}s with filtering, sorting, and pagination
func (r *{{ model.name | lower }}Repository) List(options List{{ model.name }}Options) ([]models.{{ model.name }}, bool, error) {
    var {{ model.name | lower }}s []models.{{ model.name }}

    // Build query
    query := r.db.Model(&models.{{ model.name }}{})

    // Apply filters
    query = r.applyFilters(query, options)

    // Apply sorting
    query = r.applySorting(query, options)

    // Apply preloading
    query = r.applyPreloading(query, options)

{% if model.pagination %}
    // Apply pagination with has_more detection
    hasMore := false
    if options.PageSize > 0 {
        offset := (options.Page - 1) * options.PageSize
        if offset < 0 {
            offset = 0
        }
        // Fetch one extra record to detect if there are more pages
        query = query.Offset(offset).Limit(options.PageSize + 1)
    }
{% endif %}

    // Execute query
    if err := query.Find(&{{ model.name | lower }}s).Error; err != nil {
        return nil, false, fmt.Errorf("failed to fetch {{ model.name | lower }}s: %w", err)
    }

{% if model.pagination %}
    if options.PageSize > 0 && len({{ model.name | lower }}s) > options.PageSize {
        hasMore = true
        {{ model.name | lower }}s = {{ model.name | lower }}s[:options.PageSize]
    }
{% endif %}

    return {{ model.name | lower }}s, hasMore, nil
}

// applyFilters applies all filters to the query
func (r *{{ model.name | lower }}Repository) applyFilters(query *gorm.DB, options List{{ model.name }}Options) *gorm.DB {
{% if model.filters %}
{% for filter in model.filters %}
    {% if filter == 'id' %}
    if options.ID != nil {
        query = query.Where("id = ?", *options.ID)
    }
    {% elif filter == 'user_id' %}
    if options.UserID != nil {
        query = query.Where("user_id = ?", *options.UserID)
    }
    {% elif filter.endswith('_id') %}
    if options.{{ filter | replace('_', ' ') | title | replace(' ', '') }} != nil {
        query = query.Where("{{ filter }} = ?", *options.{{ filter | replace('_', ' ') | title | replace(' ', '') }})
    }
    {% elif filter == 'status' %}
    if options.Status != "" {
        query = query.Where("status = ?", options.Status)
    }
    {% elif filter == 'verified' %}
    if options.Verified != nil {
        query = query.Where("verified = ?", *options.Verified)
    }
    {% elif filter == 'email' %}
    if options.Email != "" {
        query = query.Where("LOWER(email) = LOWER(?)", options.Email)
    }
    {% elif filter == 'role' %}
    if options.Role != "" {
        query = query.Where("role = ?", options.Role)
    }
    {% elif filter == 'search' %}
    if options.Search != "" {
        searchTerm := "%" + strings.ToLower(options.Search) + "%"
        searchConditions := []string{}
        searchValues := []interface{}{}
        
{% if model.search_fields %}
{% for search_field in model.search_fields %}
        searchConditions = append(searchConditions, "LOWER({{ search_field }}) LIKE ?")
        searchValues = append(searchValues, searchTerm)
{% endfor %}
{% else %}
        // Default search fields
        searchConditions = append(searchConditions, "LOWER(id::text) LIKE ?")
        searchValues = append(searchValues, searchTerm)
{% endif %}
        
        query = query.Where(strings.Join(searchConditions, " OR "), searchValues...)
    }
    {% else %}
    if options.{{ filter | replace('_', ' ') | title | replace(' ', '') }} != "" {
        query = query.Where("{{ filter }} = ?", options.{{ filter | replace('_', ' ') | title | replace(' ', '') }})
    }
    {% endif %}
{% endfor %}
{% endif %}

    // Date range filters
    if options.CreatedFrom != nil {
        query = query.Where("created_at >= ?", *options.CreatedFrom)
    }
    if options.CreatedTo != nil {
        query = query.Where("created_at <= ?", *options.CreatedTo)
    }
    if options.UpdatedFrom != nil {
        query = query.Where("updated_at >= ?", *options.UpdatedFrom)
    }
    if options.UpdatedTo != nil {
        query = query.Where("updated_at <= ?", *options.UpdatedTo)
    }

    return query
}

// applySorting applies sorting to the query
func (r *{{ model.name | lower }}Repository) applySorting(query *gorm.DB, options List{{ model.name }}Options) *gorm.DB {
{% if model.sort_by %}
    // Whitelist of allowed sort fields
    allowedSortFields := map[string]bool{
{% for sort_field in model.sort_by %}
        "{{ sort_field }}": true,
{% endfor %}
    }

    sortBy := options.SortBy
    if sortBy == "" || !allowedSortFields[sortBy] {
        sortBy = "{{ model.default_sort_field | default('created_at') }}"
    }

    sortOrder := strings.ToLower(options.SortOrder)
    if sortOrder != "asc" && sortOrder != "desc" {
        sortOrder = "{{ model.default_sort_order | default('desc') }}"
    }

    return query.Order(fmt.Sprintf("%s %s", sortBy, sortOrder))
{% else %}
    return query.Order("created_at desc")
{% endif %}
}

// applyPreloading applies relation preloading to the query
func (r *{{ model.name | lower }}Repository) applyPreloading(query *gorm.DB, options List{{ model.name }}Options) *gorm.DB {
{% if model.relations %}
{% for relation in model.relations %}
    if options.Preload{{ relation.name }} {
    {% if relation.select_fields or relation.order_by or relation.sort_by or relation.limit %}
        query = query.Preload("{{ relation.name }}", func(db *gorm.DB) *gorm.DB {
        {% if relation.select_fields %}
            db = db.Select({{ relation.select_fields | map('tojson') | join(', ') }})
        {% endif %}
        {% if relation.order_by %}
            db = db.Order("{{ relation.order_by }}")
        {% elif relation.sort_by %}
            db = db.Order("{{ relation.sort_by }}")
        {% endif %}
        {% if relation.limit %}
            db = db.Limit({{ relation.limit }})
        {% endif %}
            return db
        })
    {% else %}
        query = query.Preload("{{ relation.name }}")
    {% endif %}
    
    {% if relation.nested_relations %}
    {% for nested in relation.nested_relations %}
        query = query.Preload("{{ relation.name }}.{{ nested.name | capitalize }}"{% if nested.select_fields or nested.order_by or nested.limit %}, func(db *gorm.DB) *gorm.DB {
        {% if nested.select_fields %}
            db = db.Select({{ nested.select_fields | map('tojson') | join(', ') }})
        {% endif %}
        {% if nested.order_by %}
            db = db.Order("{{ nested.order_by }}")
        {% endif %}
        {% if nested.limit %}
            db = db.Limit({{ nested.limit }})
        {% endif %}
            return db
        }{% endif %})
    {% endfor %}
    {% endif %}
    }
{% endfor %}
{% endif %}
    return query
}
{% endif %}

