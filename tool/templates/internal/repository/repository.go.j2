{% if model.soft_delete and model.soft_delete.include_hard_delete %}
// HardDelete permanently deletes a {{ model.name | lower }} by ID
func (r *{{ model.name | lower }}Repository) HardDelete(id uint) error {
    if err := r.db.Unscoped().Delete(&models.{{ model.name }}{}, id).Error; err != nil {
        return fmt.Errorf("failed to hard delete {{ model.name | lower }}: %w", err)
    }
    return nil
}
{% endif %}

{% if model.soft_delete and model.soft_delete.include_restore %}
// Restore restores a soft-deleted {{ model.name | lower }} by ID
func (r *{{ model.name | lower }}Repository) Restore(id uint) error {
    result := r.db.Model(&models.{{ model.name }}{}).
        Unscoped().
        Where("id = ? AND deleted_at IS NOT NULL", id).
        Update("deleted_at", nil)
    
    if result.Error != nil {
        return fmt.Errorf("failed to restore {{ model.name | lower }}: %w", result.Error)
    }
    if result.RowsAffected == 0 {
        return fmt.Errorf("{{ model.name | lower }} not found or not deleted")
    }
    return nil
}
{% endif %}

