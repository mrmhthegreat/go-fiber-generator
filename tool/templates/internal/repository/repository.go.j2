{% if batch_op.name.startswith('BulkUpdate') %}
// {{ batch_op.name }} updates multiple {{ model.name | lower }}s
func (r *{{ model.name | lower }}Repository) {{ batch_op.name }}(ids []uint, updates map[string]interface{}) error {
    if len(ids) == 0 {
        return errors.New("no IDs provided")
    }
    if len(updates) == 0 {
        return errors.New("no updates provided")
    }
    
{% if batch_op.update_fields %}
    // Validate update fields
    allowedFields := map[string]bool{
{% for field in batch_op.update_fields %}
        "{{ field }}": true,
{% endfor %}
    }
    
    for key := range updates {
        if !allowedFields[key] {
            return fmt.Errorf("field '%s' is not allowed for bulk update", key)
        }
    }
{% endif %}
    
    result := r.db.Model(&models.{{ model.name }}{}).
        Where("id IN ?", ids).
        Updates(updates)
    
    if result.Error != nil {
        return fmt.Errorf("failed to bulk update {{ model.name | lower }}s: %w", result.Error)
    }
    return nil
}

{% elif batch_op.name == 'DeleteMultiple' %}
// DeleteMultiple deletes multiple {{ model.name | lower }}s by IDs
func (r *{{ model.name | lower }}Repository) DeleteMultiple(ids []uint) error {
    if len(ids) == 0 {
        return errors.New("no IDs provided")
    }
    
{% if batch_op.soft_delete %}
    result := r.db.Delete(&models.{{ model.name }}{}, "id IN ?", ids)
{% else %}
    result := r.db.Unscoped().Delete(&models.{{ model.name }}{}, "id IN ?", ids)
{% endif %}
    
    if result.Error != nil {
        return fmt.Errorf("failed to delete multiple {{ model.name | lower }}s: %w", result.Error)
    }
    return nil
}

