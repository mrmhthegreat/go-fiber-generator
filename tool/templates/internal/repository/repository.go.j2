// BatchCreate creates multiple {{ model.name | lower }}s in a single transaction
func (r *{{ model.name | lower }}Repository) BatchCreate(items []models.{{ model.name }}) error {
    if len(items) == 0 {
        return errors.New("no items provided")
    }
    
    return r.db.CreateInBatches(&items, {{ batch_op.batch_size | default(100) }}).Error
}
