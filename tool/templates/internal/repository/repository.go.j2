{% for getter in model.custom_getters %}
    {% if getter.pagination or getter.filters or getter.sort_by %}
    {{ getter.name }}({% for field in getter.fields %}{{ field | lower }} {{ getter.field_types[loop.index0] | default('string') }}, {% endfor %}options {{ getter.name }}Options) ([]models.{{ model.name }}, bool, error)
