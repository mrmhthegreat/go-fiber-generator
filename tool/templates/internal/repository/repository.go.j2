// GetByID retrieves a {{ model.name | lower }} by ID
func (r *{{ model.name | lower }}Repository) GetByID(id uint) (*models.{{ model.name }}, error) {
    var {{ model.name | lower }} models.{{ model.name }}
    if err := r.db.First(&{{ model.name | lower }}, id).Error; err != nil {
        if errors.Is(err, gorm.ErrRecordNotFound) {
            return nil, fmt.Errorf("{{ model.name | lower }} not found")
        }
        return nil, fmt.Errorf("failed to fetch {{ model.name | lower }}: %w", err)
    }
    return &{{ model.name | lower }}, nil
}

