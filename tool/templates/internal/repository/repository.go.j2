func (r *{{ model.name | lower }}Repository) Update({{ model.name | lower }} *models.{{ model.name }}) error {
    if err := r.db.Save({{ model.name | lower }}).Error; err != nil {
        return fmt.Errorf("failed to update {{ model.name | lower }}: %w", err)
    }
    return nil
}

// Delete deletes a {{ model.name | lower }} by ID
func (r *{{ model.name | lower }}Repository) Delete(id uint) error {
{% if model.soft_delete %}
    if err := r.db.Delete(&models.{{ model.name }}{}, id).Error; err != nil {
        return fmt.Errorf("failed to delete {{ model.name | lower }}: %w", err)
    }
{% else %}
    if err := r.db.Delete(&models.{{ model.name }}{}, id).Error; err != nil {
