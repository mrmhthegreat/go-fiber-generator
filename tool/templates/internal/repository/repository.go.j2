// List{{ model.name }}Options defines the options for filtering and sorting {{ model.name | lower }}s
type List{{ model.name }}Options struct {
{% if model.pagination %}
    // Pagination
    Page     int `json:"page" form:"page"`
    PageSize int `json:"page_size" form:"page_size"`
{% endif %}

{% if model.filters %}
    // Filters
{% for filter in model.filters %}
    {% if filter == 'id' %}
    ID *uint `json:"id,omitempty" form:"id"`
    {% elif filter == 'user_id' %}
    UserID *uint `json:"user_id,omitempty" form:"user_id"`
    {% elif filter.endswith('_id') %}
    {{ filter | replace('_', ' ') | title | replace(' ', '') }} *uint `json:"{{ filter }},omitempty" form:"{{ filter }}"`
    {% elif filter == 'status' %}
    Status string `json:"status,omitempty" form:"status"`
    {% elif filter == 'verified' %}
    Verified *bool `json:"verified,omitempty" form:"verified"`
    {% elif filter == 'email' %}
    Email string `json:"email,omitempty" form:"email"`
    {% elif filter == 'role' %}
    Role string `json:"role,omitempty" form:"role"`
    {% elif filter == 'search' %}
    Search string `json:"search,omitempty" form:"search"`
    {% else %}
    {{ filter | replace('_', ' ') | title | replace(' ', '') }} string `json:"{{ filter }},omitempty" form:"{{ filter }}"`
    {% endif %}
{% endfor %}
{% endif %}

{% if model.sort_by %}
