// -------------------------------------------------------------------------
// Mutations
// -------------------------------------------------------------------------

// CreateUser inserts a new {{ model }} record and returns it with its generated ID populated
func (r *{{ repo_name | lower | replace('repository', 'Repo') }}) CreateUser(user *domain.{{ model }}) (*domain.{{ model }}, error) {
	if err := r.db.Create(user).Error; err != nil {
		return nil, fmt.Errorf("failed to create user: %w", err)
	}
	return user, nil
}

// UpdateUser applies arbitrary field updates to the {{ model }} with the given ID.
// Pass only the fields you want to change, e.g. map[string]interface{}{"verified": true}
func (r *{{ repo_name | lower | replace('repository', 'Repo') }}) UpdateUser(id uint, updates map[string]interface{}) error {
	result := r.db.Model(&domain.{{ model }}{}).Where("id = ?", id).Updates(updates)
	if result.Error != nil {
		return fmt.Errorf("failed to update user: %w", result.Error)
	}
	if result.RowsAffected == 0 {
		return fmt.Errorf("user not found")
	}
	return nil
}

{% if auth.email_password.email_verification.enabled %}
// UpdateUserVerification sets the {{ auth.email_password.email_verification.model_field }} field for the user
// identified by email address
func (r *{{ repo_name | lower | replace('repository', 'Repo') }}) UpdateUserVerification(identifier string, verified bool) error {
	result := r.db.Model(&domain.{{ model }}{}).
		Where("LOWER(email) = LOWER(?)", identifier).
		Update("{{ auth.email_password.email_verification.model_field | lower }}", verified)
	if result.Error != nil {
		return fmt.Errorf("failed to update verification status: %w", result.Error)
	}
	if result.RowsAffected == 0 {
		return fmt.Errorf("user not found")
	}
	return nil
}

{% endif %}
{% if auth.email_password.forgot_password.enabled or auth.email_password.change_password.enabled %}
// UpdateUserPassword replaces the stored hashed password for the user identified by email
func (r *{{ repo_name | lower | replace('repository', 'Repo') }}) UpdateUserPassword(identifier string, hashedPassword string) error {
	result := r.db.Model(&domain.{{ model }}{}).
		Where("LOWER(email) = LOWER(?)", identifier).
		Update("password", hashedPassword)
	if result.Error != nil {
		return fmt.Errorf("failed to update password: %w", result.Error)
	}
	if result.RowsAffected == 0 {
		return fmt.Errorf("user not found")
	}
	return nil
}

{% endif %}