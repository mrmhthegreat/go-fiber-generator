// {{ auth.social_auth.google.repository_method }} finds a {{ model }} by Google OAuth ID
func (r *{{ repo_name | lower | replace('repository', 'Repo') }}) {{ auth.social_auth.google.repository_method }}(googleID string) (*domain.{{ model }}, error) {
