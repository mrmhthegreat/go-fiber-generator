	if err := r.db.Where("LOWER(email) = LOWER(?)", {{ method.field }}).First(&user).Error; err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) {
			return nil, fmt.Errorf("user not found")
		}
		return nil, fmt.Errorf("failed to find user by email: %w", err)
	}
	return &user, nil
}
{% elif method.field == 'username' %}
// {{ method.repository_method }} finds a {{ model }} by username
func (r *{{ repo_name | lower | replace('repository', 'Repo') }}) {{ method.repository_method }}({{ method.field }} string) (*domain.{{ model }}, error) {
	var user domain.{{ model }}
	if err := r.db.Where("LOWER(username) = LOWER(?)", {{ method.field }}).First(&user).Error; err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) {
			return nil, fmt.Errorf("user not found")
		}
		return nil, fmt.Errorf("failed to find user by username: %w", err)
	}
	return &user, nil
}
{% else %}
// {{ method.repository_method }} finds a {{ model }} by {{ method.field }}
func (r *{{ repo_name | lower | replace('repository', 'Repo') }}) {{ method.repository_method }}({{ method.field }} string) (*domain.{{ model }}, error) {
	var user domain.{{ model }}
	if err := r.db.Where("{{ method.field }} = ?", {{ method.field }}).First(&user).Error; err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) {
			return nil, fmt.Errorf("user not found")
		}
		return nil, fmt.Errorf("failed to find user by {{ method.field }}: %w", err)
	}
	return &user, nil
}
{% endif %}

