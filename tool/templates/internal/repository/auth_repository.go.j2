// UpdateUserPassword replaces the stored hashed password for the user identified by ID
func (r *{{  repo_var | lower | replace('repository', 'Repo') }}) UpdateUserPassword(id uint, hashedPassword string) error {
	result := r.db.Model(&domain.{{ model }}{}).
		Where("id = ?", id).
		Update("password", hashedPassword)
	if result.Error != nil {
		return fmt.Errorf("failed to update password: %w", result.Error)
	}
	if result.RowsAffected == 0 {
		return fmt.Errorf("user not found")
	}
	return nil
