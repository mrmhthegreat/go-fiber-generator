{% if model.custom_getters %}
{% for getter in model.custom_getters %}
{% if getter.response_type == 'custom' and getter.custom_response %}

{% set cr = getter.custom_response %}

{# ---- Nested sub-structs for each preload relation ---- #}
{% for prel in cr.preload_relations %}

{# -- Deep nested sub-structs (nested_responses inside this preload) -- #}
{% for nr in prel.nested_responses %}
// {{ nr.struct }} represents the nested {{ nr.name }} in {{ prel.struct }}
type {{ nr.struct }} struct {
{% for f in nr.typed_fields %}
{% if f.omitempty %}
    {{ f.go_name }} {{ f.type }} `json:"{{ f.json_name }},omitempty"`
{% else %}
    {{ f.go_name }} {{ f.type }} `json:"{{ f.json_name }}"`
{% endif %}
{% endfor %}
}
{% endfor %}

// {{ prel.struct }} represents the {{ prel.name }} relation in {{ cr.name }}
type {{ prel.struct }} struct {
{% for f in prel.typed_fields %}
{% if f.omitempty %}
    {{ f.go_name }} {{ f.type }} `json:"{{ f.json_name }},omitempty"`
{% else %}
    {{ f.go_name }} {{ f.type }} `json:"{{ f.json_name }}"`
{% endif %}
{% endfor %}
{% for nr in prel.nested_responses %}
{% if nr.rel_type == 'list' %}
    {{ nr.name }} []{{ nr.struct }} `json:"{{ nr.name | lower }},omitempty"`
{% else %}
    {{ nr.name }} *{{ nr.struct }} `json:"{{ nr.name | lower }},omitempty"`
{% endif %}
{% endfor %}
}

{% endfor %}

{# ---- Main custom response struct ---- #}
// {{ cr.name }} represents custom response for {{ getter.name }}
type {{ cr.name }} struct {
{% for field in cr.fields %}
{% if field.get('omitempty') %}
    {{ field.name }} {{ field.type }} `json:"{{ field.json_name }},omitempty"`
{% else %}
    {{ field.name }} {{ field.type }} `json:"{{ field.json_name }}"`
{% endif %}
{% endfor %}
{% for prel in cr.preload_relations %}
{% if prel.rel_type == 'list' %}
    {{ prel.name }} []{{ prel.struct }} `json:"{{ prel.name | lower }},omitempty"`
{% else %}
    {{ prel.name }} *{{ prel.struct }} `json:"{{ prel.name | lower }},omitempty"`
{% endif %}
{% endfor %}
}

// To{{ cr.name }} converts model to custom response
func To{{ cr.name }}(m *models.{{ model.name }}) {{ cr.name }} {
    if m == nil {
        return {{ cr.name }}{}
    }
    
    resp := {{ cr.name }}{
{% for field in cr.fields %}
        {{ field.name }}: m.{{ field.from_field }},
{% endfor %}
    }
    
{% for prel in cr.preload_relations %}
{% if prel.rel_type == 'list' %}
    for _, src := range m.{{ prel.name }} {
        nested := {{ prel.struct }}{
{% for f in prel.typed_fields %}
            {{ f.go_name }}: src.{{ f.from_field }},
{% endfor %}
        }
{% for nr in prel.nested_responses %}
{% if nr.rel_type == 'list' %}
        for _, nsrc := range src.{{ nr.name }} {
            nested.{{ nr.name }} = append(nested.{{ nr.name }}, {{ nr.struct }}{
{% for f in nr.typed_fields %}
                {{ f.go_name }}: nsrc.{{ f.from_field }},
{% endfor %}
            })
        }
{% else %}
        if src.{{ nr.name }} != nil {
            nitem := {{ nr.struct }}{
{% for f in nr.typed_fields %}
                {{ f.go_name }}: src.{{ nr.name }}.{{ f.from_field }},
{% endfor %}
            }
            nested.{{ nr.name }} = &nitem
        }
{% endif %}
{% endfor %}
        resp.{{ prel.name }} = append(resp.{{ prel.name }}, nested)
    }
{% else %}
    if m.{{ prel.name }} != nil {
        nested := {{ prel.struct }}{
{% for f in prel.typed_fields %}
            {{ f.go_name }}: m.{{ prel.name }}.{{ f.from_field }},
{% endfor %}
        }
{% for nr in prel.nested_responses %}
{% if nr.rel_type == 'list' %}
        for _, nsrc := range m.{{ prel.name }}.{{ nr.name }} {
            nested.{{ nr.name }} = append(nested.{{ nr.name }}, {{ nr.struct }}{
{% for f in nr.typed_fields %}
                {{ f.go_name }}: nsrc.{{ f.from_field }},
{% endfor %}
            })
        }
{% else %}
        if m.{{ prel.name }}.{{ nr.name }} != nil {
            nitem := {{ nr.struct }}{
{% for f in nr.typed_fields %}
                {{ f.go_name }}: m.{{ prel.name }}.{{ nr.name }}.{{ f.from_field }},
{% endfor %}
            }
            nested.{{ nr.name }} = &nitem
        }
{% endif %}
{% endfor %}
        resp.{{ prel.name }} = &nested
    }
{% endif %}
{% endfor %}
    
    return resp
}

{% if not getter.unique %}
// To{{ cr.name }}List converts models to custom responses
func To{{ cr.name }}List(ms []models.{{ model.name }}) []{{ cr.name }} {
    items := make([]{{ cr.name }}, len(ms))
    for i := range ms {
        items[i] = To{{ cr.name }}(&ms[i])
    }
    return items
}
{% endif %}

{% endif %}
{% endfor %}
{% endif %}