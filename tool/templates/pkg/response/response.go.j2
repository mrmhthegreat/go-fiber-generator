// To{{ model.name }}DetailResponse converts a model to detail response with nil checks
func To{{ model.name }}DetailResponse(m *models.{{ model.name }}) {{ model.name }}DetailResponse {
    if m == nil {
        return {{ model.name }}DetailResponse{}
    }

    resp := {{ model.name }}DetailResponse{
{% for field in model.detail_resppkg.fields %}
        {{ field.name }}: m.{{ field.from_field }},
{% endfor %}
    }

{% for relation in model.detail_resppkg.get('include_relations', []) %}
{% if relation.response_type == 'nested_list' %}
    if len(m.{{ relation.name }}) > 0 {
        resp.{{ relation.name }} = To{{ relation.response_struct }}s(m.{{ relation.name }})
    }
{% elif relation.response_type == 'nested_detail' %}
    if m.{{ relation.name }} != nil {
        v := To{{ relation.response_struct }}(m.{{ relation.name }})
        resp.{{ relation.name }} = &v
    }
{% elif relation.response_type == 'id_only' %}
    if m.{{ relation.foreign_key }} != nil && *m.{{ relation.foreign_key }} > 0 {
        resp.{{ relation.name }}ID = m.{{ relation.foreign_key }}
    }
{% endif %}
{% endfor %}

    return resp
}

