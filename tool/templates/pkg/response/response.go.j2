package response

import (
{% if model.has_time_fields or model.timestamps %}
    "time"
{% endif %}
{% if model.has_json_fields %}
    "gorm.io/datatypes"
{% endif %}

    "{{ config.project.module }}/internal/domain"
)

{% if model.list_response and model.list_resppkg.enabled %}
// {{ model.name }}ListItem represents a {{ model.name | lower }} in list view
type {{ model.name }}ListItem struct {
{% for field in model.list_resppkg.fields %}
{% if field.omitempty %}
    {{ field.name }} {{ field.type }} `json:"{{ field.json_name }},omitempty"`
{% else %}
    {{ field.name }} {{ field.type }} `json:"{{ field.json_name }}"`
{% endif %}
{% endfor %}
{% for relation in model.list_resppkg.get('include_relations', []) %}
{% if relation.response_type == 'nested_list' %}
    {{ relation.name }} []{{ relation.response_struct }} `json:"{{ relation.json_name }},omitempty"`
{% elif relation.response_type == 'nested_detail' %}
    {{ relation.name }} *{{ relation.response_struct }} `json:"{{ relation.json_name }},omitempty"`
{% elif relation.response_type == 'id_only' %}
    {{ relation.name }}ID *uint `json:"{{ relation.json_name }}_id,omitempty"`
{% endif %}
{% endfor %}
}

// To{{ model.name }}ListItem converts a model to list response
func To{{ model.name }}ListItem(m *models.{{ model.name }}) {{ model.name }}ListItem {
    if m == nil {
        return {{ model.name }}ListItem{}
    }

    item := {{ model.name }}ListItem{
{% for field in model.list_resppkg.fields %}
        {{ field.name }}: m.{{ field.from_field }},
{% endfor %}
    }

{% for relation in model.list_resppkg.get('include_relations', []) %}
{% if relation.response_type == 'nested_list' %}
    if len(m.{{ relation.name }}) > 0 {
        item.{{ relation.name }} = To{{ relation.response_struct }}s(m.{{ relation.name }})
    }
{% elif relation.response_type == 'nested_detail' %}
    if m.{{ relation.name }} != nil {
        v := To{{ relation.response_struct }}(m.{{ relation.name }})
        item.{{ relation.name }} = &v
    }
{% elif relation.response_type == 'id_only' %}
    if m.{{ relation.foreign_key }} != nil && *m.{{ relation.foreign_key }} > 0 {
        item.{{ relation.name }}ID = m.{{ relation.foreign_key }}
    }
{% endif %}
{% endfor %}

    return item
}

// To{{ model.name }}ListItems converts multiple models to list responses
func To{{ model.name }}ListItems(ms []models.{{ model.name }}) []{{ model.name }}ListItem {
    items := make([]{{ model.name }}ListItem, len(ms))
    for i := range ms {
        items[i] = To{{ model.name }}ListItem(&ms[i])
    }
    return items
}

// {{ model.name }}ListResponse represents a paginated list of {{ model.name | lower }}s
type {{ model.name }}ListResponse struct {
    Data     []{{ model.name }}ListItem `json:"data"`
    HasMore  bool                       `json:"has_more"`
    Page     int                        `json:"page,omitempty"`
    PageSize int                        `json:"page_size,omitempty"`
}

// New{{ model.name }}ListResponse creates a paginated list response
func New{{ model.name }}ListResponse(items []{{ model.name }}ListItem, hasMore bool, page, pageSize int) {{ model.name }}ListResponse {
    return {{ model.name }}ListResponse{
        Data:     items,
        HasMore:  hasMore,
        Page:     page,
        PageSize: pageSize,
    }
}

{% endif %}

