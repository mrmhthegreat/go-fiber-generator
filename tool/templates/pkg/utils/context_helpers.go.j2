package contexthelpers

import (
	{% if config.websocket.enabled %}
	"github.com/gofiber/contrib/websocket"
	{% endif %}
	"github.com/gofiber/fiber/v2"
	{% if config.session.enabled %}
	"github.com/gofiber/fiber/v2/middleware/session"
	"fmt"
	{% endif %}
	{% if config.redis.enabled %}
	"github.com/redis/go-redis/v9"
	{% endif %}

	"{{ config.project.module }}/db"
)

// ═══════════════════════════════════════════════════════════════════════════
// DATABASE
// ═══════════════════════════════════════════════════════════════════════════

// GetDB retrieves the GormDatabase instance from Fiber context locals
func GetDB(c *fiber.Ctx) *db.GormDatabase {
	dbObj := c.Locals("db")
	if dbObj == nil {
		panic("database not found in context — is the db middleware registered?")
	}
	return dbObj.(*db.GormDatabase)
}

{% if config.websocket.enabled %}
// GetDBW retrieves the GormDatabase instance from a WebSocket connection context
func GetDBW(c *websocket.Conn) *db.GormDatabase {
	dbObj := c.Locals("db")
	if dbObj == nil {
		panic("database not found in websocket context")
	}
	return dbObj.(*db.GormDatabase)
}
{% endif %}

// ═══════════════════════════════════════════════════════════════════════════
// GENERATED MODEL REPOSITORIES
// One getter per model defined in config.models
// ═══════════════════════════════════════════════════════════════════════════

{% for model in config.models | default([]) %}
// Get{{ model.name }}Repository returns the {{ model.name }} repository from the database
func Get{{ model.name }}Repository(database *db.GormDatabase) db.{{ model.name }}Repository {
	return database.{{ model.name }}
}

// Get{{ model.name }}Repo is a shorthand that reads DB from Fiber context and returns the {{ model.name }} repository
func Get{{ model.name }}Repo(c *fiber.Ctx) db.{{ model.name }}Repository {
	return GetDB(c).{{ model.name }}
}
{% endfor %}

