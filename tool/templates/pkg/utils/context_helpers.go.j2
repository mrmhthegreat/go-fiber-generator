// ═══════════════════════════════════════════════════════════════════════════
// SESSION
// ═══════════════════════════════════════════════════════════════════════════

{% if config.session.enabled %}
// GetSession retrieves the session from Fiber context
func GetSession(c *fiber.Ctx) (*session.Session, error) {
	sess, ok := c.Locals("session").(*session.Session)
	if !ok {
		return nil, fmt.Errorf("session not found in context")
	}
	return sess, nil
}

// MustGetSession retrieves the session or panics
func MustGetSession(c *fiber.Ctx) *session.Session {
	sess, err := GetSession(c)
	if err != nil {
		panic(err.Error())
	}
	return sess
}
{% endif %}

// ═══════════════════════════════════════════════════════════════════════════
// REDIS / CACHE
// ═══════════════════════════════════════════════════════════════════════════

{% if config.redis.enabled %}
// GetCache retrieves the Redis client from context
func GetCache(c *fiber.Ctx) *redis.Client {
	cache, ok := c.Locals("cache").(*redis.Client)
	if !ok {
		panic("redis cache not found in context — is the cache middleware registered?")
	}
	return cache
}
{% endif %}

// ═══════════════════════════════════════════════════════════════════════════
// USER ID HELPERS
// ═══════════════════════════════════════════════════════════════════════════

// GetUserID returns the uint user ID stored in Locals (set by JWT/session middleware)
func GetUserID(c *fiber.Ctx) uint {
	raw := c.Locals("user_id")
	if raw == nil {
		return 0
	}
	switch v := raw.(type) {
	case uint:
		return v
	case float64:
		return uint(v)
	case int:
		return uint(v)
	}
	return 0
}

{% config.rbac.enable %}
// GetRole returns the role string from Locals
func GetRole(c *fiber.Ctx) string {
	raw := c.Locals("role")
	if raw == nil {
		return ""
	}
	if s, ok := raw.(string); ok {
		return s
	}
	return ""
}
{% endif %}
