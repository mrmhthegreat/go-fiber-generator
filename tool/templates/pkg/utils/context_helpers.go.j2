package utilspkg

import (
	{% if config.websocket.enabled %}
	"github.com/gofiber/contrib/websocket"
	{% endif %}
	"github.com/gofiber/fiber/v2"
	
	{% if config.redis.enabled %}
	"github.com/redis/go-redis/v9"
	{% endif %}

	"{{ config.project.module }}/db"
)

// ═══════════════════════════════════════════════════════════════════════════
// DATABASE
// ═══════════════════════════════════════════════════════════════════════════

// GetDB retrieves the GormDatabase instance from Fiber context locals
func GetDB(c *fiber.Ctx) *db.GormDatabase {
	dbObj := c.Locals("db")
	if dbObj == nil {
		panic("database not found in context — is the db middleware registered?")
	}
	return dbObj.(*db.GormDatabase)
}

{% if config.websocket.enabled %}
// GetDBW retrieves the GormDatabase instance from a WebSocket connection context
func GetDBW(c *websocket.Conn) *db.GormDatabase {
	dbObj := c.Locals("db")
	if dbObj == nil {
		panic("database not found in websocket context")
	}
	return dbObj.(*db.GormDatabase)
}
{% endif %}

// ═══════════════════════════════════════════════════════════════════════════
// REDIS / CACHE
// ═══════════════════════════════════════════════════════════════════════════

{% if config.redis.enabled %}
// GetCache retrieves the Redis client from context
func GetCache(c *fiber.Ctx) *redis.Client {
	cache, ok := c.Locals("cache").(*redis.Client)
	if !ok {
		panic("redis cache not found in context — is the cache middleware registered?")
	}
	return cache
}
{% endif %}

// ═══════════════════════════════════════════════════════════════════════════
// USER ID HELPERS
// ═══════════════════════════════════════════════════════════════════════════

// GetUserID returns the uint user ID stored in Locals (set by JWT/session middleware)
func GetUserID(c *fiber.Ctx) uint {
	raw := c.Locals("user_id")
	if raw == nil {
		return 0
	}
	switch v := raw.(type) {
	case uint:
		return v
	case float64:
		return uint(v)
	case int:
		return uint(v)
	}
	return 0
}

{% if config.rbac.enabled %}
// GetRole returns the role string from Locals
func GetRole(c *fiber.Ctx) string {
	raw := c.Locals("role")
	if raw == nil {
		return ""
	}
	if s, ok := raw.(string); ok {
		return s
	}
	return ""
}
{% endif %}
