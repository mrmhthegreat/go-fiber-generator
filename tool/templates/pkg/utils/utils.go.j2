{% if config.session.enabled %}
// GetSession retrieves session from Fiber context
func GetSession(c *fiber.Ctx) (*session.Session, error) {
sess, ok := c.Locals("session").(*session.Session)
if !ok {
return nil, fmt.Errorf("session not found in context")
}
return sess, nil
}
{% endif %}



// GetFormValue safely gets form value
func GetFormValue(form *multipart.Form, key string) string {
if values, ok := form.Value[key]; ok && len(values) > 0 {
return values[0]
}
return ""
}

{% if config.helpers.math_helpers %}
// RoundToTwoDecimals rounds to two decimal places for monetary values
func RoundToTwoDecimals(amount float64) float64 {
return math.Round(amount*100) / 100
}

// FixAmount is an alias for RoundToTwoDecimals
func FixAmount(amount float64) float64 {
return RoundToTwoDecimals(amount)
}

// CalculatePercentage calculates percentage of a value
func CalculatePercentage(value, percentage float64) float64 {
return RoundToTwoDecimals((value * percentage) / 100)
}
{% endif %}

