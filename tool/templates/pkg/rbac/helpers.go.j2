// HasPerm checks if the current user in the context has a specific permission
// Use this in controllers to conditionally show/hide features
func HasPerm(c *fiber.Ctx, rbacService *RBACService, permissionKey string) bool {
    userID, ok := c.Locals("user_id").(uint)
    if !ok {
        return false
    }

    ctx := context.Background()
    hasPermission, err := rbacService.HasPermission(ctx, userID, permissionKey)
    if err != nil {
        return false
    }

    return hasPermission
}

// GetUserPermsMap returns a map of all permissions for the current user
// Use this to pass to templates for client-side permission checks
func GetUserPermsMap(c *fiber.Ctx, rbacService *RBACService) map[string]bool {
    userID, ok := c.Locals("user_id").(uint)
    if !ok {
        return make(map[string]bool)
    }

    ctx := context.Background()
    perms, err := rbacService.GetUserPermissions(ctx, userID)
    if err != nil {
        return make(map[string]bool)
    }

    return perms
}

// GetUserPermsForTemplate returns a simplified permission map for templates
// Converts dots to underscores for easier template usage
// e.g., "orders.view" becomes "orders_view"
func GetUserPermsForTemplate(c *fiber.Ctx, rbacService *RBACService) map[string]bool {
    perms := GetUserPermsMap(c, rbacService)
    templatePerms := make(map[string]bool)

    for key, val := range perms {
        // Replace dots with underscores for template compatibility
        templateKey := key
        // You can also create a simplified version if needed
        templatePerms[templateKey] = val
    }



    return templatePerms
}

// CheckOwnership verifies if the user owns a resource
// This is a helper for implementing "view_own" type permissions
func CheckOwnership(c *fiber.Ctx, resourceOwnerID uint) bool {
    userID, ok := c.Locals("user_id").(uint)
    if !ok {
        return false
    }
    return userID == resourceOwnerID
}

// CanViewResource checks if user can view a resource (either has global view or owns it)
func CanViewResource(c *fiber.Ctx, rbacService *RBACService, globalPerm, ownPerm string, ownerID uint) bool {
    // Check global permission first
    if HasPerm(c, rbacService, globalPerm) {
        return true
    }

    // Check own permission + ownership
    if HasPerm(c, rbacService, ownPerm) && CheckOwnership(c, ownerID) {
        return true
    }

    return false
}



