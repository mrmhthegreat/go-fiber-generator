{% if config.authentication.email_password.enabled %}
// HashPassword hashes a password using bcrypt
func HashPassword(password string) (string, error) {
bytes, err := bcrypt.GenerateFromPassword([]byte(password), {{ config.authentication.email_password.bcrypt_cost | default(14) }})
return string(bytes), err
}

// CheckPasswordHash compares a password with a hash
func CheckPasswordHash(password, hash string) bool {
err := bcrypt.CompareHashAndPassword([]byte(hash), []byte(password))
return err == nil
}

{% if config.authentication.email_password.password_validation %}
// ValidatePassword validates password strength
func ValidatePassword(password string, lang string) error {
{% set min_length = config.authentication.email_password.password_validation.min_length | default(8) %}
if len(password) < {{ min_length }} {
return fmt.Errorf("password must be at least {{ min_length }} characters")
}

{% if config.authentication.email_password.password_validation.require_uppercase %}
if !strings.ContainsAny(password, "ABCDEFGHIJKLMNOPQRSTUVWXYZ") {
return fmt.Errorf("password must contain at least one uppercase letter")
}
{% endif %}

{% if config.authentication.email_password.password_validation.require_lowercase %}
if !strings.ContainsAny(password, "abcdefghijklmnopqrstuvwxyz") {
return fmt.Errorf("password must contain at least one lowercase letter")
}
{% endif %}

{% if config.authentication.email_password.password_validation.require_number %}
if !strings.ContainsAny(password, "0123456789") {
return fmt.Errorf("password must contain at least one number")
}
{% endif %}

{% if config.authentication.email_password.password_validation.require_special %}
if !strings.ContainsAny(password, "!@#$%^&*()_+-=[]{}|;:,.<>?") {
return fmt.Errorf("password must contain at least one special character")
}
{% endif %}

return nil
}
{% endif %}
