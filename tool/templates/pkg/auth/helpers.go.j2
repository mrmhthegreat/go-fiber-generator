{% if config.authentication.email_password.email_verification.enabled or config.authentication.email_password.forgot_password.enabled %}
// OTP storage (in-memory for simplicity, use Redis in production)
var otpStore = make(map[string]OTPData)

type OTPData struct {
Code      string
ExpiresAt time.Time
}

// GenerateOTP generates a random OTP
func GenerateOTP() string {
{% set otp_length = config.authentication.email_password.email_verification.otp_length | default(6) %}
const otpLength = {{ otp_length }}
const digits = "0123456789"

otp := make([]byte, otpLength)
for i := range otp {
num, _ := rand.Int(rand.Reader, big.NewInt(int64(len(digits))))
otp[i] = digits[num.Int64()]
}

return string(otp)
}

// StoreOTP stores an OTP for an email
func StoreOTP(email, otp string) {
{% set otp_expiry = config.authentication.email_password.email_verification.otp_expiry | default('10m') %}
expiry, _ := time.ParseDuration("{{ otp_expiry }}")
otpStore[email] = OTPData{
Code:      otp,
ExpiresAt: time.Now().Add(expiry),
}
//config.RedisCache.Set(config.Ctx, email, otp, expiry)

}

// VerifyOTP verifies an OTP for an email
func VerifyOTP(email, otp string) bool {
// storedOTP, err := config.RedisCache.Get(config.Ctx, email).Result()

data, exists := otpStore[email]
if !exists {
return false
}

if time.Now().After(data.ExpiresAt) {
delete(otpStore, email)
return false
}

if data.Code != otp {
return false
}

delete(otpStore, email)
//config.RedisCache.Del(config.Ctx, email)

return true
}

func DeleteOTP(email string) bool {
delete(otpStore, email)
//config.RedisCache.Del(config.Ctx, email)
return true
}
